---
import PublicLayout from '../layouts/PublicLayout.astro';
import { PLANS, formatCents, getAnnualSavingsCents, getMonthlyEquivalentCents } from '../lib/pricing';

const faqs = [
  {
    q: 'Does FindToursIn charge commission on bookings?',
    a: 'No. We charge a flat monthly subscription and take 0% commission. When a traveller contacts you through FindToursIn, you keep 100% of the booking revenue.',
  },
  {
    q: 'Are there any hidden fees?',
    a: 'No hidden fees. You pay the monthly (or annual) subscription price listed plus VAT where applicable. Stripe handles payment securely.',
  },
  {
    q: 'Can I change or cancel my plan later?',
    a: 'Yes. You can upgrade, downgrade, or cancel at any time from your agency dashboard. Cancellations take effect at the end of the current billing period.',
  },
  {
    q: 'How do travellers contact us?',
    a: 'Travellers reach you directly via the email, phone, or website you provide on each listing — no middleman. You handle the booking and payment the way you already do.',
  },
  {
    q: 'What happens if I exceed my listing limit?',
    a: 'You can upgrade to the next plan at any time. We will notify you before you hit your limit so you can decide.',
  },
  {
    q: 'Do you offer a free trial?',
    a: 'We offer a 14-day money-back guarantee on your first subscription — if FindToursIn does not work for you, email us and we will refund your first payment.',
  },
];

const metaDescription = 'Simple, transparent pricing for tour agencies. 0% commission, flat monthly subscription starting at €39.99/month. List your tours and keep 100% of every booking.';
---

<PublicLayout
  title="Pricing — 0% Commission Tour Agency Plans"
  description={metaDescription}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
      <span class="inline-flex items-center gap-2 bg-green-100 text-green-800 text-xs font-semibold uppercase tracking-wide px-3 py-1.5 rounded-full mb-6">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
        0% Commission · Keep 100% of your revenue
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Simple pricing.<br />No surprises.
      </h1>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Flat monthly subscription. Zero commission. Pick the plan that matches the number of tours you want to list — upgrade or cancel any time.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <!-- Billing Toggle -->
    <div class="flex items-center justify-center gap-4 mb-10">
      <span id="label-monthly" class="text-sm font-semibold text-gray-900 transition-colors">Monthly</span>
      <button
        id="billing-toggle"
        class="relative w-16 h-8 bg-gray-300 rounded-full transition-colors duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-300 focus:ring-offset-2"
        aria-label="Toggle billing period"
      >
        <span id="toggle-dot" class="absolute top-1 left-1 w-6 h-6 bg-white rounded-full shadow-md transition-transform duration-300"></span>
      </button>
      <span id="label-annual" class="text-sm font-semibold text-gray-400 transition-colors">
        Annual
        <span class="inline-flex items-center ml-1.5 px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700">Save 15%</span>
      </span>
    </div>

    <!-- Plan Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-16">
      {PLANS.map((plan) => {
        const monthlyEquiv = getMonthlyEquivalentCents(plan, 'monthly');
        const annualEquiv = getMonthlyEquivalentCents(plan, 'annual');
        const annualSavings = getAnnualSavingsCents(plan);
        const isPopular = !!plan.popular;

        return (
          <div
            class:list={[
              'plan-card relative flex flex-col bg-white rounded-2xl border-2 p-8 transition-all duration-300',
              isPopular
                ? 'border-primary-500 shadow-lg shadow-primary-100 scale-[1.02]'
                : 'border-gray-200 hover:border-gray-300 hover:shadow-md',
            ]}
            data-plan-id={plan.id}
          >
            {isPopular && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center gap-1 bg-primary-600 text-white text-xs font-bold uppercase tracking-wide px-4 py-1.5 rounded-full shadow-sm">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  Most Popular
                </span>
              </div>
            )}

            <h3 class="text-xl font-bold text-gray-900 mb-1">{plan.name}</h3>
            <p class="text-sm text-gray-500 mb-6">Up to {plan.maxListings} listings</p>

            <div class="price-monthly mb-1">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-gray-900">&euro;{formatCents(monthlyEquiv)}</span>
              </div>
              <p class="text-sm text-gray-500 mt-1">per month <span class="text-gray-400">+ VAT</span></p>
            </div>

            <div class="price-annual hidden mb-1">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-gray-900">&euro;{formatCents(annualEquiv)}</span>
              </div>
              <p class="text-sm text-gray-500 mt-1">per month, billed annually <span class="text-gray-400">+ VAT</span></p>
            </div>


            <div class="annual-savings hidden mb-4">
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-green-600">
                Save &euro;{formatCents(annualSavings)} per year
              </span>
            </div>
            <div class="annual-savings-spacer mb-4"></div>

            <div class="border-t border-gray-100 mb-6"></div>

            <ul class="space-y-3 mb-8 flex-1">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-gray-600">{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={`/auth/register?role=agency&plan=${plan.id}`}
              class:list={[
                'mt-auto w-full py-3 px-6 rounded-xl font-semibold text-sm text-center transition-all duration-200 cursor-pointer block',
                isPopular
                  ? 'bg-primary-600 text-white hover:bg-primary-700 shadow-md shadow-primary-200 hover:shadow-lg hover:shadow-primary-300'
                  : 'bg-white text-gray-700 border-2 border-gray-200 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50',
              ]}
            >
              Get Started
            </a>
          </div>
        );
      })}
    </div>

    <!-- Value strip -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      <div class="text-center p-6 rounded-2xl bg-gray-50">
        <div class="font-heading text-3xl text-gray-900">0%</div>
        <div class="mt-1 text-sm text-gray-600">Commission on any booking</div>
      </div>
      <div class="text-center p-6 rounded-2xl bg-gray-50">
        <div class="font-heading text-3xl text-gray-900">Direct</div>
        <div class="mt-1 text-sm text-gray-600">Travellers contact you, not us</div>
      </div>
      <div class="text-center p-6 rounded-2xl bg-gray-50">
        <div class="font-heading text-3xl text-gray-900">Cancel</div>
        <div class="mt-1 text-sm text-gray-600">Anytime, no long contracts</div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mb-16">
      <h2 class="font-heading text-3xl font-normal text-gray-900 mb-8 text-center">Frequently asked questions</h2>
      <div class="divide-y divide-gray-200 border-y border-gray-200">
        {faqs.map((item) => (
          <details class="group py-5">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <span class="font-medium text-gray-900">{item.q}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-600 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center py-12 px-6 bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl text-white">
      <h3 class="font-heading text-3xl font-normal mb-3">Ready to list your tours?</h3>
      <p class="text-primary-100 max-w-lg mx-auto mb-6">Join hundreds of agencies already listing commission-free on FindToursIn.</p>
      <a
        href="/auth/register"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-primary-800 font-semibold rounded-lg hover:bg-gray-100 transition-colors"
      >
        Start Listing Your Tours
      </a>
    </div>
  </div>

  <!-- Product / Offer Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "FindToursIn Agency Subscription",
    "description": metaDescription,
    "brand": { "@type": "Brand", "name": "FindToursIn" },
    "offers": PLANS.map((plan) => ({
      "@type": "Offer",
      "name": plan.name,
      "price": (plan.monthlyPriceCents / 100).toFixed(2),
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": (plan.monthlyPriceCents / 100).toFixed(2),
        "priceCurrency": "EUR",
        "unitText": "MONTH",
      },
      "availability": "https://schema.org/InStock",
      "url": `https://www.findtoursin.com/auth/register?plan=${plan.id}`,
    })),
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a },
    })),
  })} />

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Pricing", "item": "https://www.findtoursin.com/pricing" },
    ],
  })} />
</PublicLayout>

<script>
  let isAnnual = false;

  const toggle = document.getElementById('billing-toggle') as HTMLElement;
  const toggleDot = document.getElementById('toggle-dot') as HTMLElement;
  const labelMonthly = document.getElementById('label-monthly') as HTMLElement;
  const labelAnnual = document.getElementById('label-annual') as HTMLElement;

  function updatePricing() {
    document.querySelectorAll('.price-monthly').forEach(el => el.classList.toggle('hidden', isAnnual));
    document.querySelectorAll('.price-annual').forEach(el => el.classList.toggle('hidden', !isAnnual));
    document.querySelectorAll('.annual-savings').forEach(el => el.classList.toggle('hidden', !isAnnual));
    document.querySelectorAll('.annual-savings-spacer').forEach(el => el.classList.toggle('hidden', isAnnual));

    toggleDot.style.transform = isAnnual ? 'translateX(32px)' : 'translateX(0)';
    toggle.classList.toggle('bg-primary-600', isAnnual);
    toggle.classList.toggle('bg-gray-300', !isAnnual);
    labelMonthly.classList.toggle('text-gray-900', !isAnnual);
    labelMonthly.classList.toggle('text-gray-400', isAnnual);
    labelAnnual.classList.toggle('text-gray-900', isAnnual);
    labelAnnual.classList.toggle('text-gray-400', !isAnnual);
  }

  toggle.addEventListener('click', () => {
    isAnnual = !isAnnual;
    updatePricing();
  });

  updatePricing();
</script>
