---
import type { TourWithImages } from '../../types';
import TourCard from '../tours/TourCard.astro';

interface Props {
  tours: TourWithImages[];
}

const { tours } = Astro.props;
const displayTours = tours.slice(0, 6);
---

<section class="featured-tours-section py-20 sm:py-28 bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-14">
      <h2 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900 mb-4">
        Featured Tours
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Handpicked experiences from top-rated agencies around the world
      </p>
      <div class="w-12 border-t-2 border-primary-400 mx-auto mt-4"></div>
    </div>

    <!-- Tours Grid -->
    {displayTours.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        {displayTours.map((tour) => (
          <TourCard tour={tour} />
        ))}
      </div>
    ) : (
      <p class="text-center text-gray-500 py-12">No featured tours available at the moment.</p>
    )}

    <!-- View All Link -->
    <div class="text-center mt-14">
      <a
        href="/tours"
        class="inline-flex items-center gap-2 text-primary-600 font-medium hover:underline transition-colors duration-200"
      >
        View All Tours
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
