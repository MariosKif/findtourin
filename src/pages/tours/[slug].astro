---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourGallery from '../../components/tours/TourGallery.astro';
import TourInfo from '../../components/tours/TourInfo.astro';
import AgencyContactCard from '../../components/tours/AgencyContactCard.astro';
import TourCard from '../../components/tours/TourCard.astro';
import { supabase } from '../../lib/supabase';
import { getDemoTourBySlug, DEMO_AGENCY, DEMO_REVIEWS } from '../../lib/demo-tours';
import { slugify } from '../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTour } from '../../lib/tour-helpers';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/tours');

let tour: any;
let images: any[] = [];
let agency: any;
let relatedTours: any[] = [];

try {
  const { data: tourData } = await supabase
    .from('tours')
    .select('*')
    .eq('slug', slug)
    .limit(1)
    .single();
  if (tourData) tour = tourData;
} catch {
  // DB unavailable — fall through to demo lookup
}

if (!tour || tour.status !== 'active') {
  const demoTour = getDemoTourBySlug(slug);
  if (!demoTour) return Astro.redirect('/tours');
  tour = demoTour;
}

// Increment view count (fire-and-forget)
if (tour?.id && !tour.id.startsWith('demo-')) {
  supabase
    .from('tours')
    .update({ view_count: (tour.view_count || 0) + 1 })
    .eq('id', tour.id)
    .then(() => {});
}

try {
  images = tour.images || [];
  if (tour.agency_id) {
    const { data: agencyData } = await supabase
      .from('users')
      .select('*')
      .eq('id', tour.agency_id)
      .single();
    agency = agencyData;
  }

  if (tour.country) {
    const { data: candidates } = await supabase
      .from('tours')
      .select(TOUR_LIST_SELECT)
      .eq('status', 'active')
      .eq('country', tour.country)
      .neq('slug', slug)
      .limit(20);
    if (candidates) {
      const scored = candidates
        .map((c: any) => ({
          t: c,
          score: (c.category === tour.category ? 2 : 0) + (c.city === tour.city ? 1 : 0),
        }))
        .sort((a, b) => b.score - a.score || (b.t.view_count || 0) - (a.t.view_count || 0))
        .slice(0, 4);
      relatedTours = scored.map((s) => normalizeTour(s.t));
    }
  }
} catch {
  // DB unavailable — use demo defaults
}

const reviews = DEMO_REVIEWS[slug] || [];

const tourWithAgency = {
  ...tour,
  agencyName: agency?.company_name || agency?.name || DEMO_AGENCY.companyName,
  agencyVerified: agency?.is_verified || DEMO_AGENCY.isVerified,
  rating: tour.rating,
  review_count: tour.review_count ?? tour.reviewCount,
};

// --- FAQ (per-tour, with schema) ---
const currency = tour.currency || 'EUR';
const currencySymbol = currency === 'EUR' ? '€' : currency === 'USD' ? '$' : currency === 'GBP' ? '£' : currency;
const durationText = tour.duration_days
  ? `${tour.duration_days} ${tour.duration_days === 1 ? 'day' : 'days'}`
  : 'a custom duration set by the agency';
const faqs = [
  {
    q: `How much does ${tour.name} cost?`,
    a: `${tour.name} starts at ${currencySymbol}${Number(tour.price).toLocaleString()} per person. Contact ${tourWithAgency.agencyName} directly for group pricing, availability, and any discounts.`,
  },
  {
    q: `How long is this tour?`,
    a: `This tour runs for ${durationText}${tour.city && tour.country ? `, based in ${tour.city}, ${tour.country}` : ''}.`,
  },
  {
    q: `How do I book ${tour.name}?`,
    a: `FindToursIn is a directory — contact ${tourWithAgency.agencyName} directly using the email, phone, or website shown on this page. There are no booking fees or commissions: you deal straight with the operator.`,
  },
  {
    q: `What's included?`,
    a: `Inclusions vary by itinerary. Reach out to ${tourWithAgency.agencyName} for the full list of what's covered, optional add-ons, and any gear or preparation recommendations.`,
  },
];

const countrySlug = tour.country ? slugify(tour.country) : null;
const citySlug = tour.city ? slugify(tour.city) : null;
---

<PublicLayout
  title={tour.name}
  description={tour.description?.slice(0, 160)}
  image={images[0]?.url}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:text-primary-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/tours" class="hover:text-primary-600">Tours</a>
      {countrySlug && (
        <>
          <span class="mx-2">/</span>
          <a href={`/tours/in/${countrySlug}`} class="hover:text-primary-600">{tour.country}</a>
        </>
      )}
      {countrySlug && citySlug && (
        <>
          <span class="mx-2">/</span>
          <a href={`/tours/in/${countrySlug}/${citySlug}`} class="hover:text-primary-600">{tour.city}</a>
        </>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-900">{tour.name}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Main Content -->
      <div class="flex-1">
        <TourGallery images={images.map(img => ({ url: img.url, altText: img.alt_text || img.altText || '' }))} />
        <div class="mt-8">
          <TourInfo tour={tour} reviews={reviews} />
        </div>
      </div>

      <!-- Contact Sidebar -->
      <aside class="w-full lg:w-96 shrink-0">
        <div class="lg:sticky lg:top-24">
          <AgencyContactCard tour={tourWithAgency} />
        </div>
      </aside>
    </div>

    <!-- FAQ -->
    <section class="mt-16 max-w-3xl">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Frequently asked questions</h2>
      <div class="divide-y divide-gray-200 border-y border-gray-200">
        {faqs.map((item) => (
          <details class="group py-5">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <span class="font-medium text-gray-900">{item.q}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-600 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related tours -->
    {relatedTours.length > 0 && (
      <section class="mt-16">
        <div class="flex items-end justify-between mb-6">
          <h2 class="font-heading text-2xl font-normal text-gray-900">
            More tours in {tour.country}
          </h2>
          {countrySlug && (
            <a href={`/tours/in/${countrySlug}`} class="text-sm text-primary-600 hover:underline">View all &rarr;</a>
          )}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedTours.map((t) => (
            <TourCard tour={t} />
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": tour.name,
    "description": tour.description,
    "url": `https://www.findtoursin.com/tours/${tour.slug}`,
    "touristType": tour.category,
    "image": images.length > 0 ? images.map(img => img.url) : undefined,
    "offers": {
      "@type": "Offer",
      "price": tour.price,
      "priceCurrency": tour.currency,
      "availability": "https://schema.org/InStock",
    },
    "provider": {
      "@type": "TravelAgency",
      "name": tourWithAgency.agencyName,
    },
    "itinerary": {
      "@type": "ItemList",
      "description": `${tour.duration_days || ''} day tour in ${tour.city}, ${tour.country}`,
    },
    "tourBookingPage": `https://www.findtoursin.com/tours/${tour.slug}`,
  })} />

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      ...(countrySlug ? [{ "@type": "ListItem", "position": 3, "name": tour.country, "item": `https://www.findtoursin.com/tours/in/${countrySlug}` }] : []),
      ...(countrySlug && citySlug ? [{ "@type": "ListItem", "position": 4, "name": tour.city, "item": `https://www.findtoursin.com/tours/in/${countrySlug}/${citySlug}` }] : []),
      { "@type": "ListItem", "position": countrySlug && citySlug ? 5 : countrySlug ? 4 : 3, "name": tour.name, "item": `https://www.findtoursin.com/tours/${tour.slug}` },
    ],
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a },
    })),
  })} />
</PublicLayout>
