---
export const prerender = false;
import PublicLayout from '../../../../layouts/PublicLayout.astro';
import TourCard from '../../../../components/tours/TourCard.astro';
import { supabase } from '../../../../lib/supabase';
import { slugify, getCountryCopy, getCityCopy } from '../../../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTour } from '../../../../lib/tour-helpers';
import { imgUrl, imgSrcset } from '../../../../lib/image';

// Public landing — edge-cache 5 min, stale up to a day.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300, stale-while-revalidate=86400');

const { country: countrySlug, city: citySlug } = Astro.params;
if (!countrySlug || !citySlug) return Astro.redirect('/tours');

const { data: allTours } = await supabase
  .from('tours')
  .select(TOUR_LIST_SELECT)
  .eq('status', 'active');

const tours = (allTours || []).filter(
  (t: any) =>
    t.country && t.city &&
    slugify(t.country) === countrySlug &&
    slugify(t.city) === citySlug,
);

if (tours.length === 0) {
  return Astro.redirect(`/tours/in/${countrySlug}`);
}

const countryName = tours[0].country as string;
const cityName = tours[0].city as string;
const countryCopy = getCountryCopy(countryName);
const cityCopy = getCityCopy(cityName, countryName);

const categoryMap = new Map<string, number>();
for (const t of tours) {
  if (t.category) categoryMap.set(t.category, (categoryMap.get(t.category) || 0) + 1);
}
const categories = Array.from(categoryMap.entries())
  .map(([category, count]) => ({ category, count }))
  .sort((a, b) => b.count - a.count);

const tourCount = tours.length;
const INDEX_MIN_TOURS = 3;
const noIndex = tourCount < INDEX_MIN_TOURS;
const priceFrom = Math.min(...tours.map((t: any) => Number(t.price) || Infinity).filter((n: number) => isFinite(n)));
const priceMax = Math.max(...tours.map((t: any) => Number(t.price) || 0));
const priceRange = isFinite(priceFrom) && priceMax > 0
  ? (priceFrom === priceMax ? `€${priceFrom}` : `€${priceFrom}-€${priceMax}`)
  : null;
const heroImage = tours.find((t: any) => t.images?.[0]?.url)?.images?.[0]?.url || countryCopy.heroImage;

const toursGridData = tours
  .sort((a: any, b: any) => (b.view_count || 0) - (a.view_count || 0))
  .map(normalizeTour);

const pageTitle = `Tours in ${cityName}, ${countryName} — From €${priceFrom}`;
const metaDescription = `${tourCount} tours in ${cityName}, ${countryName}. ${cityCopy.tagline}. Browse itineraries, compare prices, and contact agencies directly. No booking fees.`;
const canonical = `https://www.findtoursin.com/tours/in/${countrySlug}/${citySlug}`;

const faqs = [
  {
    q: `How many tours are available in ${cityName}?`,
    a: `${tourCount} ${tourCount === 1 ? 'tour is' : 'tours are'} currently listed in ${cityName}, ${countryName}, ranging from single-day experiences to multi-day trips. Prices start at €${priceFrom}.`,
  },
  {
    q: `What types of tours are popular in ${cityName}?`,
    a: cityCopy.bestFor.length > 0
      ? `${cityName} is especially popular for: ${cityCopy.bestFor.join(', ')}.`
      : `${cityName} offers a mix of ${categories.slice(0, 3).map((c) => c.category).join(', ')} and other experiences.`,
  },
  {
    q: `How do I book a tour in ${cityName}?`,
    a: `Pick a tour, open its page, and contact the agency directly via the email, phone, or website listed. FindToursIn takes no booking fee and no commission — you book straight with the operator.`,
  },
  {
    q: `When is the best time to visit ${cityName}?`,
    a: countryCopy.whenToVisit,
  },
];
---

<PublicLayout title={pageTitle} description={metaDescription} image={heroImage} noIndex={noIndex}>
  <!-- Hero -->
  <section class="relative h-[300px] sm:h-[380px] overflow-hidden">
    <img
      src={imgUrl(heroImage, 1280)}
      srcset={imgSrcset(heroImage, [640, 960, 1280, 1920])}
      sizes="100vw"
      alt={`Tours in ${cityName}, ${countryName}`}
      width="1280"
      height="380"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/30 to-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-end py-10">
      <nav class="text-sm text-white/80 mb-3">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/tours" class="hover:text-white">Tours</a>
        <span class="mx-2">/</span>
        <a href={`/tours/in/${countrySlug}`} class="hover:text-white">{countryName}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{cityName}</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl font-normal text-white leading-tight">
        Tours in {cityName}
      </h1>
      <p class="mt-3 text-lg text-white/90 max-w-2xl">{cityCopy.tagline}</p>
      <p class="mt-2 text-sm text-white/80">{tourCount} {tourCount === 1 ? 'tour' : 'tours'} from €{priceFrom}</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Intro -->
    <section class="max-w-3xl mb-10">
      <p class="text-lg text-gray-700 leading-relaxed">{cityCopy.intro}</p>
      {cityCopy.bestFor.length > 0 && (
        <div class="mt-6">
          <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Best for</p>
          <div class="flex flex-wrap gap-2">
            {cityCopy.bestFor.map((b) => (
              <span class="inline-block px-3 py-1.5 rounded-full bg-primary-50 text-primary-700 text-sm font-medium">{b}</span>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- Categories -->
    {categories.length > 1 && (
      <section class="mb-10">
        <h2 class="font-heading text-xl font-normal text-gray-900 mb-4">Browse by category</h2>
        <div class="flex flex-wrap gap-2">
          {categories.map((c) => (
            <a
              href={`/tours?country=${encodeURIComponent(countryName)}&city=${encodeURIComponent(cityName)}&category=${encodeURIComponent(c.category)}`}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 hover:bg-primary-50 transition-colors"
            >
              {c.category}
              <span class="text-xs text-gray-400">{c.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Tours grid -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">All tours in {cityName}</h2>
      {toursGridData.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
          {toursGridData.map((t: any, index: number) => (
            <TourCard tour={t} index={index} />
          ))}
        </div>
      ) : (
        <p class="text-gray-500">No tours listed yet.</p>
      )}
    </section>

    <!-- Back to country hub -->
    <section class="mb-12 p-6 rounded-2xl bg-gray-50 border border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <p class="text-sm text-gray-500">Explore more</p>
        <p class="font-heading text-xl text-gray-900">All tours in {countryName}</p>
      </div>
      <a href={`/tours/in/${countrySlug}`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-800 transition-colors">
        View {countryName} hub &rarr;
      </a>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mb-12">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Frequently asked questions</h2>
      <div class="divide-y divide-gray-200 border-y border-gray-200">
        {faqs.map((item) => (
          <details class="group py-5">
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <span class="font-medium text-gray-900">{item.q}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-600 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </div>

  <!-- TouristDestination Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": `${cityName}, ${countryName}`,
    "description": cityCopy.intro,
    "url": canonical,
    "image": heroImage,
    "containedInPlace": { "@type": "Country", "name": countryName },
    "touristType": categories.map((c) => c.category),
  })} />

  <!-- Place / geo for the city -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Place",
    "name": cityName,
    "address": { "@type": "PostalAddress", "addressLocality": cityName, "addressCountry": countryName },
    ...(priceRange ? { "priceRange": priceRange } : {}),
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      { "@type": "ListItem", "position": 3, "name": countryName, "item": `https://www.findtoursin.com/tours/in/${countrySlug}` },
      { "@type": "ListItem", "position": 4, "name": cityName, "item": canonical },
    ],
  })} />

  <!-- ItemList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": tourCount,
    "itemListElement": toursGridData.slice(0, 10).map((t: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://www.findtoursin.com/tours/${t.slug}`,
      "name": t.name,
    })),
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a },
    })),
  })} />
</PublicLayout>
