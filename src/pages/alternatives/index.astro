---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { COMPETITORS } from '../../lib/seo/competitors';
import { currentYear } from '../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const year = currentYear();
const pageTitle = `Tour-booking platform alternatives ${year}`;
const metaDescription = 'Looking for alternatives to GetYourGuide, Viator, TripAdvisor, or Civitatis? Honest, dated breakdowns of every major option for booking guided tours.';
const canonical = 'https://www.findtoursin.com/alternatives';
const SITE = 'https://www.findtoursin.com';
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Alternatives</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Tour-booking alternatives
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl" data-speakable="true">
        Independent breakdowns of alternatives to the major tour-booking platforms. Each page lists 5 options including FindToursIn, with their strengths, pricing models, and the use case each fits best.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-4 sm:grid-cols-2">
      {COMPETITORS.map((c) => (
        <a href={`/alternatives/${c.slug}-alternatives`} class="group rounded-2xl border border-gray-200 p-6 hover:border-primary-400 hover:shadow-md transition-all">
          <h2 class="font-heading text-xl text-gray-900 group-hover:text-primary-700">{c.name} alternatives</h2>
          <p class="mt-2 text-gray-700 text-sm leading-relaxed">5 alternatives to {c.name}, including FindToursIn — pricing, model, and best fit for each.</p>
        </a>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "isPartOf": { "@id": `${SITE}/#organization` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Alternatives", "item": canonical },
    ],
  })} />
</PublicLayout>
