---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { PLANS, formatCents, getAnnualSavingsCents, getMonthlyEquivalentCents } from '../../lib/pricing';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');
---

<DashboardLayout title="Choose Your Plan">
  <!-- Page Header -->
  <div class="text-center max-w-2xl mx-auto mb-10">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary-100 mb-4">
      <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
      </svg>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Choose the right plan for your business</h1>
    <p class="text-gray-500 text-lg">Scale your tour listings with a plan that fits. All plans include full analytics and priority support.</p>
  </div>

  <!-- Billing Toggle -->
  <div class="flex items-center justify-center gap-4 mb-10">
    <span id="label-monthly" class="text-sm font-semibold text-gray-900 transition-colors">Monthly</span>
    <button
      id="billing-toggle"
      class="relative w-16 h-8 bg-gray-300 rounded-full transition-colors duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-300 focus:ring-offset-2"
      aria-label="Toggle billing period"
    >
      <span id="toggle-dot" class="absolute top-1 left-1 w-6 h-6 bg-white rounded-full shadow-md transition-transform duration-300"></span>
    </button>
    <span id="label-annual" class="text-sm font-semibold text-gray-400 transition-colors">
      Annual
      <span class="inline-flex items-center ml-1.5 px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700">Save 15%</span>
    </span>
  </div>

  <!-- Discount code entry -->
  <div class="max-w-md mx-auto mb-10 bg-white rounded-2xl border border-gray-200 p-4">
    <div class="flex gap-2">
      <input id="code-input" placeholder="Discount code" class="flex-1 px-3 py-2 rounded-lg border border-gray-200 uppercase text-sm" />
      <button id="code-apply" type="button" class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-800">Apply</button>
    </div>
    <p id="code-feedback" class="mt-2 text-sm hidden"></p>
  </div>

  <!-- Plan Cards Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-16">
    {PLANS.map((plan) => {
      const monthlyEquiv = getMonthlyEquivalentCents(plan, 'monthly');
      const annualEquiv = getMonthlyEquivalentCents(plan, 'annual');
      const annualSavings = getAnnualSavingsCents(plan);
      const isPopular = !!plan.popular;

      return (
        <div
          class:list={[
            'plan-card relative flex flex-col bg-white rounded-2xl border-2 p-8 transition-all duration-300',
            isPopular
              ? 'border-primary-500 shadow-lg shadow-primary-100 scale-[1.02]'
              : 'border-gray-200 hover:border-gray-300 hover:shadow-md',
          ]}
          data-plan-id={plan.id}
        >
          {/* Popular badge */}
          {isPopular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center gap-1 bg-primary-600 text-white text-xs font-bold uppercase tracking-wide px-4 py-1.5 rounded-full shadow-sm">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                Most Popular
              </span>
            </div>
          )}

          {/* Plan name */}
          <h3 class="text-xl font-bold text-gray-900 mb-1">{plan.name}</h3>
          <p class="text-sm text-gray-500 mb-6">Up to {plan.maxListings} listings</p>

          {/* Monthly pricing */}
          <div class="price-monthly mb-1">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-gray-900">&euro;{formatCents(monthlyEquiv)}</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">per month <span class="text-gray-400">+ VAT</span></p>
          </div>

          {/* Annual pricing */}
          <div class="price-annual hidden mb-1">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-gray-900">&euro;{formatCents(annualEquiv)}</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">per month, billed annually <span class="text-gray-400">+ VAT</span></p>
          </div>


          {/* Annual savings */}
          <div class="annual-savings hidden mb-4">
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-green-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Save &euro;{formatCents(annualSavings)} per year
            </span>
          </div>

          {/* Spacer when savings hidden */}
          <div class="annual-savings-spacer mb-4"></div>

          {/* Divider */}
          <div class="border-t border-gray-100 mb-6"></div>

          {/* Features */}
          <ul class="space-y-3 mb-8 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600">{feature}</span>
              </li>
            ))}
          </ul>

          {/* CTA Button */}
          <form method="POST" action="/api/stripe/checkout-plan" class="mt-auto">
            <input type="hidden" name="planId" value={plan.id} />
            <input type="hidden" name="billingPeriod" value="monthly" class="billing-period-input" />
            <button
              type="submit"
              class:list={[
                'w-full py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200 cursor-pointer',
                isPopular
                  ? 'bg-primary-600 text-white hover:bg-primary-700 shadow-md shadow-primary-200 hover:shadow-lg hover:shadow-primary-300'
                  : 'bg-white text-gray-700 border-2 border-gray-200 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50',
              ]}
            >
              Get Started
            </button>
          </form>
        </div>
      );
    })}
  </div>

  <!-- Compare Plans Section -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-12">
    <div class="px-8 py-6 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900">Compare Plans</h2>
      <p class="text-sm text-gray-500 mt-1">See all features side by side</p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left py-4 px-8 font-semibold text-gray-500 uppercase tracking-wider text-xs w-1/5">Feature</th>
            {PLANS.map((plan) => (
              <th class:list={[
                'text-center py-4 px-4 font-semibold text-xs uppercase tracking-wider',
                plan.popular ? 'text-primary-600 bg-primary-50/50' : 'text-gray-700'
              ]}>
                {plan.name}
                {plan.popular && (
                  <span class="block text-[10px] font-bold text-primary-500 mt-0.5">POPULAR</span>
                )}
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {/* Listings */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Tour Listings</td>
            <td class="py-4 px-4 text-center text-gray-600">15</td>
            <td class="py-4 px-4 text-center text-gray-600 bg-primary-50/30">30</td>
            <td class="py-4 px-4 text-center text-gray-600">60</td>
            <td class="py-4 px-4 text-center text-gray-600">140</td>
          </tr>
          {/* Images per tour */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Images per Tour</td>
            <td class="py-4 px-4 text-center text-gray-600">10</td>
            <td class="py-4 px-4 text-center text-gray-600 bg-primary-50/30">10</td>
            <td class="py-4 px-4 text-center text-gray-600">10</td>
            <td class="py-4 px-4 text-center text-gray-600">10</td>
          </tr>
          {/* Analytics */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Analytics</td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center bg-primary-50/30">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
          </tr>
          {/* Support */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Support</td>
            <td class="py-4 px-4 text-center text-gray-600">Email</td>
            <td class="py-4 px-4 text-center text-gray-600 bg-primary-50/30">Priority</td>
            <td class="py-4 px-4 text-center text-gray-600">Dedicated Manager</td>
            <td class="py-4 px-4 text-center text-gray-600">Dedicated Manager</td>
          </tr>
          {/* Featured badge */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Featured Badge</td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center bg-primary-50/30">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
          </tr>
          {/* Priority placement */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Priority Placement</td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center bg-primary-50/30">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
          </tr>
          {/* Custom branding */}
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="py-4 px-8 font-medium text-gray-700">Custom Branding</td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center bg-primary-50/30">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </td>
            <td class="py-4 px-4 text-center">
              <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Contact CTA -->
  <div class="text-center py-10 px-6 bg-gray-50 rounded-2xl border border-gray-200">
    <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-200 mb-4">
      <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
    </div>
    <h3 class="text-xl font-bold text-gray-900 mb-2">Need more than 140 listings?</h3>
    <p class="text-gray-500 mb-6 max-w-md mx-auto">We offer custom plans for large operators. Get in touch and we'll build a package that fits your needs.</p>
    <a
      href="/contact"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold text-sm hover:bg-gray-800 transition-colors"
    >
      Contact Us
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- Fine print -->
  <p class="text-center text-xs text-gray-400 mt-6 mb-2">
    Secure payment powered by Stripe. Cancel or change your plan anytime.
  </p>
</DashboardLayout>

<script>
  let isAnnual = false;

  const toggle = document.getElementById('billing-toggle') as HTMLElement;
  const toggleDot = document.getElementById('toggle-dot') as HTMLElement;
  const labelMonthly = document.getElementById('label-monthly') as HTMLElement;
  const labelAnnual = document.getElementById('label-annual') as HTMLElement;

  function updatePricing() {
    // Toggle price display
    document.querySelectorAll('.price-monthly').forEach(el => el.classList.toggle('hidden', isAnnual));
    document.querySelectorAll('.price-annual').forEach(el => el.classList.toggle('hidden', !isAnnual));

    // Toggle annual savings visibility
    document.querySelectorAll('.annual-savings').forEach(el => el.classList.toggle('hidden', !isAnnual));
    document.querySelectorAll('.annual-savings-spacer').forEach(el => el.classList.toggle('hidden', isAnnual));

    // Update all hidden billing period inputs
    document.querySelectorAll<HTMLInputElement>('.billing-period-input').forEach(input => {
      input.value = isAnnual ? 'annual' : 'monthly';
    });

    // Toggle styling
    toggleDot.style.transform = isAnnual ? 'translateX(32px)' : 'translateX(0)';
    toggle.classList.toggle('bg-primary-600', isAnnual);
    toggle.classList.toggle('bg-gray-300', !isAnnual);
    labelMonthly.classList.toggle('text-gray-900', !isAnnual);
    labelMonthly.classList.toggle('text-gray-400', isAnnual);
    labelAnnual.classList.toggle('text-gray-900', isAnnual);
    labelAnnual.classList.toggle('text-gray-400', !isAnnual);
  }

  toggle.addEventListener('click', () => {
    isAnnual = !isAnnual;
    updatePricing();
  });

  // Initialize
  updatePricing();
</script>

<script>
  const codeInput = document.getElementById('code-input') as HTMLInputElement;
  const applyBtn = document.getElementById('code-apply') as HTMLButtonElement;
  const feedback = document.getElementById('code-feedback') as HTMLParagraphElement;

  function showFeedback(msg: string, ok: boolean) {
    feedback.textContent = msg;
    feedback.className = `mt-2 text-sm ${ok ? 'text-green-700' : 'text-red-600'}`;
  }

  function resetCard(card: Element) {
    const form = card.querySelector('form') as HTMLFormElement | null;
    const btn = card.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (form) form.action = '/api/stripe/checkout-plan';
    if (btn) btn.textContent = 'Get Started';
    const hidden = form?.querySelector<HTMLInputElement>('input[name="discountCode"]');
    hidden?.remove();
  }

  async function applyCode() {
    const raw = codeInput.value.trim().toUpperCase();
    if (!raw) return;
    applyBtn.disabled = true;

    const cards = Array.from(document.querySelectorAll<HTMLDivElement>('[data-plan-id]'));
    cards.forEach(resetCard);

    const results = await Promise.all(cards.map(async (card) => {
      const planId = card.dataset.planId!;
      const res = await fetch('/api/discount-codes/validate', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: raw, planId }),
      });
      return { planId, card, data: await res.json().catch(() => ({})) };
    }));
    applyBtn.disabled = false;

    const valid = results.filter(r => r.data?.valid === true);
    if (valid.length === 0) {
      const reason = results[0]?.data?.message || 'Code not valid';
      showFeedback(reason, false);
      return;
    }

    valid.forEach(({ card }) => {
      const form = card.querySelector('form') as HTMLFormElement | null;
      const btn = card.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (form) {
        form.action = '/api/discount-codes/redeem';
        let hidden = form.querySelector<HTMLInputElement>('input[name="discountCode"]');
        if (!hidden) {
          hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = 'discountCode';
          form.appendChild(hidden);
        }
        hidden.value = raw;
      }
      if (btn) btn.textContent = 'Activate Free';
    });

    const total = cards.length;
    const ok = valid.length;
    showFeedback(
      ok === total
        ? `Code valid for all ${total} plans — click Activate Free.`
        : `Code valid for ${ok} of ${total} plans.`,
      true,
    );
  }

  applyBtn?.addEventListener('click', applyCode);
  codeInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); applyCode(); } });

  // Intercept submits on plan-card forms when they're pointing at the redeem
  // endpoint, so failures land inline on this page instead of the raw JSON
  // response body. The Stripe path keeps its native form POST.
  document.querySelectorAll<HTMLFormElement>('[data-plan-id] form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      if (!form.action.includes('/api/discount-codes/redeem')) return;
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;

      const fd = new FormData(form);
      const planId = String(fd.get('planId') || '');
      const body = {
        code: String(fd.get('discountCode') || ''),
        planId,
      };
      try {
        const res = await fetch('/api/discount-codes/redeem', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          window.location.href = `/dashboard?activated=${encodeURIComponent(planId)}`;
          return;
        }
        const data = await res.json().catch(() => ({}));
        showFeedback(data.error || 'Failed to redeem code', false);
      } catch {
        showFeedback('Network error — please try again.', false);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>
