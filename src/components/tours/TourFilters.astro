---
import Autocomplete from '../ui/Autocomplete.astro';
import DateRangePicker from '../ui/DateRangePicker.astro';

interface Props {
  currentFilters?: {
    q?: string;
    country?: string;
    category?: string;
    minPrice?: number;
    maxPrice?: number;
    sort?: string;
    departureCountry?: string;
    departureCity?: string;
    dateFrom?: string;
    dateTo?: string;
  };
}

const { currentFilters = {} } = Astro.props;
const { q, country, category, minPrice, maxPrice, sort, departureCountry, departureCity, dateFrom, dateTo } = currentFilters;

// Merge departure fields
const departingFrom = [departureCity, departureCountry].filter(Boolean).join(', ');

const hasActiveFilters = [q, country, category, minPrice, maxPrice, departureCountry, departureCity, dateFrom, dateTo].filter(Boolean).length > 0;
---

{/* Mobile: collapsible */}
<div class="lg:hidden">
  <details class="group rounded-2xl bg-gray-50 border border-gray-900">
    <summary class="flex cursor-pointer items-center justify-between rounded-2xl px-6 py-4 font-bold text-gray-900">
      <span class="flex items-center gap-2">
        <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        Filters
      </span>
      <svg class="h-5 w-5 text-gray-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <form method="GET" action="/tours" class="space-y-4 px-6 pb-6">
      {/* Search */}
      <div class="relative">
        <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" name="q" value={q || ''} placeholder="Search tours..." class="w-full rounded-xl border border-gray-900 bg-white py-2.5 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-900 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" />
      </div>

      {/* Departing From */}
      <Autocomplete
        id="filter-departure-mobile"
        name="departureCountry"
        placeholder="Departing from"
        value={departingFrom || ''}
        apiUrl="/api/filter-values?field=departure_country"
        inputClass="rounded-xl !border-gray-900 text-sm placeholder-gray-900"
      />

      {/* Destination Country */}
      <Autocomplete
        id="filter-country-mobile"
        name="country"
        placeholder="Destination country"
        value={country || ''}
        apiUrl="/api/filter-values?field=country"
        inputClass="rounded-xl !border-gray-900 text-sm placeholder-gray-900"
      />

      {/* Category */}
      <Autocomplete
        id="filter-category-mobile"
        name="category"
        placeholder="All Categories"
        value={category || ''}
        apiUrl="/api/filter-values?field=category"
        inputClass="rounded-xl !border-gray-900 text-sm placeholder-gray-900"
      />

      {/* Price Range */}
      <div class="flex items-center gap-2">
        <input type="number" name="minPrice" value={minPrice ?? ''} placeholder="Min price" min="0" class="w-full rounded-xl border border-gray-900 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder-gray-900 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" />
        <span class="text-gray-500">&ndash;</span>
        <input type="number" name="maxPrice" value={maxPrice ?? ''} placeholder="Max price" min="0" class="w-full rounded-xl border border-gray-900 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder-gray-900 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" />
      </div>

      {/* Travel Dates */}
      <DateRangePicker id="filter-dates-mobile" variant="filter" dateFrom={dateFrom || ''} dateTo={dateTo || ''} />

      <button type="submit" class="w-full rounded-xl bg-primary-600 px-5 py-2.5 text-center text-sm font-medium text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
        Apply Filters
      </button>
    </form>
  </details>
</div>

{/* Desktop: horizontal filter bar */}
<form method="GET" action="/tours" class="hidden lg:block rounded-2xl bg-gray-50 border border-gray-900 px-6 py-5">
  <div class="grid grid-cols-4 gap-3">
    {/* Row 1 */}
    {/* Search */}
    <div class="relative">
      <svg class="absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        name="q"
        value={q || ''}
        placeholder="Search tours..."
        class="w-full rounded-xl border border-gray-900 bg-white py-2.5 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-900 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200"
      />
    </div>

    {/* Departing From */}
    <div class="relative">
      <svg class="absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
      </svg>
      <Autocomplete
        id="filter-departure"
        name="departureCountry"
        placeholder="Departing from"
        value={departingFrom || ''}
        apiUrl="/api/filter-values?field=departure_country"
        inputClass="rounded-xl !border-gray-900 text-sm pl-10 placeholder-gray-900"
      />
    </div>

    {/* Destination Country */}
    <div class="relative">
      <svg class="absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <Autocomplete
        id="filter-country"
        name="country"
        placeholder="Destination country"
        value={country || ''}
        apiUrl="/api/filter-values?field=country"
        inputClass="rounded-xl !border-gray-900 text-sm pl-10 placeholder-gray-900"
      />
    </div>

    {/* Category */}
    <Autocomplete
      id="filter-category"
      name="category"
      placeholder="All Categories"
      value={category || ''}
      apiUrl="/api/filter-values?field=category"
      inputClass="rounded-xl !border-gray-900 text-sm placeholder-gray-900"
    />
  </div>

  {/* Row 2 */}
  <div class="grid grid-cols-4 gap-3 mt-3">
    {/* Min Price */}
    <input
      type="number"
      name="minPrice"
      value={minPrice ?? ''}
      placeholder="Min price"
      min="0"
      class="w-full rounded-xl border border-gray-900 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder-gray-900 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200"
    />

    {/* Max Price */}
    <input
      type="number"
      name="maxPrice"
      value={maxPrice ?? ''}
      placeholder="Max price"
      min="0"
      class="w-full rounded-xl border border-gray-900 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder-gray-900 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200"
    />

    {/* Travel Dates */}
    <div>
      <DateRangePicker id="filter-dates" variant="filter" dateFrom={dateFrom || ''} dateTo={dateTo || ''} />
    </div>

    {/* Apply button */}
    <button
      type="submit"
      class="w-full rounded-xl bg-primary-600 px-5 py-2.5 text-center text-sm font-medium text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
    >
      Apply Filters
    </button>
  </div>

  {/* Clear filters */}
  {hasActiveFilters && (
    <div class="flex justify-end mt-3">
      <a href="/tours" class="text-sm text-primary-600 hover:underline">Clear filters</a>
    </div>
  )}
</form>
