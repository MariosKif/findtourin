---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { formatPrice, formatDate } from '../../lib/utils';

interface Tour {
  id: string;
  name: string;
  status: string;
  category: string;
  price: string;
  currency: string;
  createdAt: Date;
}

interface Props {
  tours: Tour[];
}

const { tours } = Astro.props;

const statusVariant: Record<string, 'success' | 'warning' | 'danger' | 'info' | 'neutral'> = {
  active: 'success',
  pending_payment: 'warning',
  pending_review: 'info',
  rejected: 'danger',
  draft: 'neutral',
  expired: 'neutral',
};

const statusLabel: Record<string, string> = {
  active: 'Active',
  pending_payment: 'Pending Payment',
  pending_review: 'Pending Review',
  rejected: 'Rejected',
  draft: 'Draft',
  expired: 'Expired',
};
---

{tours.length === 0 ? (
  <div class="rounded-xl bg-white p-12 text-center shadow-sm border border-gray-100">
    <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
    </svg>
    <h3 class="mt-3 text-lg font-medium text-gray-900">No listings yet</h3>
    <p class="mt-1 text-sm text-gray-500">Create your first tour listing to get started.</p>
    <div class="mt-4">
      <Button href="/dashboard/tours/new" size="sm">Create Tour</Button>
    </div>
  </div>
) : (
  <div class="overflow-x-auto rounded-xl bg-white shadow-sm border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Created</th>
          <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {tours.map((tour) => (
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="whitespace-nowrap px-6 py-4">
              <span class="text-sm font-medium text-gray-900">{tour.name}</span>
            </td>
            <td class="whitespace-nowrap px-6 py-4">
              <Badge variant={statusVariant[tour.status] || 'neutral'} size="sm">
                {statusLabel[tour.status] || tour.status}
              </Badge>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600">{tour.category}</td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900 font-medium">
              {formatPrice(tour.price, tour.currency)}
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500">{formatDate(tour.createdAt)}</td>
            <td class="whitespace-nowrap px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <Button href={`/dashboard/tours/${tour.id}/edit`} variant="ghost" size="sm">Edit</Button>
                {tour.status === 'pending_payment' && (
                  <form method="POST" action="/api/stripe/checkout">
                    <input type="hidden" name="tourId" value={tour.id} />
                    <Button type="submit" variant="primary" size="sm">Pay</Button>
                  </form>
                )}
                <button
                  type="button"
                  class="delete-tour-btn inline-flex items-center justify-center rounded-lg px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors cursor-pointer"
                  data-tour-id={tour.id}
                  data-tour-name={tour.name}
                >
                  Delete
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<script>
  function initDeleteButtons() {
    document.querySelectorAll<HTMLButtonElement>('.delete-tour-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const tourId = btn.dataset.tourId;
        const tourName = btn.dataset.tourName;

        if (!confirm(`Are you sure you want to delete "${tourName}"? This action cannot be undone.`)) {
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Deleting...';

        try {
          const res = await fetch(`/api/tours/${tourId}`, { method: 'DELETE' });

          if (res.ok) {
            const row = btn.closest('tr');
            if (row) {
              row.style.opacity = '0';
              row.style.transition = 'opacity 0.3s';
              setTimeout(() => row.remove(), 300);
            }
            (window as any).showToast?.('Tour deleted successfully', 'success');
          } else {
            const data = await res.json().catch(() => ({}));
            (window as any).showToast?.(data.message || 'Failed to delete tour', 'error');
            btn.disabled = false;
            btn.textContent = 'Delete';
          }
        } catch {
          (window as any).showToast?.('Network error', 'error');
          btn.disabled = false;
          btn.textContent = 'Delete';
        }
      });
    });
  }

  initDeleteButtons();
  document.addEventListener('astro:after-swap', initDeleteButtons);
</script>
