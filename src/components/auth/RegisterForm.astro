---
import Input from '../ui/Input.astro';
import Select from '../ui/Select.astro';
import Button from '../ui/Button.astro';

const roleOptions = [
  { value: 'user', label: 'User' },
  { value: 'agency', label: 'Agency' },
];
---

<form id="register-form" class="space-y-5">
  <div id="register-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700"></div>

  <Input
    label="Full Name"
    name="name"
    type="text"
    placeholder="John Doe"
    required
  />

  <Input
    label="Email"
    name="email"
    type="email"
    placeholder="you@example.com"
    required
  />

  <Input
    label="Password"
    name="password"
    type="password"
    placeholder="At least 8 characters"
    required
    minlength="8"
  />

  <Input
    label="Confirm Password"
    name="confirmPassword"
    type="password"
    placeholder="Repeat your password"
    required
    minlength="8"
  />

  <Select
    label="Account Type"
    name="role"
    options={roleOptions}
    value="user"
    required
  />

  <div id="agency-fields" class="hidden space-y-5">
    <Input
      label="Company Name"
      name="companyName"
      type="text"
      placeholder="Your company name"
    />

    <Input
      label="Phone"
      name="phone"
      type="tel"
      placeholder="+1 (555) 000-0000"
    />

    <Input
      label="Website"
      name="website"
      type="url"
      placeholder="https://yourcompany.com"
    />
  </div>

  <Button type="submit" variant="primary" size="lg" class="w-full">
    Create Account
  </Button>

  <div class="relative my-4">
    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
    <div class="relative flex justify-center text-sm"><span class="bg-white px-4 text-gray-500">or</span></div>
  </div>

  <button
    type="button"
    id="google-register-btn"
    class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>
    Sign up with Google
  </button>
</form>

<div id="firebase-config" class="hidden"
  data-api-key={import.meta.env.PUBLIC_FIREBASE_API_KEY}
  data-auth-domain={import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN}
  data-project-id={import.meta.env.PUBLIC_FIREBASE_PROJECT_ID}
></div>

<script>
  import { initializeApp, getApps } from 'firebase/app';
  import { getAuth, signInWithEmailAndPassword, signInWithPopup, GoogleAuthProvider } from 'firebase/auth';

  const configEl = document.getElementById('firebase-config') as HTMLDivElement;
  const firebaseConfig = {
    apiKey: configEl.dataset.apiKey,
    authDomain: configEl.dataset.authDomain,
    projectId: configEl.dataset.projectId,
  };

  const app = getApps().length === 0 ? initializeApp(firebaseConfig) : getApps()[0];
  const auth = getAuth(app);

  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('register-error') as HTMLDivElement;
  const roleSelect = form.querySelector('select[name="role"]') as HTMLSelectElement;
  const agencyFields = document.getElementById('agency-fields') as HTMLDivElement;

  function showError(message: string) {
    errorDiv.textContent = message;
    errorDiv.classList.remove('hidden');
  }

  function redirectAfterLogin(data: { role?: string }) {
    if (data.role === 'agency' || data.role === 'admin') {
      window.location.href = '/dashboard';
    } else {
      window.location.href = '/';
    }
  }

  roleSelect.addEventListener('change', () => {
    if (roleSelect.value === 'agency') {
      agencyFields.classList.remove('hidden');
    } else {
      agencyFields.classList.add('hidden');
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    errorDiv.textContent = '';

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;
    const role = formData.get('role') as string;

    if (password !== confirmPassword) {
      showError('Passwords do not match.');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating account...';

    try {
      const body: Record<string, string> = { name, email, password, role };

      if (role === 'agency') {
        const companyName = formData.get('companyName') as string;
        const phone = formData.get('phone') as string;
        const website = formData.get('website') as string;
        if (companyName) body.companyName = companyName;
        if (phone) body.phone = phone;
        if (website) body.website = website;
      }

      // Step 1: Register on server (creates Firebase Auth user + Firestore profile)
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (!res.ok) {
        const message = data?.error || 'Registration failed. Please try again.';
        showError(message);
        return;
      }

      // Step 2: Sign in client-side to get idToken
      const result = await signInWithEmailAndPassword(auth, email, password);
      const idToken = await result.user.getIdToken();

      // Step 3: Create session cookie
      const loginRes = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });

      const loginData = await loginRes.json();

      if (!loginRes.ok) {
        showError(loginData?.error || 'Login after registration failed.');
        return;
      }

      redirectAfterLogin(loginData);
    } catch {
      showError('Something went wrong. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });

  // Google sign-up
  const googleBtn = document.getElementById('google-register-btn') as HTMLButtonElement;
  googleBtn.addEventListener('click', async () => {
    errorDiv.classList.add('hidden');
    errorDiv.textContent = '';

    try {
      const provider = new GoogleAuthProvider();
      const result = await signInWithPopup(auth, provider);
      const idToken = await result.user.getIdToken();

      const res = await fetch('/api/auth/google', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });

      const data = await res.json();

      if (!res.ok) {
        showError(data?.error || 'Google sign-up failed.');
        return;
      }

      redirectAfterLogin(data);
    } catch (err: any) {
      if (err?.code !== 'auth/popup-closed-by-user') {
        showError('Google sign-up failed. Please try again.');
      }
    }
  });
</script>
