---
const destinations = [
  { city: "Santorini", country: "Greece", image: "https://images.unsplash.com/photo-1613395877344-13d4a8e0d49e?w=400&h=560&fit=crop" },
  { city: "Bali", country: "Indonesia", image: "https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=400&h=560&fit=crop" },
  { city: "Kyoto", country: "Japan", image: "https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=400&h=560&fit=crop" },
  { city: "Serengeti", country: "Tanzania", image: "https://images.unsplash.com/photo-1516426122078-c23e76319801?w=400&h=560&fit=crop" },
  { city: "Machu Picchu", country: "Peru", image: "https://images.unsplash.com/photo-1587595431973-160d0d163571?w=400&h=560&fit=crop" },
  { city: "Iceland", country: "", image: "https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=400&h=560&fit=crop" },
  { city: "Dubai", country: "UAE", image: "https://images.unsplash.com/photo-1451337516015-6b6e9a44a8a3?w=400&h=560&fit=crop" },
  { city: "Paris", country: "France", image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=400&h=560&fit=crop" },
];
---

<section class="bg-white py-16 sm:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 sm:mb-12">
      <h2 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900 mb-3">Popular Destinations</h2>
      <p class="text-gray-500 text-lg">Where travelers are heading next</p>
      <div class="w-12 border-t-2 border-primary-400 mx-auto mt-4"></div>
    </div>

    <!-- Mobile: horizontal scroll / Desktop: 4-column grid -->
    <div class="
      flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4
      lg:grid lg:grid-cols-4 lg:gap-5 lg:overflow-visible lg:snap-none lg:mx-0 lg:px-0 lg:pb-0
    ">
      {destinations.map((dest) => (
        <a
          href={`/tours?to=${encodeURIComponent(dest.city)}`}
          class="
            destination-card group relative flex-shrink-0 snap-start
            w-[280px] h-[360px] lg:w-auto lg:h-[340px]
            rounded-2xl overflow-hidden
          "
        >
          <!-- Background image -->
          <img
            src={dest.image}
            alt={dest.country ? `${dest.city}, ${dest.country}` : dest.city}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />

          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent transition-colors duration-300 group-hover:from-black/40 group-hover:via-black/10"></div>

          <!-- Text content -->
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white font-bold text-2xl leading-tight">
              {dest.city}
            </h3>
            {dest.country && (
              <p class="text-white/80 text-sm mt-1">{dest.country}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar on mobile while keeping scroll functionality */
  .flex.overflow-x-auto {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .flex.overflow-x-auto::-webkit-scrollbar {
    display: none;
  }
</style>
