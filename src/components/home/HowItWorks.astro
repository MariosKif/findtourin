---
const steps = [
  {
    number: '1',
    title: 'Browse Tours',
    description: 'Search by destination, category, or price.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>`,
  },
  {
    number: '2',
    title: 'Contact Agency',
    description: 'Reach out directly via email, phone, or website.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>`,
  },
  {
    number: '3',
    title: 'Start Your Adventure',
    description: 'Book directly and enjoy your tour.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
  },
];
---

<section class="how-it-works-section py-20 sm:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-14">
      <h2 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900 mb-4">
        How It Works
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Finding your dream tour is simple
      </p>
      <div class="w-12 border-t-2 border-primary-400 mx-auto mt-4"></div>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">
      {steps.map((step, index) => (
        <div class="relative text-center">
          {/* Connecting line between circles (desktop). Starts at the current
              circle's right edge (50% + half-circle = 32px = 2rem) and reaches
              the next circle's left edge. Width = column_width + gap - 64px:
                md gap-10 (40px) → 100% - 24px
                lg gap-16 (64px) → 100% (the gap exactly cancels both radii) */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-1.5rem)] lg:w-full border-t-2 border-dashed border-primary-200"></div>
          )}

          {/* Step Circle */}
          <div class="relative inline-flex flex-col items-center mb-6">
            <div class="w-16 h-16 rounded-full bg-primary-50 border-2 border-primary-200 flex items-center justify-center mb-3">
              <span class="text-2xl font-bold text-primary-600">{step.number}</span>
            </div>
          </div>

          {/* Title & Description */}
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{step.title}</h3>
          <p class="text-gray-600 leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
