---
import '../styles/global.css';
import WebVitals from '../components/common/WebVitals.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  /** Optional explicit canonical override. Pages where the canonical
      should NOT be self (e.g. a thin category page that should fold into
      its country hub) pass an absolute URL here. When omitted, canonical
      is derived from the current pathname. */
  canonical?: string;
  /** Optional subtitle for the auto-generated OG image. Falls back to the
      meta description when omitted. */
  ogSubtitle?: string;
  /** Optional eyebrow text on the OG image. Defaults to "findtoursin.com". */
  ogEyebrow?: string;
  /** Optional rich page-view payload — passed straight to gtag() so
      individual pages (e.g. tour detail) can attach slug/price/currency
      to the GA4 page_view event without a custom dimension config. */
  gaPageData?: Record<string, string | number | boolean | undefined>;
}

const {
  title = 'FindToursIn',
  description = 'Discover amazing tours worldwide. Browse curated travel experiences from trusted agencies.',
  image,
  noIndex = false,
  canonical,
  ogSubtitle,
  ogEyebrow,
  gaPageData,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical)
  : new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'FindToursIn' ? title : `${title} | FindToursIn`;

// OG image resolution. If a page passes an explicit image (e.g. blog hero,
// tour photo), use it. Otherwise auto-generate a per-page card via /api/og
// with the title + a sensible subtitle. The auto-generated path is the
// site-wide default — every page now ships a unique social card without
// per-page wiring.
function buildOgUrl(t: string, sub: string, eyebrow: string): string {
  const params = new URLSearchParams({
    title: t.slice(0, 80),
    subtitle: sub.slice(0, 90),
    eyebrow: eyebrow.slice(0, 50),
  });
  return `/api/og?${params.toString()}`;
}

const resolvedImage = image
  ? image
  : buildOgUrl(
      title === 'FindToursIn' ? 'Find tours from trusted local agencies' : title,
      ogSubtitle || description,
      ogEyebrow || 'findtoursin.com',
    );

// OG/Twitter image must be absolute. Convert relative paths to absolute
// against the site URL.
const absoluteOgImage = resolvedImage.startsWith('http')
  ? resolvedImage
  : new URL(resolvedImage, Astro.site).toString();

// GA4 measurement ID. Honour PUBLIC_GA_MEASUREMENT_ID at build time so a
// future swap to a different property is one Vercel env-var change, not a
// code edit. Falls back to the original hardcoded ID for backward-compat.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-JEX5ES946C';

// Search-engine ownership verification tags. Each only renders when the
// corresponding env var is set, so they can be added one at a time as
// the user claims ownership in each console. PUBLIC_ prefix means Astro
// inlines the value at build; no runtime fetch.
const GOOGLE_VERIFICATION = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION || '';
const BING_VERIFICATION = import.meta.env.PUBLIC_BING_SITE_VERIFICATION || '';
const YANDEX_VERIFICATION = import.meta.env.PUBLIC_YANDEX_VERIFICATION || '';
const PINTEREST_VERIFICATION = import.meta.env.PUBLIC_PINTEREST_VERIFICATION || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Google Analytics 4. The loader runs only when GA_ID is set, so a
        future deploy that explicitly clears PUBLIC_GA_MEASUREMENT_ID can
        opt out without code changes. */}
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`} is:inline></script>
        <script is:inline define:vars={{ GA_ID, gaPageData }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          // Pass per-page enrichment (tour slug / price / etc) through the
          // initial config call so the first page_view carries the data
          // and we don't fire two events per page.
          // `send_page_view: false` because View Transitions navigations
          // don't trigger a fresh `config` call — instead we manually
          // fire `page_view` on every astro:page-load (including the
          // initial one, see listener below).
          gtag('config', GA_ID, { ...(gaPageData || {}), send_page_view: false });

          // Fire page_view on every Astro page-load event. This covers
          // both the initial render and subsequent View-Transition-based
          // navigations, so per-page GA4 metrics stay accurate when the
          // SPA-style routing kicks in.
          document.addEventListener('astro:page-load', function () {
            window.gtag && window.gtag('event', 'page_view', {
              page_location: location.href,
              page_path: location.pathname + location.search,
              page_title: document.title,
            });
          });

          // Outbound + contact-channel click tracking. Captures any click
          // on an http(s) link to a different host, plus mailto: and tel:
          // links — the latter two are the lead signals (traveller is
          // about to email or phone a tour agency). transport_type=beacon
          // keeps the event firing even as the browser navigates away.
          document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest ? e.target.closest('a') : null;
            if (!a) return;
            var href = a.getAttribute('href') || '';
            if (!href) return;
            var isExternal = /^https?:\/\//.test(href) && !href.includes(location.host);
            var isMail = href.indexOf('mailto:') === 0;
            var isTel = href.indexOf('tel:') === 0;
            if (!isExternal && !isMail && !isTel) return;
            gtag('event', 'click_outbound', {
              link_url: href,
              link_domain: isExternal ? (new URL(href)).hostname : (isMail ? 'mailto' : 'tel'),
              link_text: (a.textContent || '').trim().slice(0, 80),
              outbound: isExternal,
              contact_channel: isMail ? 'email' : (isTel ? 'phone' : 'web'),
              transport_type: 'beacon',
            });
          }, true);
        </script>
      </>
    )}
    {/* Favicons. Google's search-result favicon picker uses the highest
        sized PNG it can find via <link rel="icon">, so the 192/512 PNGs
        are listed FIRST and the small 16/32 variants only after — they
        only serve browser-tab use. SVG follows because some browsers
        prefer it, but it's not the one Google ranks for SERPs. */}
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="FindToursIn Blog" href="/blog/rss.xml" />
    <link rel="alternate" type="application/feed+json" title="FindToursIn Blog (JSON Feed)" href="/blog/feed.json" />
    {/* Preload the homepage hero JPG only when this Layout is rendering the
        homepage. On every other page (tour detail, blog, pricing, about)
        the hero never displays, so preloading it cost ~1.3 MB of wasted
        bandwidth on cold loads. */}
    {Astro.url.pathname === '/' && (
      <link rel="preload" as="image" href="/images/hero-bg.jpg" fetchpriority="high" />
    )}
    <link rel="canonical" href={canonicalURL} />
    {/* Hreflang self-references. Site is English-only today; declaring
        en + x-default future-proofs us for el/it/es/de/pt expansion
        (Greek matters for Greece-tour queries from .gr searches) and
        prevents Google from inferring the wrong default language. */}
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    {/* Astro View Transitions — SPA-like cross-page navigation using
        the native browser View Transitions API. Pages now slide rather
        than reload, which improves perceived performance and INP. The
        `astro:page-load` listener below re-fires the GA4 page_view
        event on transition so analytics integrity is preserved. */}
    <ClientRouter />
    {/* Search-engine ownership verification. Each tag renders only when
        the corresponding PUBLIC_*_VERIFICATION env var is set. Adding
        them is the prerequisite for claiming the property in each
        console (Search Console, Bing Webmaster Tools, Yandex Webmaster,
        Pinterest). */}
    {GOOGLE_VERIFICATION && <meta name="google-site-verification" content={GOOGLE_VERIFICATION} />}
    {BING_VERIFICATION && <meta name="msvalidate.01" content={BING_VERIFICATION} />}
    {YANDEX_VERIFICATION && <meta name="yandex-verification" content={YANDEX_VERIFICATION} />}
    {PINTEREST_VERIFICATION && <meta name="p:domain_verify" content={PINTEREST_VERIFICATION} />}
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="FindToursIn" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={absoluteOgImage} />

    {/* Site-wide WebSite JSON-LD with SearchAction. Tells Google we
        have a working internal search at /tours?search={q}, which
        unlocks the sitelinks search box rich result — a search field
        embedded directly in the SERP listing. Only fires on the
        homepage to avoid the duplicated-entity warning Search Console
        otherwise raises. */}
    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://www.findtoursin.com/#website",
        "url": "https://www.findtoursin.com",
        "name": "FindToursIn",
        "description": "Tour-discovery marketplace connecting travellers with vetted local tour agencies in Greece, Turkey, Italy, Bulgaria, and Albania.",
        "publisher": { "@id": "https://www.findtoursin.com/#organization" },
        "inLanguage": "en",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://www.findtoursin.com/tours?search={search_term_string}",
          },
          "query-input": "required name=search_term_string",
        },
      })} />
    )}

    {/* Site-wide Organization JSON-LD. The same @id is used everywhere so
        Google de-duplicates this entity across every page render. Enriched
        with contactPoint, sameAs, foundingDate, and slogan — the fields
        AI engines lift to describe the brand in answer cards. */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://www.findtoursin.com/#organization",
      "name": "FindToursIn",
      "alternateName": "Find Tours In",
      "url": "https://www.findtoursin.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.findtoursin.com/icon-512.png",
        "width": 512,
        "height": 512,
      },
      "slogan": "Find your next tour from trusted local agencies — no booking fees, no commission.",
      "description": "FindToursIn is a marketplace of vetted local tour agencies in Greece, Turkey, Italy, Bulgaria, and Albania. Browse itineraries and contact agencies directly — we charge no booking fee or commission.",
      "foundingDate": "2025",
      "areaServed": [
        { "@type": "Country", "name": "Greece" },
        { "@type": "Country", "name": "Turkey" },
        { "@type": "Country", "name": "Italy" },
        { "@type": "Country", "name": "Bulgaria" },
        { "@type": "Country", "name": "Albania" },
      ],
      "knowsAbout": [
        "Guided tours",
        "Tour agencies",
        "Travel itineraries",
        "Cultural tours",
        "Food tours",
        "Walking tours",
        "Day trips",
        "Multi-day tours",
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "info@findtoursin.com",
        "availableLanguage": ["English"],
      },
      "sameAs": [
        // Populate with verified social profiles as they go live; the
        // empty array is harmless and the field self-documents intent.
      ],
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <slot />
    <WebVitals />

    <!-- Global <img> error fallback. If a remote image (Unsplash, Supabase
         storage, agency upload, etc.) fails to load we paint a neutral
         placeholder over the image's box so the layout never collapses or
         shows a browser-default broken-image glyph. Opt-out per image with
         `data-no-fallback`. Inline so it runs before any image errors fire. -->
    <script is:inline>
      (function () {
        const PLACEHOLDER =
          "data:image/svg+xml;utf8," +
          encodeURIComponent(
            "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23a3a3a3' stroke-width='1.5'><rect x='3' y='3' width='18' height='18' rx='2' ry='2' fill='%23f3f4f6'/><circle cx='8.5' cy='8.5' r='1.5'/><path d='M21 15l-5-5L5 21'/></svg>"
          );
        function handle(target) {
          if (!(target instanceof HTMLImageElement)) return;
          if (target.dataset.fallbackApplied === '1') return;
          if (target.dataset.noFallback === '1') return;
          target.dataset.fallbackApplied = '1';
          target.src = PLACEHOLDER;
          target.classList.add('object-contain', 'bg-gray-100', 'p-4');
          target.alt = target.alt || 'Image unavailable';
        }
        window.addEventListener('error', function (ev) { handle(ev.target); }, true);
      })();
    </script>
  </body>
</html>
