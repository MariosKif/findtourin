---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourCard from '../../components/tours/TourCard.astro';
import { supabase } from '../../lib/supabase';
import { slugify } from '../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTours } from '../../lib/tour-helpers';

// Public agency profile — edge-cache 5 min, stale up to a day.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300, stale-while-revalidate=86400');

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/tours');

// Look up agency by slugified(company_name) — fall back to slugified(name).
const { data: agencies } = await supabase
  .from('users')
  .select('id, name, company_name, company_desc, website, phone, avatar_url, is_verified, created_at')
  .eq('role', 'agency');

const agency = (agencies || []).find((a: any) => {
  const s = slugify(a.company_name || a.name || '');
  return s === slug;
});

if (!agency) return Astro.redirect('/tours');

const { data: toursData } = await supabase
  .from('tours')
  .select(TOUR_LIST_SELECT)
  .eq('agency_id', agency.id)
  .eq('status', 'active')
  .order('view_count', { ascending: false });

const tours = normalizeTours(toursData);

// Aggregate stats about the agency for the profile card
const countrySet = new Set<string>();
const categorySet = new Set<string>();
for (const t of tours) {
  if (t.country) countrySet.add(t.country);
  if (t.category) categorySet.add(t.category);
}
const countries = Array.from(countrySet);
const categories = Array.from(categorySet);
const priceFrom = tours.length > 0 ? Math.min(...tours.map((t: any) => Number(t.price) || Infinity).filter((n: number) => isFinite(n))) : null;
const memberSince = new Date(agency.created_at || Date.now()).getFullYear();

const displayName = agency.company_name || agency.name;
const pageTitle = `${displayName} — Tours on FindToursIn`;
const metaDescription = agency.company_desc
  ? agency.company_desc.slice(0, 155)
  : `${displayName} offers ${tours.length} ${tours.length === 1 ? 'tour' : 'tours'}${countries.length > 0 ? ` in ${countries.slice(0, 3).join(', ')}` : ''}. View itineraries and contact the agency directly on FindToursIn.`;
const canonical = `https://www.findtoursin.com/agencies/${slug}`;
---

<PublicLayout title={pageTitle} description={metaDescription}>
  <!-- Hero / Profile Card -->
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/tours" class="hover:text-primary-600">Tours</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{displayName}</span>
      </nav>

      <div class="flex flex-col md:flex-row items-start gap-8">
        <!-- Avatar -->
        <div class="shrink-0">
          {agency.avatar_url ? (
            <img src={agency.avatar_url} alt={displayName} class="w-24 h-24 rounded-2xl object-cover bg-gray-100" />
          ) : (
            <div class="w-24 h-24 rounded-2xl bg-primary-600 text-white flex items-center justify-center font-heading text-3xl">
              {displayName.charAt(0).toUpperCase()}
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <h1 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900">{displayName}</h1>
            {agency.is_verified && (
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-100 text-green-700 text-xs font-semibold">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                Verified
              </span>
            )}
          </div>

          {agency.company_desc && (
            <p class="text-gray-700 leading-relaxed max-w-2xl mb-4">{agency.company_desc}</p>
          )}

          <!-- Stats row -->
          <div class="flex flex-wrap gap-6 text-sm text-gray-600">
            <div>
              <span class="font-semibold text-gray-900">{tours.length}</span> {tours.length === 1 ? 'tour' : 'tours'}
            </div>
            {countries.length > 0 && (
              <div>
                <span class="font-semibold text-gray-900">{countries.length}</span> {countries.length === 1 ? 'country' : 'countries'}
              </div>
            )}
            {priceFrom !== null && (
              <div>
                From <span class="font-semibold text-gray-900">€{priceFrom}</span>
              </div>
            )}
            <div>
              Listing since <span class="font-semibold text-gray-900">{memberSince}</span>
            </div>
          </div>

          <!-- Contact buttons -->
          <div class="flex flex-wrap gap-3 mt-6">
            {agency.website && (
              <a href={agency.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Visit website
              </a>
            )}
            {agency.phone && (
              <a href={`tel:${agency.phone}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {categories.length > 1 && (
      <section class="mb-10">
        <h2 class="font-heading text-xl font-normal text-gray-900 mb-4">Tour categories</h2>
        <div class="flex flex-wrap gap-2">
          {categories.map((c) => (
            <span class="inline-block px-3 py-1.5 rounded-full bg-gray-100 text-gray-700 text-sm">{c}</span>
          ))}
        </div>
      </section>
    )}

    <section class="mb-12">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">
        {tours.length > 0 ? `All tours by ${displayName}` : `${displayName} has no active tours right now`}
      </h2>
      {tours.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
          {tours.map((t: any, index: number) => (
            <TourCard tour={t} index={index} />
          ))}
        </div>
      ) : (
        <p class="text-gray-500">Check back soon — new listings are added regularly.</p>
      )}
    </section>
  </div>

  <!-- TravelAgency Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TravelAgency",
    "name": displayName,
    "description": agency.company_desc || metaDescription,
    "url": canonical,
    "image": agency.avatar_url || undefined,
    "areaServed": countries.map((c) => ({ "@type": "Country", "name": c })),
    "telephone": agency.phone || undefined,
    "sameAs": agency.website ? [agency.website] : undefined,
  })} />

  <!-- Breadcrumbs -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      { "@type": "ListItem", "position": 3, "name": displayName, "item": canonical },
    ],
  })} />

  <!-- ItemList of agency tours -->
  {tours.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "itemListElement": tours.slice(0, 10).map((t: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://www.findtoursin.com/tours/${t.slug}`,
        "name": t.name,
      })),
    })} />
  )}
</PublicLayout>
