---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { BEST_OF } from '../../lib/seo/best-of';
import { currentYear } from '../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const year = currentYear();
const pageTitle = `Best-of tour rankings ${year} — FindToursIn editorial`;
const metaDescription = `Editorially ranked "best of" lists across our regions — best Greece tours, best day trips, best food tours. ${BEST_OF.length} curated lists, updated annually.`;
const canonical = 'https://www.findtoursin.com/best';
const SITE = 'https://www.findtoursin.com';
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Best of</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Best-of tour rankings
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl" data-speakable="true">
        Editorial picks ranked with reasoning. We don\'t accept payment for placement; rankings are based on itinerary depth, agency reliability, and price-to-value. Lists drop tours that go offline and re-rank annually.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-4 sm:grid-cols-2">
      {BEST_OF.map((b) => (
        <a href={`/best/${b.slug}`} class="group rounded-2xl border border-gray-200 p-6 hover:border-primary-400 hover:shadow-md transition-all">
          <p class="text-xs font-medium text-primary-700 uppercase tracking-wider mb-2">{b.country || 'Editorial'}</p>
          <h2 class="font-heading text-xl text-gray-900 group-hover:text-primary-700">{b.title}</h2>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">{b.tagline}</p>
          <p class="mt-3 text-xs text-gray-500">{b.picks.length} picks · Updated {b.updated}</p>
        </a>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "isPartOf": { "@id": `${SITE}/#organization` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": BEST_OF.length,
    "itemListElement": BEST_OF.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/best/${b.slug}`,
      "name": b.title,
    })),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Best of", "item": canonical },
    ],
  })} />
</PublicLayout>
