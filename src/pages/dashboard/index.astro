---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabase';
import { formatPrice } from '../../lib/utils';
import { getListingCapState } from '../../lib/subscriptions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// Fetch tours
const { data: allUserTours } = await supabase
  .from('tours')
  .select('*')
  .eq('agency_id', user.id);

const tours = allUserTours || [];
const totalListings = tours.length;
const activeListings = tours.filter(t => t.status === 'active').length;
const pendingPayment = tours.filter(t => t.status === 'pending_payment').length;
const totalViews = tours.reduce((sum, t) => sum + (t.view_count || 0), 0);

// Total spent
const { data: paymentsData } = await supabase
  .from('payments')
  .select('amount')
  .eq('agency_id', user.id)
  .eq('status', 'completed');

const totalSpent = (paymentsData || []).reduce((sum, p) => sum + (p.amount || 0), 0);

// Recent listings
const recentTours = [...tours]
  .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())
  .slice(0, 5);

// Top performing
const topTours = [...tours]
  .filter(t => t.status === 'active')
  .sort((a, b) => (b.view_count || 0) - (a.view_count || 0))
  .slice(0, 5);

const capState = await getListingCapState(user.id);
const capUsedPercent = Math.min(100, Math.round((capState.used / capState.max) * 100));

const url = new URL(Astro.request.url);
const activated = url.searchParams.get('activated');
const codeFailed = url.searchParams.get('code_failed');

const codeFailMessages: Record<string, string> = {
  not_found: 'The code you entered was not found.',
  inactive: 'That code is currently disabled.',
  exhausted: 'That code has reached its redemption limit.',
  plan_not_eligible: 'That code does not apply to your selected plan.',
  per_user_exhausted: 'You have already redeemed that code the maximum number of times.',
  rpc_failed: 'We could not activate the code. Contact support if this keeps happening.',
};
const codeFailedMessage = codeFailed ? codeFailMessages[codeFailed] || 'The discount code could not be applied.' : null;

const statusColors: Record<string, string> = {
  active: 'bg-green-100 text-green-700',
  pending_payment: 'bg-amber-100 text-amber-700',
  inactive: 'bg-gray-100 text-gray-600',
  deleted: 'bg-red-100 text-red-600',
};
---

<DashboardLayout title="Dashboard">
  {activated && (
    <div class="mb-6 rounded-xl bg-green-50 border border-green-200 p-4 text-sm text-green-800 flex items-start gap-3">
      <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p>Your <strong class="capitalize">{activated}</strong> plan is now active. Welcome aboard!</p>
    </div>
  )}
  {codeFailedMessage && (
    <div class="mb-6 rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p>{codeFailedMessage} Your account is set up — you can redeem a different code from <a href="/dashboard/pricing" class="underline">the pricing page</a>.</p>
    </div>
  )}
  {/* Subscription status banner */}
  <div class="bg-gray-50 rounded-xl p-4 flex items-center justify-between mb-6">
    <div>
      <p class="text-sm font-medium text-gray-900">Subscription Status</p>
      <p class="text-xs text-gray-500">Manage your subscription to keep listings active</p>
    </div>
    <a href="/dashboard/subscription" class="px-3 py-1.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 hover:bg-amber-200 transition-colors">
      View Subscription
    </a>
  </div>

  {/* Stats grid */}
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center gap-3 mb-2">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="text-sm text-gray-500">Total Views</span>
      </div>
      <p class="text-2xl font-bold text-gray-900">{totalViews.toLocaleString()}</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center gap-3 mb-2">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm text-gray-500">Active Listings</span>
      </div>
      <p class="text-2xl font-bold text-gray-900">{activeListings}</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center gap-3 mb-2">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm text-gray-500">Pending</span>
      </div>
      <p class="text-2xl font-bold text-gray-900">{pendingPayment}</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center gap-3 mb-2">
        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <span class="text-sm text-gray-500">Total Listings</span>
      </div>
      <p class="text-2xl font-bold text-gray-900">{totalListings}</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-sm font-medium text-gray-500">Plan Usage</p>
        <span class="text-xs font-semibold uppercase tracking-wider text-primary-600">{capState.plan.name}</span>
      </div>
      <p class="text-2xl font-bold text-gray-900">
        {capState.used} <span class="text-base font-normal text-gray-400">/ {capState.max}</span>
      </p>
      <div class="mt-3 h-1.5 w-full bg-gray-100 rounded-full overflow-hidden">
        <div
          class:list={['h-full transition-all', capState.atCap ? 'bg-red-500' : capUsedPercent >= 80 ? 'bg-amber-500' : 'bg-primary-500']}
          style={`width: ${capUsedPercent}%`}
        ></div>
      </div>
      {capState.atCap && (
        <a href="/dashboard/pricing" class="mt-3 inline-block text-xs font-semibold text-red-600 hover:underline">
          Upgrade to add more listings →
        </a>
      )}
    </div>
  </div>

  {/* Two panels */}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {/* Recent Listings */}
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Recent Listings</h2>
        <a href="/dashboard/tours" class="text-sm text-primary-600 hover:underline">View all</a>
      </div>
      {recentTours.length > 0 ? (
        <div class="space-y-1">
          {recentTours.map((tour) => (
            <a href={`/dashboard/tours/${tour.id}/edit`} class="flex items-center justify-between py-3 px-3 rounded-lg hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                  {tour.images?.[0]?.url ? (
                    <img src={tour.images[0].url} alt="" class="w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full bg-gray-200" />
                  )}
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate">{tour.name}</p>
                  <p class="text-xs text-gray-500">{tour.country} · {tour.category}</p>
                </div>
              </div>
              <span class:list={['text-xs font-medium px-2 py-1 rounded-full shrink-0 ml-2', statusColors[tour.status] || 'bg-gray-100 text-gray-600']}>
                {tour.status === 'pending_payment' ? 'Pending' : tour.status}
              </span>
            </a>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center h-40 text-gray-400 text-sm">
          <p>No listings yet</p>
          <a href="/dashboard/tours/new" class="mt-2 text-primary-600 hover:underline">Create your first tour</a>
        </div>
      )}
    </div>

    {/* Top Performing */}
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Top Performing</h2>
        <a href="/dashboard/analytics" class="text-sm text-primary-600 hover:underline">View all</a>
      </div>
      {topTours.length > 0 ? (
        <div class="space-y-1">
          {topTours.map((tour) => (
            <div class="flex items-center justify-between py-3 px-3 rounded-lg hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                  {tour.images?.[0]?.url ? (
                    <img src={tour.images[0].url} alt="" class="w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full bg-gray-200" />
                  )}
                </div>
                <p class="text-sm font-medium text-gray-900 truncate">{tour.name}</p>
              </div>
              <div class="flex items-center gap-1 text-sm text-gray-500 shrink-0 ml-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                {tour.view_count || 0}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="flex items-center justify-center h-40 text-gray-400 text-sm">
          No active tours yet
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
