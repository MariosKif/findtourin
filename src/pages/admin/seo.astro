---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabase';
import { slugify, getCityIntentCopy, getDayTripCopy } from '../../lib/destinations';
import { INTENT_SLUGS, tourMatchesIntent, MIN_TOURS_FOR_INDEX, humanIntent } from '../../lib/programmatic';
import { TOUR_LIST_SELECT } from '../../lib/tour-helpers';
import { scoreTourSeo } from '../../lib/seo/scorer';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') return Astro.redirect('/');

// ---- Fetch the live state once ----
const [toursResult, agenciesResult, notFoundResult] = await Promise.all([
  supabase.from('tours').select(TOUR_LIST_SELECT).eq('status', 'active'),
  supabase.from('users').select('id, name, company_name, is_verified').eq('role', 'agency'),
  // Top missing paths from the last 7 days. The view is created by the
  // not-found-log migration; if the migration hasn't been applied yet
  // this query errors out and we fall back to an empty list.
  supabase.from('top_missing_paths_7d').select('*').limit(50),
]);

const tours = (toursResult.data || []) as any[];
const agencies = (agenciesResult.data || []) as any[];
const missingPaths = (notFoundResult.data || []) as { path: string; total_hits: number; latest: string }[];

// ---- Tour scoring ----
const scoredTours = tours.map((t) => ({
  id: t.id,
  slug: t.slug,
  name: t.name,
  agencyId: t.agency_id,
  ...scoreTourSeo(t),
}));
scoredTours.sort((a, b) => a.score - b.score);
const tourScoreSummary = {
  ready: scoredTours.filter((t) => t.verdict === 'ready').length,
  borderline: scoredTours.filter((t) => t.verdict === 'borderline').length,
  needsWork: scoredTours.filter((t) => t.verdict === 'needs-work').length,
};
const worstTours = scoredTours.slice(0, 10);

// ---- Hub-coverage analysis (mirrors the seo-health cron logic) ----
const countryToursCount = new Map<string, { name: string; count: number }>();
const cityBucket = new Map<string, { countrySlug: string; citySlug: string; cityName: string; countryName: string; tours: any[] }>();

for (const t of tours) {
  if (!t.country) continue;
  const cs = slugify(t.country);
  const existing = countryToursCount.get(cs) || { name: t.country, count: 0 };
  existing.count += 1;
  countryToursCount.set(cs, existing);
  if (t.city) {
    const key = `${cs}|${slugify(t.city)}`;
    if (!cityBucket.has(key)) {
      cityBucket.set(key, { countrySlug: cs, citySlug: slugify(t.city), cityName: t.city, countryName: t.country, tours: [] });
    }
    cityBucket.get(key)!.tours.push(t);
  }
}

const indexableCountries = Array.from(countryToursCount.values()).filter((c) => c.count >= 2);
const indexableCities = Array.from(cityBucket.values()).filter((b) => b.tours.length >= 2);
const oneAwayCities = Array.from(cityBucket.values())
  .filter((b) => b.tours.length === 1)
  .map((b) => ({ city: b.cityName, country: b.countryName }))
  .sort((a, b) => a.country.localeCompare(b.country) || a.city.localeCompare(b.city));

// Editorial gaps: city × intent combos that pass the ≥3-tour gate but
// don't have curated copy yet. These are the most actionable items —
// a hand-written 150-word intent passage unlocks a fully-indexable page.
interface EditorialGap {
  city: string;
  country: string;
  intent: string;
  matchingTours: number;
}
const editorialGaps: EditorialGap[] = [];
for (const bucket of cityBucket.values()) {
  for (const intent of INTENT_SLUGS) {
    const matches = bucket.tours.filter((t: any) => tourMatchesIntent(t, intent)).length;
    if (matches < MIN_TOURS_FOR_INDEX) continue;
    const copy = getCityIntentCopy(bucket.cityName, bucket.countryName, intent);
    if (copy.curated) continue;
    editorialGaps.push({ city: bucket.cityName, country: bucket.countryName, intent, matchingTours: matches });
  }
  // Day-trip gap
  const dayTripCount = bucket.tours.filter((t: any) => {
    const d = typeof t.duration_days === 'number' ? t.duration_days : null;
    return d !== null && d <= 1;
  }).length;
  if (dayTripCount >= MIN_TOURS_FOR_INDEX && !getDayTripCopy(bucket.cityName).curated) {
    editorialGaps.push({ city: bucket.cityName, country: bucket.countryName, intent: 'day-trips-from', matchingTours: dayTripCount });
  }
}
editorialGaps.sort((a, b) => b.matchingTours - a.matchingTours);

// Verified-agency rate
const verifiedAgencies = agencies.filter((a) => a.is_verified).length;
const verificationRate = agencies.length > 0 ? Math.round((verifiedAgencies / agencies.length) * 100) : 0;
---

<DashboardLayout title="SEO Health Dashboard">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-8">
      <h1 class="font-heading text-3xl font-normal text-gray-900">SEO Health Dashboard</h1>
      <p class="mt-2 text-gray-600">Live state of every SEO surface. Updated each render.</p>
    </header>

    {/* ---- Top stats grid ---- */}
    <section class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="rounded-2xl border border-gray-200 p-5 bg-white">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-1">Active tours</p>
        <p class="text-3xl font-heading text-gray-900">{tours.length}</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-5 bg-white">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-1">Agencies</p>
        <p class="text-3xl font-heading text-gray-900">{agencies.length}</p>
        <p class="text-xs text-gray-500 mt-1">{verifiedAgencies} verified ({verificationRate}%)</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-5 bg-white">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-1">Indexable countries</p>
        <p class="text-3xl font-heading text-gray-900">{indexableCountries.length}</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-5 bg-white">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-1">Indexable cities</p>
        <p class="text-3xl font-heading text-gray-900">{indexableCities.length}</p>
      </div>
    </section>

    {/* ---- Tour SEO scoring summary ---- */}
    <section class="mb-10">
      <h2 class="font-heading text-2xl text-gray-900 mb-4">Tour SEO scores</h2>
      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="rounded-2xl border border-green-200 bg-green-50 p-5">
          <p class="text-xs uppercase tracking-wider text-green-700 mb-1">Ready (≥80)</p>
          <p class="text-3xl font-heading text-green-900">{tourScoreSummary.ready}</p>
        </div>
        <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5">
          <p class="text-xs uppercase tracking-wider text-amber-700 mb-1">Borderline (60-79)</p>
          <p class="text-3xl font-heading text-amber-900">{tourScoreSummary.borderline}</p>
        </div>
        <div class="rounded-2xl border border-red-200 bg-red-50 p-5">
          <p class="text-xs uppercase tracking-wider text-red-700 mb-1">Needs work (&lt;60)</p>
          <p class="text-3xl font-heading text-red-900">{tourScoreSummary.needsWork}</p>
        </div>
      </div>

      {worstTours.length > 0 && (
        <div class="rounded-2xl border border-gray-200 overflow-hidden bg-white">
          <div class="px-5 py-3 border-b border-gray-200 bg-gray-50">
            <h3 class="font-medium text-gray-900">Worst-scored tours (top 10 to fix)</h3>
          </div>
          <table class="w-full text-left">
            <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wider">
              <tr>
                <th class="px-5 py-3">Tour</th>
                <th class="px-5 py-3 text-right">Score</th>
                <th class="px-5 py-3">Top issue</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {worstTours.map((t) => (
                <tr>
                  <td class="px-5 py-4">
                    <a href={`/tours/${t.slug}`} class="text-primary-700 hover:underline font-medium">{t.name}</a>
                  </td>
                  <td class="px-5 py-4 text-right">
                    <span class={
                      t.verdict === 'ready' ? 'inline-flex items-center px-2.5 py-1 rounded-full bg-green-100 text-green-800 text-xs font-semibold' :
                      t.verdict === 'borderline' ? 'inline-flex items-center px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold' :
                      'inline-flex items-center px-2.5 py-1 rounded-full bg-red-100 text-red-800 text-xs font-semibold'
                    }>{t.score}/100</span>
                  </td>
                  <td class="px-5 py-4 text-sm text-gray-700">
                    {t.issues[0] ? t.issues[0].message : 'No issues'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    {/* ---- Editorial gaps (city × intent combos missing curated copy) ---- */}
    <section class="mb-10">
      <h2 class="font-heading text-2xl text-gray-900 mb-2">Editorial gaps</h2>
      <p class="text-sm text-gray-600 mb-4">City × intent combos that pass the ≥3-tour gate but have no curated copy yet. Adding a 150-word passage unlocks each as an indexable page.</p>
      {editorialGaps.length > 0 ? (
        <div class="rounded-2xl border border-gray-200 overflow-hidden bg-white">
          <table class="w-full text-left">
            <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wider">
              <tr>
                <th class="px-5 py-3">City</th>
                <th class="px-5 py-3">Intent</th>
                <th class="px-5 py-3 text-right">Tours matching</th>
                <th class="px-5 py-3">File to edit</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {editorialGaps.map((gap) => (
                <tr>
                  <td class="px-5 py-4 text-gray-900">{gap.city}, {gap.country}</td>
                  <td class="px-5 py-4 text-gray-700">{gap.intent === 'day-trips-from' ? 'Day trips from' : humanIntent(gap.intent)}</td>
                  <td class="px-5 py-4 text-right text-gray-700">{gap.matchingTours}</td>
                  <td class="px-5 py-4 text-xs text-gray-500 font-mono">
                    {gap.intent === 'day-trips-from' ? 'src/lib/destinations.ts → DAY_TRIP_COPY' : 'src/lib/destinations.ts → INTENT_COPY'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="text-sm text-gray-500 italic">No editorial gaps right now — every eligible city × intent has curated copy.</p>
      )}
    </section>

    {/* ---- One-away cities (single tour, hub suppressed) ---- */}
    {oneAwayCities.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl text-gray-900 mb-2">One-tour-short cities</h2>
        <p class="text-sm text-gray-600 mb-4">Cities with exactly one tour. Adding a second tour unlocks the city hub. Each unlocked hub is one new indexable page.</p>
        <div class="flex flex-wrap gap-2">
          {oneAwayCities.map((c) => (
            <span class="inline-block px-3 py-1.5 rounded-full bg-amber-50 text-amber-800 text-sm">
              {c.city}, {c.country}
            </span>
          ))}
        </div>
      </section>
    )}

    {/* ---- Top missing paths (404 hits) ---- */}
    {missingPaths.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl text-gray-900 mb-2">Top missing paths (last 7 days)</h2>
        <p class="text-sm text-gray-600 mb-4">URLs that hit our 404 page repeatedly. Could indicate broken internal links, mistyped URLs from external referrers, or genuine content opportunities.</p>
        <div class="rounded-2xl border border-gray-200 overflow-hidden bg-white">
          <table class="w-full text-left">
            <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wider">
              <tr>
                <th class="px-5 py-3">Path</th>
                <th class="px-5 py-3 text-right">Hits</th>
                <th class="px-5 py-3 text-right">Last seen</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {missingPaths.slice(0, 20).map((p) => (
                <tr>
                  <td class="px-5 py-4 font-mono text-xs text-gray-700">{p.path}</td>
                  <td class="px-5 py-4 text-right text-gray-900">{p.total_hits}</td>
                  <td class="px-5 py-4 text-right text-gray-500 text-xs">{new Date(p.latest).toISOString().slice(0, 10)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {/* ---- Operations links ---- */}
    <section class="mb-10">
      <h2 class="font-heading text-2xl text-gray-900 mb-4">Operations</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/sitemap-dynamic.xml" target="_blank" rel="noopener" class="rounded-2xl border border-gray-200 p-5 bg-white hover:border-primary-400 transition-colors">
          <h3 class="font-heading text-lg text-gray-900 mb-1">Live sitemap</h3>
          <p class="text-sm text-gray-600">Inspect what's currently indexed</p>
        </a>
        <a href="/llms.txt" target="_blank" rel="noopener" class="rounded-2xl border border-gray-200 p-5 bg-white hover:border-primary-400 transition-colors">
          <h3 class="font-heading text-lg text-gray-900 mb-1">llms.txt</h3>
          <p class="text-sm text-gray-600">AI-engine context document</p>
        </a>
        <a href="/api/cron/seo-health" target="_blank" rel="noopener" class="rounded-2xl border border-gray-200 p-5 bg-white hover:border-primary-400 transition-colors">
          <h3 class="font-heading text-lg text-gray-900 mb-1">SEO health cron</h3>
          <p class="text-sm text-gray-600">JSON output of the nightly run</p>
        </a>
      </div>
    </section>

  </div>
</DashboardLayout>
