---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourCard from '../../components/tours/TourCard.astro';
import FAQSection from '../../components/common/FAQSection.astro';
import { supabase } from '../../lib/supabase';
import { slugify, getCountryCopy, getCityCopy, getDayTripCopy } from '../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTour } from '../../lib/tour-helpers';
import { imgUrl, imgSrcset } from '../../lib/image';
import { shouldIndex, getYearStampedTitle, currentYear, MIN_TOURS_FOR_INDEX } from '../../lib/programmatic';

// Public landing — edge-cache 5 min, stale up to a day.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300, stale-while-revalidate=86400');

const { city: citySlug } = Astro.params;
if (!citySlug) return new Response('Not found', { status: 404 });

// Pull all active tours and find the canonical city name (DB casing).
const { data: allTours } = await supabase
  .from('tours')
  .select(TOUR_LIST_SELECT)
  .eq('status', 'active');

// Day-trip filter heuristic: tours based in {city} with duration of 1 day
// or less. Day-trip pages target the "day trips from {city}" keyword family
// — one of the highest-traffic patterns in the vertical. Conservative on
// purpose: tours we can't classify (no duration set) are excluded so the
// thin-content gate stays honest.
const cityTours = (allTours || []).filter((t: any) => t.city && slugify(t.city) === citySlug);
const tours = cityTours.filter((t: any) => {
  const d = typeof t.duration_days === 'number' ? t.duration_days : null;
  return d !== null && d <= 1;
});

if (cityTours.length === 0) {
  return new Response('Not found', { status: 404 });
}

const cityName = cityTours[0].city as string;
const countryName = cityTours[0].country as string;
const countrySlug = slugify(countryName);

const copy = getDayTripCopy(cityName);
const cityCopy = getCityCopy(cityName, countryName);
const countryCopy = getCountryCopy(countryName);

// Gate: ≥3 single-day tours AND curated copy. Otherwise 404.
if (!shouldIndex({ tourCount: tours.length, hasUniqueCopy: copy.curated, minTours: MIN_TOURS_FOR_INDEX })) {
  return new Response('Not found', { status: 404 });
}

const tourCount = tours.length;
const priceFrom = Math.min(...tours.map((t: any) => Number(t.price) || Infinity).filter((n: number) => isFinite(n)));
const heroImage = tours.find((t: any) => t.images?.[0]?.url)?.images?.[0]?.url || countryCopy.heroImage;

const toursGridData = tours
  .sort((a: any, b: any) => (b.view_count || 0) - (a.view_count || 0))
  .map(normalizeTour);

const year = currentYear();
const pageTitle = getYearStampedTitle('day-trips-from', { city: cityName });
const metaDescription = `${tourCount} day trips from ${cityName}, ${countryName} ${year}. ${copy.topDestinations.length > 0 ? `Top destinations: ${copy.topDestinations.slice(0, 3).join(', ')}.` : ''} Compare itineraries and book directly with local agencies.`;
const canonical = `https://www.findtoursin.com/day-trips-from/${citySlug}`;
---

<PublicLayout
  title={pageTitle}
  description={metaDescription}
  image={heroImage}
  canonical={canonical}
>
  <!-- Hero -->
  <section class="relative h-[300px] sm:h-[380px] overflow-hidden">
    <img
      src={imgUrl(heroImage, 1280)}
      srcset={imgSrcset(heroImage, [640, 960, 1280, 1920])}
      sizes="100vw"
      alt={`Day trips from ${cityName}, ${countryName}`}
      width="1280"
      height="380"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/30 to-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-end py-10">
      <nav class="text-sm text-white/80 mb-3">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/tours" class="hover:text-white">Tours</a>
        <span class="mx-2">/</span>
        <a href={`/tours/in/${countrySlug}/${citySlug}`} class="hover:text-white">{cityName}</a>
        <span class="mx-2">/</span>
        <span class="text-white">Day trips</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl font-normal text-white leading-tight">
        Day Trips from {cityName} {year}
      </h1>
      <p class="mt-3 text-lg text-white/90 max-w-2xl">{tourCount} {tourCount === 1 ? 'excursion' : 'excursions'} from €{priceFrom}</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Curated intro -->
    <section class="max-w-3xl mb-10">
      <p class="text-lg text-gray-700 leading-relaxed" data-speakable="true">{copy.intro}</p>
    </section>

    <!-- Top destinations these day trips reach -->
    {copy.topDestinations.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-xl font-normal text-gray-900 mb-4">Where these trips go</h2>
        <div class="flex flex-wrap gap-2">
          {copy.topDestinations.map((d) => (
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-50 text-primary-700 text-sm font-medium">
              {d}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- Tours grid -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">All day trips from {cityName}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        {toursGridData.map((t: any, index: number) => (
          <TourCard tour={t} index={index} />
        ))}
      </div>
    </section>

    <!-- Cross-link back -->
    <section class="grid gap-4 sm:grid-cols-2 mb-12">
      <a href={`/tours/in/${countrySlug}/${citySlug}`} class="p-6 rounded-2xl bg-gray-50 border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors">
        <p class="text-sm text-gray-500">All tours in</p>
        <p class="font-heading text-xl text-gray-900">{cityName} &rarr;</p>
      </a>
      <a href={`/tours/in/${countrySlug}`} class="p-6 rounded-2xl bg-gray-50 border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors">
        <p class="text-sm text-gray-500">All tours in</p>
        <p class="font-heading text-xl text-gray-900">{countryName} &rarr;</p>
      </a>
    </section>

    <!-- FAQ (visible + FAQPage JSON-LD with Speakable) -->
    <FAQSection faqs={copy.faqs} />
  </div>

  <!-- CollectionPage + ItemList + BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "about": { "@type": "TouristDestination", "name": `${cityName}, ${countryName}` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      { "@type": "ListItem", "position": 3, "name": cityName, "item": `https://www.findtoursin.com/tours/in/${countrySlug}/${citySlug}` },
      { "@type": "ListItem", "position": 4, "name": "Day trips", "item": canonical },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": tourCount,
    "itemListElement": toursGridData.slice(0, 10).map((t: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://www.findtoursin.com/tours/${t.slug}`,
      "name": t.name,
    })),
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
