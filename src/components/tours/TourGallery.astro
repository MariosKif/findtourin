---
interface Props {
  images: {
    url: string;
    altText?: string | null;
  }[];
}

const { images } = Astro.props;
const hasImages = images.length > 0;
---

{hasImages ? (
  <div class="tour-gallery">
    {/* Main Image */}
    <div class="mb-3 overflow-hidden rounded-2xl bg-gray-100">
      <img
        id="gallery-main"
        src={images[0].url}
        alt={images[0].altText || 'Tour image'}
        class="h-[400px] w-full object-cover transition-opacity duration-300 md:h-[500px]"
      />
    </div>

    {/* Thumbnail Strip */}
    {images.length > 1 && (
      <div class="flex gap-2 overflow-x-auto pb-2" id="gallery-thumbs">
        {images.map((img, i) => (
          <button
            type="button"
            class:list={[
              'gallery-thumb shrink-0 overflow-hidden rounded-lg border-2 transition-all duration-200 hover:opacity-100',
              i === 0 ? 'border-primary-500 opacity-100' : 'border-transparent opacity-60',
            ]}
            data-url={img.url}
            data-alt={img.altText || 'Tour image'}
            data-index={i}
          >
            <img
              src={img.url}
              alt={img.altText || `Thumbnail ${i + 1}`}
              class="h-20 w-28 object-cover"
              loading="lazy"
            />
          </button>
        ))}
      </div>
    )}
  </div>
) : (
  <div class="flex h-[400px] items-center justify-center rounded-2xl bg-gradient-to-br from-primary-400 to-secondary-500 md:h-[500px]">
    <svg class="h-24 w-24 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
  </div>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mainImg = document.getElementById('gallery-main') as HTMLImageElement | null;
    const thumbContainer = document.getElementById('gallery-thumbs');
    if (!mainImg || !thumbContainer) return;

    const thumbs = thumbContainer.querySelectorAll<HTMLButtonElement>('.gallery-thumb');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const url = thumb.dataset.url;
        const alt = thumb.dataset.alt || 'Tour image';

        if (!url) return;

        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = url;
          mainImg.alt = alt;
          mainImg.style.opacity = '1';
        }, 150);

        thumbs.forEach((t) => {
          t.classList.remove('border-primary-500', 'opacity-100');
          t.classList.add('border-transparent', 'opacity-60');
        });
        thumb.classList.remove('border-transparent', 'opacity-60');
        thumb.classList.add('border-primary-500', 'opacity-100');
      });
    });
  });
</script>
