---
const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-300">
  <!-- Newsletter row -->
  <div class="border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-heading text-xl text-white font-normal">Stay inspired</h3>
          <p class="text-sm text-gray-400 mt-1">Get the latest tours and travel tips in your inbox.</p>
        </div>
        <form class="flex w-full sm:w-auto gap-2">
          <input
            type="email"
            placeholder="Your email address"
            class="w-full sm:w-64 px-4 py-2.5 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-500 text-sm focus:outline-none focus:border-primary-500"
          />
          <button type="submit" class="px-5 py-2.5 rounded-lg bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium transition-colors cursor-pointer whitespace-nowrap">
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-2 font-heading text-xl text-white">
          <svg class="w-8 h-8 shrink-0" viewBox="0 0 64 64" fill="none">
            <path d="M32 4C19.85 4 10 13.85 10 26c0 14.4 18.8 31.2 20.5 32.8a2 2 0 002.9 0C35.2 57.2 54 40.4 54 26 54 13.85 44.15 4 32 4z" class="fill-primary-400" />
            <path d="M32 4c-7.5 0-14 3.6-18.2 9.2C17.4 16.8 24.2 19 32 19c10 0 18.5-4 22-10C49.8 6 41.5 4 32 4z" class="fill-primary-300" />
            <path d="M54 26c0-3.2-.6-6.2-1.8-9-3.5 6-12 10-22.2 10-7 0-13.2-1.8-17.6-4.8C11.5 24 11 25 10.6 26.2c1.4 4 8.6 7.8 18.4 7.8C42 34 51 30 54 26z" class="fill-primary-200/60" />
            <circle cx="32" cy="26" r="11" class="fill-gray-950" />
            <path d="M32 16.5l3 8.5h-6l3-8.5z" class="fill-primary-400" />
            <path d="M32 35.5l-3-8.5h6l-3 8.5z" class="fill-primary-300/60" />
            <path d="M41.5 26l-8.5 3v-6l8.5 3z" class="fill-primary-300/60" />
            <path d="M22.5 26l8.5-3v6l-8.5-3z" class="fill-primary-300/60" />
            <circle cx="32" cy="26" r="3.5" class="fill-secondary-500" />
          </svg>
          FindToursIn
        </a>
        <p class="mt-4 text-sm text-gray-400 max-w-md">
          Discover amazing tours from trusted agencies worldwide. Your next adventure is just a click away.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Explore</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/tours" class="text-sm hover:text-white transition-colors">Browse Tours</a></li>
          <li><a href="/blog" class="text-sm hover:text-white transition-colors">Blog</a></li>
          <li><a href="/about" class="text-sm hover:text-white transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- For Agencies -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">For Agencies</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/auth/register" class="text-sm hover:text-white transition-colors">List Your Tours</a></li>
          <li><a href="/auth/login" class="text-sm hover:text-white transition-colors">Agency Login</a></li>
          <li><a href="/dashboard" class="text-sm hover:text-white transition-colors">Dashboard</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-400">&copy; {year} FindToursIn. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <!-- Social media placeholders -->
        <div class="flex items-center gap-4">
          <a href="#" class="text-gray-500 hover:text-white transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="text-gray-500 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="text-gray-500 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
        <span class="text-gray-700">|</span>
        <a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
