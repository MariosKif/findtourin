---
export const prerender = false;
import PublicLayout from '../layouts/PublicLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import FeaturedTours from '../components/home/FeaturedTours.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import PopularDestinations from '../components/home/PopularDestinations.astro';
import { FEATURED_TOURS } from '../lib/demo-tours';
import { supabase } from '../lib/supabase';
import { TOUR_LIST_SELECT, normalizeTour } from '../lib/tour-helpers';

// --- Real data from DB (with safe fallback) ---
let featuredTours: any[] = FEATURED_TOURS as any[];
let stats = { tours: 0, agencies: 0, countries: 0 };
let realDestinations: { city: string; country: string; image: string }[] | undefined = undefined;

// Public page; no per-user content. Let Vercel edge cache the HTML for 5 min,
// serve stale up to a day while revalidating in background. Repeat visits drop
// from ~1.8s to ~50ms.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300, stale-while-revalidate=86400');

try {
  // Two queries in parallel — they're independent, sequential = 2× the latency.
  const [toursResp, countResp] = await Promise.all([
    supabase
      .from('tours')
      .select(TOUR_LIST_SELECT)
      .eq('status', 'active')
      .order('view_count', { ascending: false })
      .limit(50),
    supabase
      .from('tours')
      .select('*', { count: 'exact', head: true })
      .eq('status', 'active'),
  ]);
  const toursData = toursResp.data;
  const totalTours = countResp.count;

  if (toursData && toursData.length > 0) {
    // Featured: top 6 by views
    featuredTours = toursData.slice(0, 6).map(normalizeTour);

    const agencyIds = new Set<string>();
    const countries = new Set<string>();
    toursData.forEach((t: any) => {
      if (t.agency_id) agencyIds.add(t.agency_id);
      if (t.country) countries.add(t.country);
    });

    stats = {
      tours: totalTours || toursData.length,
      agencies: agencyIds.size,
      countries: countries.size,
    };

    // Destinations: pick up to 8 unique cities with tours, prefer most-viewed
    const seen = new Set<string>();
    const picked: { city: string; country: string; image: string }[] = [];
    const DEFAULT_CITY_IMG: Record<string, string> = {
      Santorini: "https://images.unsplash.com/photo-1613395877344-13d4a8e0d49e?w=400&h=560&fit=crop",
      Mykonos: "https://images.unsplash.com/photo-1601581875309-fafbf2d3ed3a?w=400&h=560&fit=crop",
      Corfu: "https://images.unsplash.com/photo-1580137189272-c9379f8864fd?w=400&h=560&fit=crop",
      Crete: "https://images.unsplash.com/photo-1570077188670-e3a8d69ac5ff?w=400&h=560&fit=crop",
      "Veliko Tarnovo": "/images/veliko.jpg",
      Ksamil: "https://images.unsplash.com/photo-1596005554384-d293674c91d7?w=400&h=560&fit=crop",
      Istanbul: "https://images.unsplash.com/photo-1541432901042-2d8bd64b4a9b?w=400&h=560&fit=crop",
      Athens: "https://images.unsplash.com/photo-1555993539-1732b0258235?w=400&h=560&fit=crop",
      Rhodes: "https://images.unsplash.com/photo-1504512485720-7d83a16ee930?w=400&h=560&fit=crop",
      Meteora: "https://images.unsplash.com/photo-1586956214029-4a41d7a7d24a?w=400&h=560&fit=crop",
      Heraklion: "https://images.unsplash.com/photo-1602867741746-6df80f40b3f6?w=400&h=560&fit=crop",
      Zakynthos: "https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=400&h=560&fit=crop",
      Siena: "https://images.unsplash.com/photo-1537799943037-f5da89a65689?w=400&h=560&fit=crop",
      Naples: "https://images.unsplash.com/photo-1534445867742-43195f401b6c?w=400&h=560&fit=crop",
      Fethiye: "https://images.unsplash.com/photo-1604873660580-1b2b5e3c5e94?w=400&h=560&fit=crop",
      Izmir: "https://images.unsplash.com/photo-1568322503975-e8bbc926ce08?w=400&h=560&fit=crop",
      "La Spezia": "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?w=400&h=560&fit=crop",
      Ioannina: "https://images.unsplash.com/photo-1486870591958-9b9d0d1dda99?w=400&h=560&fit=crop",
      Litochoro: "https://images.unsplash.com/photo-1551632811-561732d1e306?w=400&h=560&fit=crop",
      Delphi: "https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?w=400&h=560&fit=crop",
    };
    for (const t of toursData) {
      if (!t.city || !t.country) continue;
      const key = `${t.city}|${t.country}`;
      if (seen.has(key)) continue;
      seen.add(key);
      const img = DEFAULT_CITY_IMG[t.city] || t.images?.[0]?.url || '/images/hero-bg.jpg';
      picked.push({ city: t.city, country: t.country, image: img });
      if (picked.length === 8) break;
    }
    if (picked.length > 0) realDestinations = picked;
  }
} catch {
  // DB unavailable — silently fall through to demo data
}

const heroStats = stats.tours > 0 ? stats : undefined;
---

<PublicLayout
  title="FindToursIn — 0% Commission Tours in Greece, Italy, Türkiye & Beyond"
  description="Browse curated tours from trusted local agencies across Greece, Italy, Türkiye, Albania and Bulgaria. Contact operators directly — zero commission, no booking fees."
>
  <HeroSection stats={heroStats} />
  <FeaturedTours tours={featuredTours} />
  <PopularDestinations destinations={realDestinations} />
  <HowItWorks />

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-primary-800 to-primary-900 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-normal text-white">Ready to Share Your Tours with the World?</h2>
      <p class="mt-4 text-xl font-semibold text-white">0% Commission &middot; Keep 100% of Your Revenue</p>
      <p class="mt-3 text-lg text-primary-200 max-w-2xl mx-auto">
        Join hundreds of agencies already listing their tours on FindToursIn.
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 backdrop-blur-sm text-white text-sm rounded-full border border-white/20">
          <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          0% Commission
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 backdrop-blur-sm text-white text-sm rounded-full border border-white/20">
          <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Direct Bookings
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 backdrop-blur-sm text-white text-sm rounded-full border border-white/20">
          <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Simple Pricing
        </span>
      </div>
      <p class="mt-3 text-sm text-primary-300">Trusted by 200+ agencies worldwide</p>
      <div class="mt-8">
        <a
          href="/auth/register"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-primary-800 font-semibold rounded-lg hover:bg-gray-100 transition-colors duration-200"
        >
          List Your Tours
        </a>
      </div>
    </div>
  </section>

  <!-- GSAP Animations -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Hero animations
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    if (document.querySelector('#hero-title')) {
      heroTl.from('#hero-title', { y: 40, opacity: 0, duration: 1 });
    }
    if (document.querySelector('#hero-search')) {
      heroTl.from('#hero-search', { y: 30, opacity: 0, duration: 0.8 }, '-=0.4');
    }
    if (document.querySelector('#hero-stats')) {
      heroTl.from('#hero-stats', { y: 20, opacity: 0, duration: 0.5 }, '-=0.3');
    }

    // Scroll-triggered animations
    const sections = ['.featured-tours-section', '.how-it-works-section'];
    sections.forEach((selector) => {
      const el = document.querySelector(selector);
      if (!el) return;

      const targets = el.querySelectorAll('.tour-card, .destination-card');
      if (!targets.length) return;
      gsap.fromTo(targets,
        { y: 40, opacity: 0 },
        {
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: 'power2.out',
        }
      );
    });

    // Section headings
    document.querySelectorAll('section h2').forEach((heading) => {
      gsap.fromTo(heading,
        { y: 20, opacity: 0 },
        {
          scrollTrigger: {
            trigger: heading,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
          y: 0,
          opacity: 1,
          duration: 0.5,
          ease: 'power2.out',
        }
      );
    });
  </script>

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "FindToursIn",
    "url": "https://www.findtoursin.com",
    "logo": "https://www.findtoursin.com/images/logo-icon.svg",
    "description": "Tour discovery platform connecting travellers with trusted tour agencies across Southeast Europe and the Mediterranean.",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "url": "https://www.findtoursin.com/contact"
    },
    "sameAs": []
  })} />

  <!-- WebSite Schema with SearchAction -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "FindToursIn",
    "url": "https://www.findtoursin.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.findtoursin.com/tours?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
</PublicLayout>
