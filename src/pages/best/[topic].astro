---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourCard from '../../components/tours/TourCard.astro';
import FAQSection from '../../components/common/FAQSection.astro';
import { supabase } from '../../lib/supabase';
import { TOUR_LIST_SELECT, normalizeTour } from '../../lib/tour-helpers';
import { getBestOfList, BEST_OF } from '../../lib/seo/best-of';
import { currentYear, MIN_TOURS_FOR_INDEX } from '../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400');

const { topic } = Astro.params;
if (!topic) return new Response('Not found', { status: 404 });

const list = getBestOfList(topic);
if (!list) return new Response('Not found', { status: 404 });

// Resolve picks against live tours. Drops any pick whose slug no longer
// exists in the DB so we never link to a dead tour. The index gate below
// requires at least MIN_TOURS_FOR_INDEX surviving picks.
const slugs = list.picks.map((p) => p.slug);
const { data: liveTours } = await supabase
  .from('tours')
  .select(TOUR_LIST_SELECT)
  .eq('status', 'active')
  .in('slug', slugs);

const tourBySlug = new Map<string, any>();
for (const t of (liveTours || []) as any[]) {
  if (t.slug) tourBySlug.set(t.slug, normalizeTour(t));
}

const resolvedPicks = list.picks
  .map((pick) => ({ pick, tour: tourBySlug.get(pick.slug) }))
  .filter((p) => p.tour);

if (resolvedPicks.length < MIN_TOURS_FOR_INDEX) {
  // Editorial slug exists but not enough picks survived against the DB —
  // ship as 404 rather than as a thin page. The author can re-pick when
  // tours come back.
  return new Response('Not found', { status: 404 });
}

const SITE = 'https://www.findtoursin.com';
const canonical = `${SITE}/best/${list.slug}`;
const year = currentYear();
const pageTitle = `${list.title} ${year} — Editorially Ranked`;
const metaDescription = list.description;
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/best" class="hover:text-primary-600">Best of</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{list.title}</span>
      </nav>
      <p class="text-xs font-medium text-primary-700 uppercase tracking-wider mb-2">FindToursIn editorial · {year}</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        {list.title} {year}
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl">{list.tagline}</p>
      <p class="mt-2 text-sm text-gray-500">{resolvedPicks.length} picks · Updated {list.updated}</p>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Lead passage (speakable, the part LLMs cite) -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 leading-relaxed" data-speakable="true">{list.intro}</p>
    </section>

    <!-- Ranked picks -->
    <section class="space-y-10 mb-14">
      {resolvedPicks.map((p, i) => (
        <article class="grid sm:grid-cols-[3.5rem_1fr] gap-4 sm:gap-6">
          <div class="text-5xl font-heading text-primary-200 sm:text-right leading-none">#{i + 1}</div>
          <div>
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h2 class="font-heading text-2xl text-gray-900">
                <a href={`/tours/${p.pick.slug}`} class="hover:text-primary-700">{p.tour.name}</a>
              </h2>
              {p.pick.callout && (
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-50 text-primary-700 text-xs font-semibold">{p.pick.callout}</span>
              )}
            </div>
            <p class="text-gray-700 leading-relaxed mb-4" data-speakable="true">{p.pick.rationale}</p>
            <div class="rounded-2xl border border-gray-200 p-4 sm:p-5">
              <TourCard tour={p.tour} index={i} />
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Methodology note — editorial transparency -->
    <section class="mb-14 rounded-2xl border border-gray-200 bg-gray-50 p-6">
      <h2 class="font-heading text-lg text-gray-900 mb-2">How we ranked this list</h2>
      <p class="text-gray-700 text-sm leading-relaxed">
        Editorial picks based on itinerary depth, agency reliability (verified status, tenure on FindToursIn), and price-to-value ratio. We don\'t accept payment for placement. Tours that drop off the platform are removed from this list automatically; the list ships only when ≥3 picks remain live.
      </p>
    </section>

    <!-- FAQs -->
    <FAQSection faqs={list.faqs} />

    <!-- Related -->
    {list.related.length > 0 && (
      <section class="mt-14 p-6 rounded-2xl bg-white border border-gray-200">
        <h2 class="font-heading text-xl text-gray-900 mb-4">Related</h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {list.related.map((r) => (
            <li><a href={r.href} class="text-primary-700 hover:underline">{r.label} &rarr;</a></li>
          ))}
        </ul>
      </section>
    )}

  </article>

  <!-- Article + ItemList: ItemList is the schema that powers the
       "Top X for Y" rich result family on Google. Each picked tour is
       a ListItem with position. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "datePublished": list.updated,
    "dateModified": list.updated,
    "lastReviewed": list.updated,
    "author": { "@id": `${SITE}/#organization` },
    "publisher": { "@id": `${SITE}/#organization` },
    "mainEntityOfPage": canonical,
    "inLanguage": "en",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["[data-speakable]"],
    },
    ...(list.country ? { "about": [{ "@type": "Country", "name": list.country }] } : {}),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": list.title,
    "description": list.description,
    "url": canonical,
    "numberOfItems": resolvedPicks.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": resolvedPicks.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/tours/${p.pick.slug}`,
      "name": p.tour.name,
      "description": p.pick.rationale,
    })),
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Best of", "item": `${SITE}/best` },
      { "@type": "ListItem", "position": 3, "name": list.title, "item": canonical },
    ],
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
