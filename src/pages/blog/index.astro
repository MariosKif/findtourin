---
import PublicLayout from '../../layouts/PublicLayout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<PublicLayout title="Blog" description="Travel tips, destination guides, and industry insights from FindToursIn.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-4 text-lg text-gray-600">Travel tips, destination guides, and industry insights.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-gray-500">No blog posts yet. Check back soon!</p>
      </div>
    )}
  </div>
</PublicLayout>
