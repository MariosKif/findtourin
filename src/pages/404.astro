---
import PublicLayout from '../layouts/PublicLayout.astro';
import { supabase } from '../lib/supabase';
import { slugify } from '../lib/destinations';
import { GUIDES } from '../lib/seo/guides';

// 404s are noindex by definition. Beyond that, we make this page useful:
//  - search box that goes straight to /tours search
//  - top destinations from live DB
//  - top guides
//  - top blog posts
// All non-blocking — DB failure just shows a leaner version.

let topCountries: { name: string; slug: string; count: number }[] = [];
let topCities: { name: string; countrySlug: string; citySlug: string }[] = [];

try {
  const { data } = await supabase
    .from('tours')
    .select('country, city')
    .eq('status', 'active');
  if (data) {
    const cMap = new Map<string, number>();
    const cityMap = new Map<string, { name: string; country: string; count: number }>();
    for (const row of data as { country?: string; city?: string }[]) {
      if (row.country) {
        cMap.set(row.country, (cMap.get(row.country) || 0) + 1);
        if (row.city) {
          const key = `${row.country}|${row.city}`;
          const e = cityMap.get(key) || { name: row.city, country: row.country, count: 0 };
          e.count += 1;
          cityMap.set(key, e);
        }
      }
    }
    topCountries = Array.from(cMap.entries())
      .map(([name, count]) => ({ name, slug: slugify(name), count }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 5);
    topCities = Array.from(cityMap.values())
      .filter((c) => c.count >= 2)
      .sort((a, b) => b.count - a.count)
      .slice(0, 6)
      .map((c) => ({ name: c.name, countrySlug: slugify(c.country), citySlug: slugify(c.name) }));
  }
} catch {
  // skip silently
}

const requestedPath = Astro.url.pathname;
const topGuides = GUIDES.slice(0, 4);
---

<PublicLayout title="Page Not Found (404)" description="The page you requested doesn't exist. Browse our destinations, guides, and tours instead." noIndex={true}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-7xl sm:text-8xl font-heading text-primary-200 leading-none">404</p>
      <h1 class="mt-4 text-3xl sm:text-4xl font-heading font-normal text-gray-900">Page not found</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-xl mx-auto">
        The page <code class="px-2 py-0.5 rounded bg-gray-100 text-gray-700 text-sm break-all">{requestedPath}</code> doesn\'t exist or has moved. Try one of the routes below.
      </p>
    </div>

    <!-- Search box — submits to /tours with the query -->
    <form action="/tours" method="GET" class="max-w-xl mx-auto mb-12">
      <label for="q" class="sr-only">Search tours</label>
      <div class="flex gap-2">
        <input
          id="q"
          name="search"
          type="search"
          placeholder="Search tours by destination or activity"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:border-primary-500"
          autocomplete="off"
          autofocus
        />
        <button type="submit" class="px-6 py-3 rounded-lg bg-primary-600 hover:bg-primary-700 text-white font-medium transition-colors cursor-pointer whitespace-nowrap">
          Search
        </button>
      </div>
      <p class="mt-2 text-xs text-gray-500 text-center">Or browse by destination below.</p>
    </form>

    <!-- Top countries -->
    {topCountries.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-xl text-gray-900 mb-4">Popular destinations</h2>
        <div class="flex flex-wrap gap-2">
          {topCountries.map((c) => (
            <a href={`/tours/in/${c.slug}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
              {c.name}
              <span class="text-xs text-gray-400">{c.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {topCities.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-xl text-gray-900 mb-4">Popular cities</h2>
        <div class="flex flex-wrap gap-2">
          {topCities.map((c) => (
            <a href={`/tours/in/${c.countrySlug}/${c.citySlug}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
              {c.name}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Guides -->
    <section class="mb-10">
      <h2 class="font-heading text-xl text-gray-900 mb-4">Planning guides</h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        {topGuides.map((g) => (
          <li><a href={`/guide/${g.slug}`} class="text-primary-700 hover:underline">{g.title.split(':')[0]} →</a></li>
        ))}
        <li><a href="/guide/glossary" class="text-primary-700 hover:underline">Tour-industry glossary →</a></li>
      </ul>
    </section>

    <!-- Quick links -->
    <section class="mt-12 p-6 rounded-2xl bg-gray-50 border border-gray-200">
      <h2 class="font-heading text-lg text-gray-900 mb-3">Or jump to</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-800 transition-colors">Homepage</a>
        <a href="/tours" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">All tours</a>
        <a href="/blog" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">Travel blog</a>
        <a href="/best" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">Best of</a>
        <a href="/itineraries" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">Itineraries</a>
        <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">Contact</a>
      </div>
    </section>
  </div>

  {/* Log this 404 to the server-side analytics. We avoid logging from
      the page itself (server-side) because Astro's 404 fallback runs
      twice (once per redirect attempt). The client-side beacon dedupes
      via sessionStorage and only fires once per pathname per session. */}
  <script is:inline define:vars={{ path: requestedPath }}>
    (function () {
      try {
        var key = '404:' + path;
        if (sessionStorage.getItem(key)) return;
        sessionStorage.setItem(key, '1');
        var ref = document.referrer ? document.referrer.slice(0, 500) : '';
        navigator.sendBeacon
          ? navigator.sendBeacon('/api/404-log', JSON.stringify({ path: path, referer: ref }))
          : fetch('/api/404-log', { method: 'POST', body: JSON.stringify({ path: path, referer: ref }), keepalive: true });
      } catch {}
    })();
  </script>
</PublicLayout>
