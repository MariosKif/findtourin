---
interface Props {
  tour: {
    id: string;
    name: string;
    slug: string;
    description: string;
    country: string;
    city: string;
    departureCountry?: string | null;
    departureCity?: string | null;
    price: string;
    currency: string;
    category: string;
    durationDays: number | null;
    thumbnail: string | null;
    rating?: number;
    reviewCount?: number;
    bookingCount?: number;
  };
}

const { tour } = Astro.props;

const currencySymbols: Record<string, string> = {
  EUR: '\u20AC',
  USD: '$',
  GBP: '\u00A3',
};
const symbol = currencySymbols[tour.currency] || tour.currency;

const destinationLabel = `${tour.city}, ${tour.country}`;
const ratingValue = tour.rating ?? 0;
---

<a
  href={`/tours/${tour.slug}`}
  class="tour-card group block overflow-hidden rounded-xl bg-white transition-all duration-300 hover:shadow-lg"
>
  {/* Image */}
  <div class="relative aspect-[4/3] overflow-hidden rounded-xl bg-gray-100">
    {tour.thumbnail ? (
      <img
        src={tour.thumbnail}
        alt={tour.name}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
        <svg class="h-16 w-16 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    )}

    {/* Duration pill - bottom left */}
    {tour.durationDays && (
      <span class="absolute bottom-3 left-3 rounded-full bg-black/60 px-3 py-1 text-xs font-medium text-white">
        {tour.durationDays} {tour.durationDays === 1 ? 'day' : 'days'}
      </span>
    )}

    {/* Wishlist heart button - top right */}
    <button
      type="button"
      class="wishlist-btn absolute top-3 right-3 flex h-9 w-9 items-center justify-center rounded-full bg-white/80 backdrop-blur-sm shadow-sm transition-colors hover:bg-white"
      data-tour-id={tour.id}
      aria-label="Add to favourites"
      onclick="event.preventDefault(); event.stopPropagation();"
    >
      {/* Outline heart (default) */}
      <svg class="wishlist-icon-outline h-5 w-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      {/* Filled heart (wishlisted) */}
      <svg class="wishlist-icon-filled hidden h-5 w-5 text-red-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
  </div>

  {/* Content */}
  <div class="pt-3 pb-1">
    {/* Category - show on hover */}
    <span class="text-[11px] font-medium uppercase tracking-wider text-primary-600 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
      {tour.category}
    </span>

    <h3 class="mt-0.5 text-[15px] font-semibold text-gray-900 transition-colors group-hover:text-primary-600 line-clamp-2">
      {tour.name}
    </h3>

    {/* Destination */}
    <p class="mt-1 text-sm text-gray-500 line-clamp-1">{destinationLabel}</p>

    {/* Rating + Price row */}
    <div class="mt-2 flex items-center justify-between">
      {/* Compact rating */}
      {tour.rating != null ? (
        <div class="flex items-center gap-1">
          <svg class="h-3.5 w-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm font-medium text-gray-700">{ratingValue.toFixed(1)}</span>
          {tour.reviewCount != null && (
            <span class="text-xs text-gray-400">({tour.reviewCount})</span>
          )}
        </div>
      ) : (
        <div></div>
      )}

      {/* Price */}
      <div>
        <span class="text-xs text-gray-400">From </span>
        <span class="text-base font-bold text-gray-900">{symbol}{Number(tour.price).toLocaleString()}</span>
      </div>
    </div>
  </div>
</a>

<script>
  let favouritesCache: string[] | null = null;
  let fetchPromise: Promise<string[]> | null = null;

  async function loadFavourites(): Promise<string[]> {
    if (favouritesCache !== null) return favouritesCache;
    if (fetchPromise) return fetchPromise;

    fetchPromise = fetch('/api/favourites')
      .then(res => {
        if (!res.ok) return [];
        return res.json();
      })
      .catch(() => []);

    favouritesCache = await fetchPromise;
    fetchPromise = null;
    return favouritesCache!;
  }

  async function initWishlistButtons() {
    const buttons = document.querySelectorAll('.wishlist-btn');
    const favs = await loadFavourites();

    buttons.forEach((btn) => {
      const tourId = (btn as HTMLElement).dataset.tourId;
      if (!tourId) return;

      const outlineIcon = btn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const filledIcon = btn.querySelector('.wishlist-icon-filled') as HTMLElement;
      if (!outlineIcon || !filledIcon) return;

      // Set initial state
      if (favs.includes(tourId)) {
        outlineIcon.classList.add('hidden');
        filledIcon.classList.remove('hidden');
      } else {
        outlineIcon.classList.remove('hidden');
        filledIcon.classList.add('hidden');
      }

      // Remove old listeners by cloning
      const newBtn = btn.cloneNode(true) as HTMLElement;
      newBtn.onclick = (e) => { e.preventDefault(); e.stopPropagation(); };
      btn.parentNode?.replaceChild(newBtn, btn);

      const newOutline = newBtn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const newFilled = newBtn.querySelector('.wishlist-icon-filled') as HTMLElement;

      newBtn.addEventListener('click', async () => {
        const isFavourited = !newOutline.classList.contains('hidden') === false;

        if (isFavourited) {
          // Remove favourite
          newOutline.classList.remove('hidden');
          newFilled.classList.add('hidden');

          const res = await fetch(`/api/favourites/${tourId}`, { method: 'DELETE' });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache = favouritesCache.filter(id => id !== tourId);
          }
        } else {
          // Add favourite
          newOutline.classList.add('hidden');
          newFilled.classList.remove('hidden');
          newFilled.classList.add('wishlist-heartbeat');
          setTimeout(() => newFilled.classList.remove('wishlist-heartbeat'), 600);

          const res = await fetch('/api/favourites', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tourId }),
          });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache.push(tourId);
          }
        }
      });
    });
  }

  // Run on initial load and on Astro page navigations
  initWishlistButtons();
  document.addEventListener('astro:after-swap', () => {
    favouritesCache = null;
    initWishlistButtons();
  });
</script>
