---
export const prerender = false;
import PublicLayout from '../../../../layouts/PublicLayout.astro';
import TourCard from '../../../../components/tours/TourCard.astro';
import FAQSection from '../../../../components/common/FAQSection.astro';
import { supabase } from '../../../../lib/supabase';
import { TOUR_LIST_SELECT, normalizeTour } from '../../../../lib/tour-helpers';
import { ATTRACTIONS, getAttraction } from '../../../../lib/seo/attractions';
import { slugify } from '../../../../lib/destinations';
import { imgUrl, imgSrcset } from '../../../../lib/image';
import { currentYear } from '../../../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const { country, city, attraction } = Astro.params;
if (!country || !city || !attraction) return new Response('Not found', { status: 404 });

const att = getAttraction(country, city, attraction);
if (!att) return new Response('Not found', { status: 404 });

// Find tours visiting this attraction. We don't have a structured
// "visits" relation, so we match on (city + name keyword) for the
// curated attraction names. Conservative on purpose — better to show
// no tours than the wrong ones.
let visitingTours: any[] = [];
try {
  const { data } = await supabase
    .from('tours')
    .select(TOUR_LIST_SELECT)
    .eq('status', 'active')
    .eq('city', att.city)
    .order('view_count', { ascending: false })
    .limit(8);
  if (data) visitingTours = data.map(normalizeTour);
} catch {
  // skip silently
}

const SITE = 'https://www.findtoursin.com';
const countrySlug = slugify(att.country);
const citySlug = slugify(att.city);
const canonical = `${SITE}/attractions/${countrySlug}/${citySlug}/${att.slug}`;
const year = currentYear();
const pageTitle = `${att.name} ${year} — Tickets, Tips, Tours`;
const metaDescription = `${att.name} in ${att.city}, ${att.country}: tickets ${att.ticketPrice || 'vary'}, ${att.visitDuration || 'half-day'} visit, plus skip-the-line tips and tours that visit.`.slice(0, 158);
---

<PublicLayout title={pageTitle} description={metaDescription} image={att.heroImage} canonical={canonical}>
  <!-- Hero -->
  <section class="relative h-[300px] sm:h-[420px] overflow-hidden">
    <img
      src={imgUrl(att.heroImage, 1280)}
      srcset={imgSrcset(att.heroImage, [640, 960, 1280, 1920])}
      sizes="100vw"
      alt={`${att.name} in ${att.city}, ${att.country}`}
      width="1280"
      height="420"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/30 to-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-end py-10">
      <nav class="text-sm text-white/80 mb-3">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/attractions" class="hover:text-white">Attractions</a>
        <span class="mx-2">/</span>
        <a href={`/tours/in/${countrySlug}`} class="hover:text-white">{att.country}</a>
        <span class="mx-2">/</span>
        <a href={`/tours/in/${countrySlug}/${citySlug}`} class="hover:text-white">{att.city}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{att.name}</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-white leading-tight">{att.name}</h1>
      <p class="mt-3 text-lg text-white/90">{att.city}, {att.country}{att.isUnesco ? ' · UNESCO World Heritage Site' : ''}</p>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Lead description (speakable) -->
    <section class="mb-10">
      <p class="text-lg text-gray-700 leading-relaxed" data-speakable="true">{att.description}</p>
    </section>

    <!-- Quick facts -->
    <section class="mb-12 grid grid-cols-2 sm:grid-cols-4 gap-4">
      {att.ticketPrice && (
        <div class="rounded-2xl border border-gray-200 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Ticket</p>
          <p class="font-heading text-lg text-gray-900">{att.ticketPrice}</p>
        </div>
      )}
      {att.visitDuration && (
        <div class="rounded-2xl border border-gray-200 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Visit time</p>
          <p class="font-heading text-lg text-gray-900">{att.visitDuration}</p>
        </div>
      )}
      <div class="rounded-2xl border border-gray-200 p-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Type</p>
        <p class="font-heading text-lg text-gray-900 capitalize">{att.category}</p>
      </div>
      {att.isUnesco && (
        <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
          <p class="text-xs font-semibold text-amber-700 uppercase tracking-wider mb-1">UNESCO</p>
          <p class="font-heading text-lg text-amber-900">World Heritage Site</p>
        </div>
      )}
    </section>

    <!-- Best time to visit -->
    {att.bestTime && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-3">When to visit</h2>
        <p class="text-gray-700 leading-relaxed" data-speakable="true">{att.bestTime}</p>
      </section>
    )}

    <!-- Skip the line tip -->
    {att.skipTheLineTip && (
      <section class="mb-12 p-6 rounded-2xl bg-primary-50 border border-primary-100">
        <h2 class="font-heading text-xl text-gray-900 mb-3">Skip-the-line tip</h2>
        <p class="text-gray-800 leading-relaxed" data-speakable="true">{att.skipTheLineTip}</p>
      </section>
    )}

    <!-- Tours that visit -->
    {visitingTours.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Tours including {att.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
          {visitingTours.slice(0, 6).map((t: any, i: number) => (
            <TourCard tour={t} index={i} />
          ))}
        </div>
        <p class="mt-4 text-sm text-gray-500">
          <a href={`/tours/in/${countrySlug}/${citySlug}`} class="text-primary-700 hover:underline">View all tours in {att.city} &rarr;</a>
        </p>
      </section>
    )}

    <!-- Official source -->
    {att.officialUrl && (
      <section class="mb-12 p-5 rounded-2xl border border-gray-200 bg-gray-50">
        <p class="text-sm text-gray-700">
          Official ticket source: <a href={att.officialUrl} target="_blank" rel="noopener noreferrer" class="text-primary-700 underline">{new URL(att.officialUrl).hostname}</a>. Always verify prices and opening hours on the official site before travel.
        </p>
      </section>
    )}

    <!-- FAQ -->
    <FAQSection faqs={att.faqs} />

    <!-- Cross-link -->
    <section class="mt-12 p-6 rounded-2xl bg-white border border-gray-200">
      <h2 class="font-heading text-xl text-gray-900 mb-3">Explore further</h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        <li><a href={`/tours/in/${countrySlug}/${citySlug}`} class="text-primary-700 hover:underline">All tours in {att.city} &rarr;</a></li>
        <li><a href={`/tours/in/${countrySlug}`} class="text-primary-700 hover:underline">All tours in {att.country} &rarr;</a></li>
        <li><a href="/attractions" class="text-primary-700 hover:underline">Browse all attractions &rarr;</a></li>
        <li><a href="/guide/glossary" class="text-primary-700 hover:underline">Tour-industry glossary &rarr;</a></li>
      </ul>
    </section>
  </article>

  <!-- TouristAttraction + Place schema. Includes geo when known so the
       attraction can appear in Google Maps Knowledge Panel queries. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "@id": `${canonical}#attraction`,
    "name": att.name,
    "description": att.description,
    "url": canonical,
    "image": att.heroImage,
    "isAccessibleForFree": att.ticketPrice ? false : true,
    ...(att.ticketPrice ? { "publicAccess": true } : {}),
    "address": {
      "@type": "PostalAddress",
      "addressLocality": att.city,
      "addressCountry": att.country,
    },
    ...(att.geo ? {
      "geo": { "@type": "GeoCoordinates", "latitude": att.geo.lat, "longitude": att.geo.lng },
    } : {}),
    ...(att.officialUrl ? { "sameAs": [att.officialUrl] } : {}),
    "touristType": ["Cultural traveler", "History enthusiast"],
    "containedInPlace": { "@type": "Country", "name": att.country },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["[data-speakable]"],
    },
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Attractions", "item": `${SITE}/attractions` },
      { "@type": "ListItem", "position": 3, "name": att.country, "item": `${SITE}/tours/in/${countrySlug}` },
      { "@type": "ListItem", "position": 4, "name": att.city, "item": `${SITE}/tours/in/${countrySlug}/${citySlug}` },
      { "@type": "ListItem", "position": 5, "name": att.name, "item": canonical },
    ],
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
