---
export const prerender = false;
import AccountLayout from '../../layouts/AccountLayout.astro';
import TourCard from '../../components/tours/TourCard.astro';
import Button from '../../components/ui/Button.astro';
import { supabase } from '../../lib/supabase';
import { DEMO_TOURS } from '../../lib/demo-tours';
import { TOUR_LIST_SELECT, normalizeTour } from '../../lib/tour-helpers';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const { data: favData } = await supabase
  .from('favourites')
  .select('tour_id')
  .eq('user_id', user.id);

const tourIds = (favData || []).map(f => f.tour_id);

const allTours: any[] = [];
if (tourIds.length > 0) {
  const { data: toursData } = await supabase
    .from('tours')
    .select(TOUR_LIST_SELECT)
    .in('id', tourIds);

  (toursData || []).forEach((tour: any) => {
    allTours.push(normalizeTour(tour));
  });
}

// Fallback to demo tours for IDs not found in database
const foundIds = new Set(allTours.map(t => t.id));
const missingIds = tourIds.filter(id => !foundIds.has(id));
for (const missingId of missingIds) {
  const demoTour = DEMO_TOURS.find(t => t.id === missingId);
  if (demoTour) {
    allTours.push(normalizeTour(demoTour as any));
  }
}

const toursWithThumbnails = allTours;
---

<AccountLayout title="Favourites">
  {toursWithThumbnails.length > 0 ? (
    <div>
      <div class="flex items-center gap-2 mb-6 text-gray-600">
        <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <span class="text-sm font-medium">
          {toursWithThumbnails.length} {toursWithThumbnails.length === 1 ? 'tour' : 'tours'} saved
        </span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {toursWithThumbnails.map((tour, index) => (
          <TourCard tour={tour} index={index} />
        ))}
      </div>
    </div>
  ) : (
    <div class="text-center py-16 sm:py-24">
      <div class="mx-auto w-24 h-24 rounded-full bg-primary-50 flex items-center justify-center mb-6">
        <svg class="h-12 w-12 text-primary-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 font-heading">No favourites yet</h2>
      <p class="mt-3 text-gray-500 max-w-md mx-auto">
        When you find a tour you love, tap the heart icon to save it here.
        Your favourites will be waiting for you whenever you're ready to book.
      </p>

      <div class="mt-8">
        <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-3">Popular categories to explore</p>
        <div class="flex flex-wrap justify-center gap-2">
          {['Cultural', 'Adventure', 'Food & Wine', 'Nature', 'Beach & Island', 'Hiking & Trekking'].map((cat) => (
            <a
              href={`/tours?category=${encodeURIComponent(cat)}`}
              class="px-4 py-2 rounded-full border border-gray-200 text-sm text-gray-600 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50 transition-colors"
            >
              {cat}
            </a>
          ))}
        </div>
      </div>

      <div class="mt-8">
        <Button href="/tours" variant="primary">Explore Tours</Button>
      </div>
    </div>
  )}
</AccountLayout>
