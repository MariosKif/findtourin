---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { getAuthor } from '../../lib/seo/authors';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });

const author = getAuthor(slug);
if (!author) return new Response('Not found', { status: 404 });

const SITE = 'https://www.findtoursin.com';
const canonical = `${SITE}/authors/${author.slug}`;
const personId = `${canonical}#person`;
const pageTitle = `${author.name} — Author at FindToursIn`;
const metaDescription = `${author.name}, ${author.jobTitle} at FindToursIn. ${author.bio.slice(0, 100)}…`;

const imageHref = author.imageUrl || '/icon-512.png';
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Authors</span>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{author.name}</span>
      </nav>

      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img src={imageHref} alt={author.name} width="120" height="120" class="w-24 h-24 sm:w-32 sm:h-32 rounded-2xl object-cover bg-gray-100" loading="eager" />
        <div>
          <h1 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900 leading-tight">{author.name}</h1>
          <p class="mt-2 text-gray-600">{author.jobTitle} · FindToursIn</p>
          {author.sameAs.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {author.sameAs.map((url) => (
                <a href={url} target="_blank" rel="noopener noreferrer me" class="text-sm text-primary-700 hover:underline">{new URL(url).hostname}</a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-10">
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-4">About</h2>
      <p class="text-gray-700 leading-relaxed" data-speakable="true">{author.bio}</p>
    </section>

    {author.knowsAbout.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-4">Areas of expertise</h2>
        <div class="flex flex-wrap gap-2">
          {author.knowsAbout.map((k) => (
            <span class="inline-block px-3 py-1.5 rounded-full bg-primary-50 text-primary-700 text-sm font-medium">{k}</span>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="font-heading text-2xl font-normal text-gray-900 mb-4">Recent work</h2>
      <p class="text-gray-600 mb-4">Browse the latest editorial output:</p>
      <div class="flex flex-wrap gap-3">
        <a href="/blog" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">All blog posts &rarr;</a>
        <a href="/guide" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">All guides &rarr;</a>
      </div>
    </section>
  </div>

  <!-- Person JSON-LD. The @id ties this Person across blog posts, guides,
       and any other entity that credits the author by reference. Including
       worksFor and knowsAbout drives E-E-A-T signal. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personId,
    "name": author.name,
    "jobTitle": author.jobTitle,
    "url": canonical,
    "description": author.bio,
    "image": imageHref.startsWith('http') ? imageHref : `${SITE}${imageHref}`,
    "worksFor": { "@id": `${SITE}/#organization` },
    "knowsAbout": author.knowsAbout,
    "sameAs": author.sameAs,
  })} />

  <!-- ProfilePage signals to Google that this is the canonical author bio. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "url": canonical,
    "mainEntity": { "@id": personId },
    "isPartOf": { "@id": `${SITE}/#organization` },
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Authors", "item": `${SITE}/authors` },
      { "@type": "ListItem", "position": 3, "name": author.name, "item": canonical },
    ],
  })} />
</PublicLayout>
