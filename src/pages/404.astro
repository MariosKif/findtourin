---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Page Not Found">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <p class="text-8xl font-bold text-primary-200">404</p>
    <h1 class="mt-4 text-3xl font-bold text-gray-900">Page Not Found</h1>
    <p class="mt-4 text-lg text-gray-600 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-8 flex gap-4">
      <a href="/" class="px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
        Go Home
      </a>
      <a href="/tours" class="px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
        Browse Tours
      </a>
    </div>
  </div>
</PublicLayout>
