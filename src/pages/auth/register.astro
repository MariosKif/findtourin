---
export const prerender = false;

import PublicLayout from '../../layouts/PublicLayout.astro';
import RegisterForm from '../../components/auth/RegisterForm.astro';

const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/dashboard');
}
---

<PublicLayout title="Create Account" noIndex={true}>
  <div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="rounded-2xl bg-white p-8 shadow-lg border border-gray-100">
        <div class="mb-8 text-center">
          <h1 class="text-2xl font-bold text-gray-900">Create Account</h1>
          <p class="mt-2 text-gray-600">Join FindToursIn today</p>
          <div class="flex justify-center mt-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 border border-green-200 text-xs font-semibold text-green-700">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              0% Commission for Agencies
            </span>
          </div>
        </div>

        <RegisterForm />

        <p class="mt-6 text-center text-sm text-gray-600">
          Already have an account?
          <a href="/auth/login" class="font-medium text-primary-600 hover:text-primary-700">
            Log in
          </a>
        </p>
      </div>
    </div>
  </div>
</PublicLayout>
