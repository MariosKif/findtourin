---
interface Props {
  tour: {
    id: string;
    name: string;
    slug: string;
    description: string;
    country: string;
    city: string;
    departure_country?: string | null;
    departure_city?: string | null;
    price: string;
    currency: string;
    category: string;
    duration_days?: number | null;
    thumbnail: string | null;
    rating?: number;
    review_count?: number;
    view_count?: number;
    favouriteCount?: number;
  };
}

const { tour } = Astro.props;

const currencySymbols: Record<string, string> = {
  EUR: '\u20AC',
  USD: '$',
  GBP: '\u00A3',
};
const symbol = currencySymbols[tour.currency] || tour.currency;
const ratingValue = tour.rating ?? 0;
---

<a
  href={`/tours/${tour.slug}`}
  class="tour-card group block"
>
  {/* Image */}
  <div class="relative aspect-square overflow-hidden rounded-xl bg-gray-100">
    {tour.thumbnail ? (
      <img
        src={tour.thumbnail}
        alt={tour.name}
        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-gray-200 to-gray-300">
        <svg class="h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    )}

    {/* Wishlist heart button - top right */}
    <button
      type="button"
      class="wishlist-btn absolute top-2.5 right-2.5 flex h-8 w-8 items-center justify-center rounded-full bg-white/70 backdrop-blur-sm transition-all hover:bg-white hover:scale-110"
      data-tour-id={tour.id}
      aria-label="Add to favourites"
      onclick="event.preventDefault(); event.stopPropagation();"
    >
      <svg class="wishlist-icon-outline h-[18px] w-[18px] text-gray-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <svg class="wishlist-icon-filled hidden h-[18px] w-[18px] text-red-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
  </div>

  {/* Content */}
  <div class="mt-2.5">
    <h3 class="text-[15px] font-medium text-gray-900 leading-snug line-clamp-1">
      {tour.name}
    </h3>

    <p class="mt-0.5 text-sm text-gray-500 line-clamp-1">{tour.city}, {tour.country}</p>

    {/* Price & Rating */}
    <div class="mt-1 flex items-center gap-1 text-sm">
      <span class="text-gray-500">From</span>
      <span class="font-semibold text-gray-900">{symbol}{Number(tour.price).toLocaleString()}</span>
      {tour.rating != null && tour.rating > 0 && (
        <>
          <span class="text-gray-300 mx-0.5">&middot;</span>
          <svg class="h-3 w-3 text-gray-900" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-gray-900">{ratingValue.toFixed(2)}</span>
        </>
      )}
    </div>
  </div>
</a>

<script>
  let favouritesCache: string[] | null = null;
  let fetchPromise: Promise<string[]> | null = null;

  async function loadFavourites(): Promise<string[]> {
    if (favouritesCache !== null) return favouritesCache;
    if (fetchPromise) return fetchPromise;

    fetchPromise = fetch('/api/favourites')
      .then(res => {
        if (!res.ok) return [];
        return res.json();
      })
      .catch(() => []);

    favouritesCache = await fetchPromise;
    fetchPromise = null;
    return favouritesCache!;
  }

  async function initWishlistButtons() {
    const buttons = document.querySelectorAll('.wishlist-btn');
    const favs = await loadFavourites();

    buttons.forEach((btn) => {
      const tourId = (btn as HTMLElement).dataset.tourId;
      if (!tourId) return;

      const outlineIcon = btn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const filledIcon = btn.querySelector('.wishlist-icon-filled') as HTMLElement;
      if (!outlineIcon || !filledIcon) return;

      if (favs.includes(tourId)) {
        outlineIcon.classList.add('hidden');
        filledIcon.classList.remove('hidden');
      } else {
        outlineIcon.classList.remove('hidden');
        filledIcon.classList.add('hidden');
      }

      const newBtn = btn.cloneNode(true) as HTMLElement;
      newBtn.onclick = (e) => { e.preventDefault(); e.stopPropagation(); };
      btn.parentNode?.replaceChild(newBtn, btn);

      const newOutline = newBtn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const newFilled = newBtn.querySelector('.wishlist-icon-filled') as HTMLElement;

      newBtn.addEventListener('click', async () => {
        const isFavourited = !newOutline.classList.contains('hidden') === false;

        if (isFavourited) {
          newOutline.classList.remove('hidden');
          newFilled.classList.add('hidden');

          const res = await fetch(`/api/favourites/${tourId}`, { method: 'DELETE' });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache = favouritesCache.filter(id => id !== tourId);
          }
        } else {
          newOutline.classList.add('hidden');
          newFilled.classList.remove('hidden');
          newFilled.classList.add('wishlist-heartbeat');
          setTimeout(() => newFilled.classList.remove('wishlist-heartbeat'), 600);

          const res = await fetch('/api/favourites', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tourId }),
          });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache.push(tourId);
          }
        }
      });
    });
  }

  initWishlistButtons();
  document.addEventListener('astro:after-swap', () => {
    favouritesCache = null;
    initWishlistButtons();
  });
</script>
