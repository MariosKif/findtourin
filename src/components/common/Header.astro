---
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tours', label: 'Tours' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header id="site-header" class:list={[
  "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
  isHome ? "bg-transparent" : "bg-white/90 backdrop-blur-md border-b border-gray-100"
]}>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-5">
      <!-- Logo -->
      <a href="/" class:list={[
        "flex items-center gap-2 font-heading text-xl transition-colors",
        isHome ? "text-white header-logo" : "text-primary-700"
      ]}>
        <img src="/images/logo-icon.svg" alt="FindToursIn" class="w-10 h-10 shrink-0" />
        FindToursIn
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'uppercase tracking-wider text-[13px] font-semibold transition-colors',
              currentPath === link.href
                ? isHome
                  ? 'text-white border-b-2 border-white pb-1 header-nav-active'
                  : 'text-primary-600 border-b-2 border-primary-500 pb-1'
                : isHome
                  ? 'text-white/80 hover:text-white header-nav-link'
                  : 'text-gray-600 hover:text-primary-600',
            ]}
          >
            {link.label}
          </a>
        ))}
        {user?.role === 'admin' && (
          <a
            href="/admin"
            class:list={[
              'uppercase tracking-wider text-[13px] font-semibold transition-colors',
              currentPath.startsWith('/admin')
                ? isHome
                  ? 'text-white border-b-2 border-white pb-1 header-nav-active'
                  : 'text-primary-600 border-b-2 border-primary-500 pb-1'
                : isHome
                  ? 'text-white/80 hover:text-white header-nav-link'
                  : 'text-gray-600 hover:text-primary-600',
            ]}
          >
            Admin
          </a>
        )}
      </div>

      <!-- Auth Actions -->
      <div class="hidden md:flex items-center gap-3">
        {user ? (
          <div class="relative" id="profile-dropdown-container">
            <button
              id="profile-dropdown-btn"
              class="flex items-center gap-2 cursor-pointer"
              aria-label="Open profile menu"
            >
              <span class:list={[
                "text-sm font-medium transition-colors header-nav-link",
                isHome ? "text-white/80" : "text-gray-700"
              ]}>
                {user.name}
              </span>
              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 text-sm font-semibold">
                {user.name?.charAt(0).toUpperCase() || 'U'}
              </div>
            </button>
            <div id="profile-dropdown" class="hidden absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-2 z-50">
              {user.role === 'user' && (
                <a href="/account/settings" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  My Account
                </a>
              )}
              {(user.role === 'agency' || user.role === 'admin') && (
                <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                  Dashboard
                </a>
              )}
              <a href="/account/settings" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Settings
              </a>
              <a href="/account/favourites" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                Favourites
              </a>
              <hr class="my-1 border-gray-100" />
              <a href="#" id="logout-btn" class="flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                Logout
              </a>
            </div>
          </div>
        ) : (
          <>
            <a href="/auth/login" class:list={[
              "text-sm font-medium transition-colors",
              isHome ? "text-white/80 hover:text-white header-nav-link" : "text-gray-600 hover:text-primary-600"
            ]}>
              Log in
            </a>
            <a
              href="/auth/register"
              class:list={[
                "px-4 py-2 text-sm font-medium rounded-lg transition-colors border",
                isHome
                  ? "border-white text-white hover:bg-white hover:text-gray-900 header-cta"
                  : "border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white"
              ]}
            >
              List Your Tours
            </a>
          </>
        )}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class:list={["md:hidden p-2", isHome ? "text-white" : "text-gray-600 hover:text-gray-900"]}
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 mt-2 bg-white rounded-b-xl">
      <div class="flex flex-col gap-2 pt-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href
                ? 'bg-primary-50 text-primary-600'
                : 'text-gray-600 hover:bg-gray-50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <hr class="my-2 border-gray-100" />
        {user ? (
          <>
            {user.role === 'user' && (
              <a href="/account/settings" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">My Account</a>
            )}
            {(user.role === 'agency' || user.role === 'admin') && (
              <a href="/dashboard" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Dashboard</a>
            )}
            <a href="/account/settings" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Settings</a>
            <a href="/account/favourites" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Favourites</a>
            <a href="#" class="mobile-logout-btn px-3 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50">Logout</a>
          </>
        ) : (
          <>
            <a href="/auth/login" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50">Log in</a>
            <a href="/auth/register" class="px-3 py-2 rounded-lg text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 text-center">List Your Tours</a>
          </>
        )}
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Profile dropdown toggle
  const dropdownBtn = document.getElementById('profile-dropdown-btn');
  const dropdown = document.getElementById('profile-dropdown');
  dropdownBtn?.addEventListener('click', () => {
    dropdown?.classList.toggle('hidden');
  });
  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const container = document.getElementById('profile-dropdown-container');
    if (container && !container.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
    }
  });

  // Logout handler
  async function handleLogout(e: Event) {
    e.preventDefault();
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  }
  document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
  document.querySelector('.mobile-logout-btn')?.addEventListener('click', handleLogout);

  // Scroll-based transparency toggle for homepage
  const header = document.getElementById('site-header');
  if (header?.classList.contains('bg-transparent')) {
    const logo = header.querySelector('.header-logo') as HTMLElement;
    const navLinks = header.querySelectorAll('.header-nav-link') as NodeListOf<HTMLElement>;
    const navActive = header.querySelector('.header-nav-active') as HTMLElement;
    const cta = header.querySelector('.header-cta') as HTMLElement;
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > 80;

      if (scrolled) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-gray-100');
        if (logo) { logo.classList.remove('text-white'); logo.classList.add('text-primary-700'); }
        navLinks.forEach(l => { l.classList.remove('text-white/80', 'hover:text-white'); l.classList.add('text-gray-600', 'hover:text-primary-600'); });
        if (navActive) { navActive.classList.remove('text-white', 'border-white'); navActive.classList.add('text-primary-600', 'border-primary-500'); }
        if (cta) { cta.classList.remove('border-white', 'text-white', 'hover:bg-white', 'hover:text-gray-900'); cta.classList.add('border-gray-900', 'text-gray-900', 'hover:bg-gray-900', 'hover:text-white'); }
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-gray-100');
        if (logo) { logo.classList.add('text-white'); logo.classList.remove('text-primary-700'); }
        navLinks.forEach(l => { l.classList.add('text-white/80', 'hover:text-white'); l.classList.remove('text-gray-600', 'hover:text-primary-600'); });
        if (navActive) { navActive.classList.add('text-white', 'border-white'); navActive.classList.remove('text-primary-600', 'border-primary-500'); }
        if (cta) { cta.classList.add('border-white', 'text-white', 'hover:bg-white', 'hover:text-gray-900'); cta.classList.remove('border-gray-900', 'text-gray-900', 'hover:bg-gray-900', 'hover:text-white'); }
      }
    });
  }
</script>
