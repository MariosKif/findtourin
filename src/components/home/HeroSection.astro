---
interface Stats {
  tours: number;
  agencies: number;
  countries: number;
}

interface Props {
  stats?: Stats;
  locations?: string[];
}

const {
  stats,
  locations = [
    "Greece", "Bulgaria", "Turkey", "Germany", "Sweden",
    "Scotland", "Italy", "Spain", "France", "Japan",
    "Morocco", "Peru", "Iceland", "Thailand", "Australia",
  ],
} = Astro.props;

const formatStat = (n: number) => {
  if (n >= 100) return `${Math.floor(n / 10) * 10}+`;
  if (n >= 10) return `${n}+`;
  return `${n}`;
};
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden -mt-[72px] pt-[72px] bg-gradient-to-br from-primary-600 via-primary-700 to-primary-900">
  <!-- Hero background image. Fades in once it loads so the pre-image state is
       just the branded gradient above (instead of a near-black 'shadow' that
       fresh visitors see while the JPG downloads on a cold cache). -->
  <img
    src="/images/hero-bg.jpg"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
    fetchpriority="high"
    decoding="async"
    onload="this.classList.remove('opacity-0'); document.getElementById('hero-overlay')?.classList.remove('opacity-0')"
  />
  <!-- Text-contrast overlay. Faded out until the image loads so the pre-image
       state stays clean branded blue (otherwise it stacks dim-on-gradient and
       reads as 'a black shadow over the site' on slow mobile networks). -->
  <div id="hero-overlay" class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/40 opacity-0 transition-opacity duration-500"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <!-- Heading -->
    <h1
      id="hero-title"
      class="font-heading text-5xl md:text-7xl lg:text-8xl font-normal text-white leading-tight mb-6"
    >
      Find Tours in<br />
      <span id="hero-location-wrapper" class="inline-block relative overflow-hidden" style="vertical-align: bottom;">
        {/* Invisible sizer: first item sets the height, widest sets the width */}
        {locations.map((loc, i) => (
          <span class={`block invisible ${i === 0 ? '' : 'h-0'}`} aria-hidden="true">{loc}</span>
        ))}
        {/* Visible animated locations */}
        {locations.map((loc, i) => (
          <span
            class="hero-location absolute inset-x-0 top-0"
            style={`opacity: ${i === 0 ? 1 : 0}; transform: translateY(${i === 0 ? '0%' : '100%'})`}
          >
            {loc}
          </span>
        ))}
      </span>
    </h1>

    <!-- Static tagline -->
    <p class="text-xl md:text-2xl text-white/80 font-light max-w-2xl mx-auto mb-12">
      Curated tours from trusted agencies worldwide
    </p>

    <!-- Single pill search bar -->
    <form
      id="hero-search"
      action="/tours"
      method="get"
      class="relative max-w-xl lg:max-w-2xl mx-auto"
    >
      <div class="flex items-center bg-white rounded-full shadow-2xl h-14 lg:h-16 overflow-hidden">
        <input
          type="text"
          name="to"
          placeholder="Where do you want to go?"
          class="flex-1 h-full px-6 lg:px-8 text-gray-900 placeholder-gray-400 border-0 bg-transparent focus:outline-none text-base lg:text-lg"
        />
        <button
          type="submit"
          class="flex items-center justify-center h-10 w-10 lg:h-12 lg:w-12 mr-2 rounded-full bg-primary-600 hover:bg-primary-700 text-white transition-colors duration-200 shrink-0 cursor-pointer"
          aria-label="Search tours"
        >
          <svg class="h-5 w-5 lg:h-6 lg:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </div>
    </form>
  </div>
</section>

{stats && stats.tours > 0 && (
  <section id="hero-stats" class="bg-gray-50 py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-center items-center divide-x divide-gray-300">
        <div class="text-center px-8 sm:px-12">
          <div class="font-heading text-3xl sm:text-4xl font-normal text-gray-900">{formatStat(stats.tours)}</div>
          <div class="text-gray-500 text-sm mt-1">{stats.tours === 1 ? 'Tour' : 'Tours'}</div>
        </div>
        <div class="text-center px-8 sm:px-12">
          <div class="font-heading text-3xl sm:text-4xl font-normal text-gray-900">{formatStat(stats.agencies)}</div>
          <div class="text-gray-500 text-sm mt-1">{stats.agencies === 1 ? 'Agency' : 'Agencies'}</div>
        </div>
        <div class="text-center px-8 sm:px-12">
          <div class="font-heading text-3xl sm:text-4xl font-normal text-gray-900">{formatStat(stats.countries)}</div>
          <div class="text-gray-500 text-sm mt-1">{stats.countries === 1 ? 'Country' : 'Countries'}</div>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  import gsap from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const locations = document.querySelectorAll(".hero-location");
    if (locations.length === 0) return;

    const tl = gsap.timeline({ repeat: -1 });

    locations.forEach((loc, i) => {
      const next = locations[(i + 1) % locations.length];

      // Hold current location visible
      tl.to(loc, { duration: 2.5 });

      // Slide current out (up + fade)
      tl.to(loc, {
        opacity: 0,
        y: "-100%",
        duration: 0.5,
        ease: "power2.inOut",
      });

      // Slide next in (from below + fade in)
      tl.fromTo(
        next,
        { opacity: 0, y: "100%" },
        { opacity: 1, y: "0%", duration: 0.5, ease: "power2.inOut" },
        "<"
      );
    });
  });
</script>
