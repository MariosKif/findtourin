---
interface Option {
  value: string;
  label: string;
}

interface Props {
  label?: string;
  name: string;
  options: Option[];
  value?: string;
  required?: boolean;
  error?: string;
  class?: string;
  [key: string]: any;
}

const {
  label,
  name,
  options = [],
  value,
  required = false,
  error,
  class: className,
  ...rest
} = Astro.props;

const selectId = `select-${name}`;
---

<div class:list={['flex flex-col gap-1.5', className]}>
  {label && (
    <label for={selectId} class="text-sm font-medium text-gray-700">
      {label}
      {required && <span class="text-red-500 ml-0.5">*</span>}
    </label>
  )}
  <div class="relative">
    <select
      id={selectId}
      name={name}
      required={required}
      class:list={[
        'w-full appearance-none rounded-lg border bg-white px-4 py-2.5 pr-10 text-gray-900 transition-colors duration-200',
        'focus:outline-none focus:ring-2 focus:ring-offset-0',
        error
          ? 'border-red-400 focus:border-red-500 focus:ring-red-200'
          : 'border-gray-300 focus:border-primary-500 focus:ring-primary-200',
      ]}
      {...rest}
    >
      <slot />
      {options.map((opt) => (
        <option value={opt.value} selected={opt.value === value}>
          {opt.label}
        </option>
      ))}
    </select>
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
      <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
  {error && (
    <p class="text-sm text-red-600">{error}</p>
  )}
</div>
