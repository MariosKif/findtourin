---
export const prerender = false;
import PublicLayout from '../../../layouts/PublicLayout.astro';
import FAQSection from '../../../components/common/FAQSection.astro';
import { supabase } from '../../../lib/supabase';
import { TOUR_LIST_SELECT, normalizeTour } from '../../../lib/tour-helpers';
import { getItinerary } from '../../../lib/seo/itineraries';
import { currentYear } from '../../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const { country, duration } = Astro.params;
if (!country || !duration) return new Response('Not found', { status: 404 });

// duration param format: `7-days`, `10-days`. Parse the number; reject
// anything that doesn't match.
const m = duration.match(/^(\d+)-days?$/);
if (!m) return new Response('Not found', { status: 404 });
const days = Number(m[1]);

const itinerary = getItinerary(country, days);
if (!itinerary) return new Response('Not found', { status: 404 });

// Resolve any suggested tour slugs against live tours so we can render
// real cards and filter dead links automatically.
const allSlugs = Array.from(
  new Set(
    itinerary.days_plan.flatMap((d) => d.suggestedTourSlugs || []),
  ),
);
const tourBySlug = new Map<string, any>();
if (allSlugs.length > 0) {
  try {
    const { data: liveTours } = await supabase
      .from('tours')
      .select(TOUR_LIST_SELECT)
      .eq('status', 'active')
      .in('slug', allSlugs);
    for (const t of (liveTours || []) as any[]) {
      if (t.slug) tourBySlug.set(t.slug, normalizeTour(t));
    }
  } catch {
    // DB unavailable — render the itinerary without tour links.
  }
}

const SITE = 'https://www.findtoursin.com';
const canonical = `${SITE}/itineraries/${itinerary.countrySlug}/${itinerary.days}-days`;
const year = currentYear();
const pageTitle = `${itinerary.title} ${year} — Day-by-Day Plan`;
const metaDescription = itinerary.description;
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/itineraries" class="hover:text-primary-600">Itineraries</a>
        <span class="mx-2">/</span>
        <a href={`/tours/in/${itinerary.countrySlug}`} class="hover:text-primary-600">{itinerary.country}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{itinerary.days} days</span>
      </nav>
      <p class="text-xs font-medium text-primary-700 uppercase tracking-wider mb-2">Editorial itinerary · {year}</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        {itinerary.title}
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl">{itinerary.tagline}</p>
      <p class="mt-3 text-sm text-gray-500">
        {itinerary.days} days · Best months: {itinerary.bestMonths} · From €{itinerary.costRange.from} per person · Updated {itinerary.updated}
      </p>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Lead passage (speakable) -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 leading-relaxed" data-speakable="true">{itinerary.intro}</p>
    </section>

    <!-- Day-by-day -->
    <section class="mb-14">
      <h2 class="font-heading text-2xl sm:text-3xl font-normal text-gray-900 mb-8">Day by day</h2>
      <ol class="space-y-8">
        {itinerary.days_plan.map((d) => (
          <li class="grid sm:grid-cols-[3rem_1fr] gap-4 sm:gap-6">
            <div class="text-2xl font-heading text-primary-300 sm:text-right">D{d.day}</div>
            <div>
              <h3 class="font-heading text-xl text-gray-900 mb-1">{d.title}</h3>
              <p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Base: {d.base}</p>
              <p class="text-gray-700 leading-relaxed mb-3">{d.body}</p>
              {d.suggestedTourSlugs && d.suggestedTourSlugs.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {d.suggestedTourSlugs.map((s) => {
                    const t = tourBySlug.get(s);
                    return t ? (
                      <a href={`/tours/${s}`} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-primary-200 bg-white text-primary-700 text-xs font-medium hover:bg-primary-50 transition-colors">
                        Book: {t.name}
                      </a>
                    ) : null;
                  })}
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Cost / timing summary -->
    <section class="mb-14 grid sm:grid-cols-2 gap-4">
      <div class="rounded-2xl border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Cost (land-only)</p>
        <p class="font-heading text-2xl text-gray-900">€{itinerary.costRange.from}–{itinerary.costRange.to} per person</p>
        <p class="mt-2 text-sm text-gray-600">Excludes international flights. Premium fully-guided versions add 50–80% to the upper bound.</p>
      </div>
      <div class="rounded-2xl border border-gray-200 p-6">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Best months</p>
        <p class="font-heading text-2xl text-gray-900">{itinerary.bestMonths}</p>
        <p class="mt-2 text-sm text-gray-600">Avoid peak August unless beach-only; book peak weeks 8–12 weeks ahead.</p>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection faqs={itinerary.faqs} />

    <!-- Cross-link -->
    <section class="mt-14 p-6 rounded-2xl bg-gray-50 border border-gray-200">
      <h2 class="font-heading text-xl text-gray-900 mb-3">Related</h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        <li><a href={`/tours/in/${itinerary.countrySlug}`} class="text-primary-700 hover:underline">All tours in {itinerary.country} &rarr;</a></li>
        <li><a href="/best" class="text-primary-700 hover:underline">Editorially ranked tours &rarr;</a></li>
        <li><a href="/guide" class="text-primary-700 hover:underline">Tour planning guides &rarr;</a></li>
        <li><a href="/itineraries" class="text-primary-700 hover:underline">Other itineraries &rarr;</a></li>
      </ul>
    </section>
  </article>

  <!-- Trip schema is the right type for itineraries; itinerary is an
       ItemList nested inside it. lastReviewed feeds freshness signals. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Trip",
    "name": itinerary.title,
    "description": itinerary.description,
    "url": canonical,
    "provider": { "@id": `${SITE}/#organization` },
    "inLanguage": "en",
    "subjectOf": canonical,
    "tripOrigin": { "@type": "Country", "name": itinerary.country },
    "itinerary": {
      "@type": "ItemList",
      "numberOfItems": itinerary.days_plan.length,
      "itemListElement": itinerary.days_plan.map((d) => ({
        "@type": "ListItem",
        "position": d.day,
        "name": d.title,
        "description": d.body,
      })),
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["[data-speakable]"],
    },
  })} />

  <!-- Article wrapper for editorial freshness. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "datePublished": itinerary.updated,
    "dateModified": itinerary.updated,
    "lastReviewed": itinerary.updated,
    "author": { "@id": `${SITE}/#organization` },
    "publisher": { "@id": `${SITE}/#organization` },
    "mainEntityOfPage": canonical,
    "inLanguage": "en",
    "about": [{ "@type": "Country", "name": itinerary.country }],
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Itineraries", "item": `${SITE}/itineraries` },
      { "@type": "ListItem", "position": 3, "name": itinerary.country, "item": `${SITE}/tours/in/${itinerary.countrySlug}` },
      { "@type": "ListItem", "position": 4, "name": `${itinerary.days}-day itinerary`, "item": canonical },
    ],
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
