---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import { db } from '../../lib/db';
import { profiles } from '../../lib/db/schema';
import { desc } from 'drizzle-orm';
import { formatDate } from '../../lib/utils';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') return Astro.redirect('/');

const allUsers = await db
  .select({
    id: profiles.id,
    email: profiles.email,
    name: profiles.name,
    role: profiles.role,
    isVerified: profiles.isVerified,
    companyName: profiles.companyName,
    createdAt: profiles.createdAt,
  })
  .from(profiles)
  .orderBy(desc(profiles.createdAt));
---

<DashboardLayout title="Manage Users">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Name</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Email</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Role</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Verified</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Joined</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {allUsers.map((u) => (
            <tr class="hover:bg-gray-50" data-user-id={u.id}>
              <td class="px-4 py-3">
                <div>
                  <p class="font-medium text-gray-900">{u.name}</p>
                  {u.companyName && <p class="text-xs text-gray-500">{u.companyName}</p>}
                </div>
              </td>
              <td class="px-4 py-3 text-gray-600">{u.email}</td>
              <td class="px-4 py-3">
                <select class="role-select text-xs border border-gray-300 rounded px-2 py-1" data-user-id={u.id}>
                  <option value="user" selected={u.role === 'user'}>User</option>
                  <option value="agency" selected={u.role === 'agency'}>Agency</option>
                  <option value="admin" selected={u.role === 'admin'}>Admin</option>
                </select>
              </td>
              <td class="px-4 py-3">
                <Badge variant={u.isVerified ? 'success' : 'neutral'} size="sm">
                  {u.isVerified ? 'Yes' : 'No'}
                </Badge>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs">{formatDate(u.createdAt)}</td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <button class="verify-btn text-xs text-primary-600 hover:underline" data-user-id={u.id} data-verified={String(!u.isVerified)}>
                    {u.isVerified ? 'Unverify' : 'Verify'}
                  </button>
                  <button class="delete-user-btn text-xs text-red-600 hover:underline" data-user-id={u.id}>
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    document.querySelectorAll('.role-select').forEach((select) => {
      select.addEventListener('change', async (e) => {
        const target = e.currentTarget as HTMLSelectElement;
        const userId = target.dataset.userId;
        await fetch(`/api/admin/users/${userId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: target.value }),
        });
      });
    });

    document.querySelectorAll('.verify-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const userId = target.dataset.userId;
        const verified = target.dataset.verified === 'true';
        const res = await fetch(`/api/admin/users/${userId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isVerified: verified }),
        });
        if (res.ok) location.reload();
      });
    });

    document.querySelectorAll('.delete-user-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        if (!confirm('Delete this user? This cannot be undone.')) return;
        const userId = target.dataset.userId;
        const res = await fetch(`/api/admin/users/${userId}`, { method: 'DELETE' });
        if (res.ok) {
          target.closest('tr')?.remove();
        }
      });
    });
  </script>
</DashboardLayout>
