---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import FAQSection from '../../components/common/FAQSection.astro';
import { getGuide, GUIDES } from '../../lib/seo/guides';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });

const guide = getGuide(slug);
if (!guide) return new Response('Not found', { status: 404 });

const SITE = 'https://www.findtoursin.com';
const canonical = `${SITE}/guide/${guide.slug}`;
const pageTitle = guide.title;
const metaDescription = guide.description;

// Word count drives the schema's wordCount property — useful signal for
// helpful-content scoring and reading-time estimation by AI engines.
const fullText = `${guide.keyTakeaway} ${guide.sections.map((s) => `${s.heading} ${s.body}`).join(' ')} ${guide.faqs.map((f) => `${f.q} ${f.a}`).join(' ')}`;
const wordCount = fullText.split(/\s+/).filter(Boolean).length;
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/guide" class="hover:text-primary-600">Guides</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{guide.title}</span>
    </nav>

    <header class="mb-10">
      <p class="text-xs font-medium text-primary-700 uppercase tracking-wider mb-2">FindToursIn guide</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-normal text-gray-900 leading-tight">{guide.title}</h1>
      <p class="mt-4 text-lg text-gray-700">{guide.tagline}</p>
      <p class="mt-3 text-sm text-gray-500">{guide.readingMinutes} min read · Updated {guide.updated}</p>
    </header>

    <!-- Key takeaway box — the part LLMs lift, mark as speakable -->
    <aside class="mb-10 p-5 sm:p-6 rounded-2xl bg-primary-50 border border-primary-100">
      <p class="text-xs font-semibold text-primary-700 uppercase tracking-wider mb-2">Key takeaway</p>
      <p class="text-gray-800 leading-relaxed" data-speakable="true">{guide.keyTakeaway}</p>
    </aside>

    <!-- Body sections -->
    <div class="prose prose-lg max-w-none">
      {guide.sections.map((s) => (
        <section class="mb-10">
          <h2 class="font-heading text-2xl sm:text-3xl font-normal text-gray-900 mb-4">{s.heading}</h2>
          <p class="text-gray-700 leading-relaxed">{s.body}</p>
        </section>
      ))}
    </div>

    <!-- FAQs (Speakable wired by component) -->
    <FAQSection faqs={guide.faqs} />

    <!-- Related guides -->
    {guide.related.length > 0 && (
      <section class="mt-14 p-6 sm:p-8 rounded-2xl bg-gray-50 border border-gray-200">
        <h2 class="font-heading text-xl text-gray-900 mb-4">Related</h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {guide.related.map((r) => (
            <li>
              <a href={r.href} class="inline-flex items-center gap-2 text-primary-700 hover:text-primary-900">
                {r.label} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <!-- Article schema (the standard travel-guide format).
       Headline mirrors title, lastReviewed feeds freshness signals,
       wordCount + Speakable improve AI Overview eligibility. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": guide.title,
    "description": guide.description,
    "url": canonical,
    "datePublished": guide.updated,
    "dateModified": guide.updated,
    "lastReviewed": guide.updated,
    "author": { "@id": `${SITE}/#organization` },
    "publisher": { "@id": `${SITE}/#organization` },
    "mainEntityOfPage": canonical,
    "inLanguage": "en",
    "wordCount": wordCount,
    "articleSection": guide.category,
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["[data-speakable]"],
    },
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Guides", "item": `${SITE}/guide` },
      { "@type": "ListItem", "position": 3, "name": guide.title, "item": canonical },
    ],
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
