---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { GUIDES } from '../../lib/seo/guides';
import { currentYear } from '../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const year = currentYear();
const pageTitle = `Tour planning guides ${year} — FindToursIn`;
const metaDescription = 'Editorial guides for tour planners: how to choose a tour, tour vs self-guided, booking safely, tipping, and best-time-to-visit destination guides.';
const canonical = 'https://www.findtoursin.com/guide';
const SITE = 'https://www.findtoursin.com';

const categoryLabels: Record<string, string> = {
  planning: 'Planning',
  booking: 'Booking',
  safety: 'Safety',
  money: 'Money & tips',
  destination: 'Destinations',
};
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Guides</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Tour planning guides
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl" data-speakable="true">
        {GUIDES.length} editorial guides for travellers comparing tours, choosing operators, and planning trips. No fluff — just the frameworks and numbers we wish someone had given us before our first booking.
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-6 sm:grid-cols-2">
      {GUIDES.map((g) => (
        <a href={`/guide/${g.slug}`} class="group rounded-2xl border border-gray-200 p-6 hover:border-primary-400 hover:shadow-md transition-all">
          <p class="text-xs font-medium text-primary-700 uppercase tracking-wider mb-2">{categoryLabels[g.category] || g.category}</p>
          <h2 class="font-heading text-xl text-gray-900 mb-2 group-hover:text-primary-700">{g.title}</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">{g.tagline}</p>
          <p class="text-xs text-gray-500">{g.readingMinutes} min read · Updated {g.updated}</p>
        </a>
      ))}
    </div>

    <!-- Cross-link to glossary -->
    <section class="mt-14 p-6 sm:p-8 rounded-2xl bg-gray-50 border border-gray-200">
      <h2 class="font-heading text-xl text-gray-900 mb-3">Looking up a term?</h2>
      <p class="text-gray-600 mb-5">The glossary defines 50+ tour-industry terms in plain English.</p>
      <a href="/guide/glossary" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-800 transition-colors">Open the glossary &rarr;</a>
    </section>
  </div>

  <!-- CollectionPage + ItemList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "isPartOf": { "@id": `${SITE}/#organization` },
    "publisher": { "@id": `${SITE}/#organization` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": GUIDES.length,
    "itemListElement": GUIDES.map((g, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/guide/${g.slug}`,
      "name": g.title,
    })),
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Guides", "item": canonical },
    ],
  })} />
</PublicLayout>
