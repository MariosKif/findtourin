---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourGallery from '../../components/tours/TourGallery.astro';
import TourInfo from '../../components/tours/TourInfo.astro';
import AgencyContactCard from '../../components/tours/AgencyContactCard.astro';
import { supabase } from '../../lib/supabase';
import { getDemoTourBySlug, DEMO_AGENCY, DEMO_REVIEWS } from '../../lib/demo-tours';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/tours');

let tour: any;
let images: any[] = [];
let agency: any;

try {
  const { data: tourData } = await supabase
    .from('tours')
    .select('*')
    .eq('slug', slug)
    .limit(1)
    .single();
  if (tourData) tour = tourData;
} catch {
  // DB unavailable — fall through to demo lookup
}

if (!tour || tour.status !== 'active') {
  const demoTour = getDemoTourBySlug(slug);
  if (!demoTour) return Astro.redirect('/tours');
  tour = demoTour;
}

// Increment view count (fire-and-forget)
if (tour?.id && !tour.id.startsWith('demo-')) {
  supabase
    .from('tours')
    .update({ view_count: (tour.view_count || 0) + 1 })
    .eq('id', tour.id)
    .then(() => {});
}

try {
  images = tour.images || [];
  if (tour.agency_id) {
    const { data: agencyData } = await supabase
      .from('users')
      .select('*')
      .eq('id', tour.agency_id)
      .single();
    agency = agencyData;
  }
} catch {
  // DB unavailable — use demo defaults
}

const reviews = DEMO_REVIEWS[slug] || [];

const tourWithAgency = {
  ...tour,
  agencyName: agency?.company_name || agency?.name || DEMO_AGENCY.companyName,
  agencyVerified: agency?.is_verified || DEMO_AGENCY.isVerified,
  rating: tour.rating,
  review_count: tour.review_count ?? tour.reviewCount,
};
---

<PublicLayout
  title={tour.name}
  description={tour.description?.slice(0, 160)}
  image={images[0]?.url}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:text-primary-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/tours" class="hover:text-primary-600">Tours</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{tour.name}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Main Content -->
      <div class="flex-1">
        <TourGallery images={images.map(img => ({ url: img.url, altText: img.alt_text || img.altText || '' }))} />
        <div class="mt-8">
          <TourInfo tour={tour} reviews={reviews} />
        </div>
      </div>

      <!-- Contact Sidebar -->
      <aside class="w-full lg:w-96 shrink-0">
        <div class="lg:sticky lg:top-24">
          <AgencyContactCard tour={tourWithAgency} />
        </div>
      </aside>
    </div>
  </div>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": tour.name,
    "description": tour.description,
    "url": `https://www.findtoursin.com/tours/${tour.slug}`,
    "touristType": tour.category,
    "image": images.length > 0 ? images.map(img => img.url) : undefined,
    "offers": {
      "@type": "Offer",
      "price": tour.price,
      "priceCurrency": tour.currency,
      "availability": "https://schema.org/InStock",
    },
    "provider": {
      "@type": "TravelAgency",
      "name": tourWithAgency.agencyName,
    },
    "itinerary": {
      "@type": "ItemList",
      "description": `${tour.duration_days || ''} day tour in ${tour.city}, ${tour.country}`,
    },
    "tourBookingPage": `https://www.findtoursin.com/tours/${tour.slug}`,
  })} />

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      { "@type": "ListItem", "position": 3, "name": tour.name, "item": `https://www.findtoursin.com/tours/${tour.slug}` },
    ],
  })} />
</PublicLayout>
