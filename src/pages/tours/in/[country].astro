---
export const prerender = false;
import PublicLayout from '../../../layouts/PublicLayout.astro';
import TourCard from '../../../components/tours/TourCard.astro';
import FAQSection from '../../../components/common/FAQSection.astro';
import { supabase } from '../../../lib/supabase';
import { slugify, getCountryCopy } from '../../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTour } from '../../../lib/tour-helpers';
import { imgUrl, imgSrcset } from '../../../lib/image';
import { getYearStampedTitle, currentYear } from '../../../lib/programmatic';

// Public landing — edge-cache 5 min, stale up to a day.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300, stale-while-revalidate=86400');

const { country: countrySlug } = Astro.params;
if (!countrySlug) return Astro.redirect('/tours');

// Pull all active tours, find the canonical country name (DB casing) matching the slug.
const { data: allTours } = await supabase
  .from('tours')
  .select(TOUR_LIST_SELECT)
  .eq('status', 'active');

const tours = (allTours || []).filter((t: any) => t.country && slugify(t.country) === countrySlug);

if (tours.length === 0) {
  return Astro.redirect('/tours');
}

const countryName = tours[0].country as string;
const copy = getCountryCopy(countryName);

// Other-country cross-links. Helps users compare and pushes link equity
// across the country hubs. Only countries with ≥2 tours qualify (matches
// the sitemap gate).
const otherCountriesMap = new Map<string, number>();
for (const t of allTours || []) {
  if (t.country && slugify(t.country) !== countrySlug) {
    otherCountriesMap.set(t.country, (otherCountriesMap.get(t.country) || 0) + 1);
  }
}
const otherCountries = Array.from(otherCountriesMap.entries())
  .filter(([, count]) => count >= 2)
  .map(([name, count]) => ({ name, slug: slugify(name), count }))
  .sort((a, b) => b.count - a.count);

// Group by city for secondary navigation
const cityMap = new Map<string, { count: number; sampleImage: string | null }>();
const categoryMap = new Map<string, number>();
for (const t of tours) {
  if (t.city) {
    const existing = cityMap.get(t.city) || { count: 0, sampleImage: null };
    existing.count += 1;
    if (!existing.sampleImage && t.images?.[0]?.url) existing.sampleImage = t.images[0].url;
    cityMap.set(t.city, existing);
  }
  if (t.category) categoryMap.set(t.category, (categoryMap.get(t.category) || 0) + 1);
}
const cities = Array.from(cityMap.entries())
  .map(([city, info]) => ({ city, ...info }))
  .sort((a, b) => b.count - a.count);
const categories = Array.from(categoryMap.entries())
  .map(([category, count]) => ({ category, count }))
  .sort((a, b) => b.count - a.count);

const tourCount = tours.length;
const INDEX_MIN_TOURS = 3;
const noIndex = tourCount < INDEX_MIN_TOURS;
const priceFrom = Math.min(...tours.map((t: any) => Number(t.price) || Infinity).filter((n: number) => isFinite(n)));
const priceMax = Math.max(...tours.map((t: any) => Number(t.price) || 0));
const priceRange = isFinite(priceFrom) && priceMax > 0
  ? (priceFrom === priceMax ? `€${priceFrom}` : `€${priceFrom}-€${priceMax}`)
  : null;

const toursGridData = tours
  .sort((a: any, b: any) => (b.view_count || 0) - (a.view_count || 0))
  .slice(0, 24)
  .map(normalizeTour);

const year = currentYear();
const pageTitle = getYearStampedTitle('country-hub', { country: countryName, tourCount, priceFrom });
const metaDescription = `Browse ${tourCount} tours in ${countryName} ${year} from trusted local agencies. ${copy.tagline}. Compare itineraries, durations, and prices — contact agencies directly.`;
const canonical = `https://www.findtoursin.com/tours/in/${countrySlug}`;

// FAQ for schema + visible section
const faqs = [
  {
    q: `How much do tours in ${countryName} cost?`,
    a: `Tours in ${countryName} listed on FindToursIn start from €${priceFrom}. Prices vary by duration, group size, and included activities. ${tourCount} options are currently available.`,
  },
  {
    q: `When is the best time to visit ${countryName}?`,
    a: copy.whenToVisit,
  },
  {
    q: `How do I book a tour in ${countryName}?`,
    a: `FindToursIn is a directory — you contact the agency directly using the email, phone, or website shown on each tour page. We charge no booking fee or commission.`,
  },
  ...(copy.mustSee.length > 0 ? [{
    q: `What are the must-see places in ${countryName}?`,
    a: `Top places include: ${copy.mustSee.join(', ')}. Many are covered by tours listed on FindToursIn.`,
  }] : []),
];
---

<PublicLayout title={pageTitle} description={metaDescription} image={copy.heroImage} noIndex={noIndex}>
  <!-- Hero -->
  <section class="relative h-[340px] sm:h-[420px] overflow-hidden">
    <img
      src={imgUrl(copy.heroImage, 1280)}
      srcset={imgSrcset(copy.heroImage, [640, 960, 1280, 1920])}
      sizes="100vw"
      alt={`Tours in ${countryName}`}
      width="1280"
      height="420"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/30 to-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-end py-10">
      <nav class="text-sm text-white/80 mb-3">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/tours" class="hover:text-white">Tours</a>
        <span class="mx-2">/</span>
        <span class="text-white">{countryName}</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-white leading-tight">
        Tours in {countryName} {year}
      </h1>
      <p class="mt-3 text-lg sm:text-xl text-white/90 max-w-2xl">{copy.tagline}</p>
      <p class="mt-2 text-sm text-white/80">{tourCount} {tourCount === 1 ? 'tour' : 'tours'} from €{priceFrom} · {cities.length} {cities.length === 1 ? 'city' : 'cities'}</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Intro copy -->
    <section class="max-w-3xl mb-12">
      <p class="text-lg text-gray-700 leading-relaxed">{copy.intro}</p>
      {copy.mustSee.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {copy.mustSee.map((m) => (
            <span class="inline-block px-3 py-1.5 rounded-full bg-primary-50 text-primary-700 text-sm font-medium">{m}</span>
          ))}
        </div>
      )}
    </section>

    <!-- Cities in this country -->
    {cities.length > 1 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Cities in {countryName}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {cities.map((c) => (
            <a
              href={`/tours/in/${countrySlug}/${slugify(c.city)}`}
              class="group relative aspect-[4/3] rounded-xl overflow-hidden bg-gray-100"
            >
              {c.sampleImage ? (
                <img
                  src={imgUrl(c.sampleImage, 480)}
                  srcset={imgSrcset(c.sampleImage, [320, 480, 640])}
                  sizes="(max-width: 640px) 50vw, 25vw"
                  alt={c.city}
                  width="480"
                  height="360"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-primary-400 to-primary-700"></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
              <div class="absolute bottom-3 left-4">
                <h3 class="text-white font-semibold text-lg leading-tight">{c.city}</h3>
                <p class="text-white/80 text-xs">{c.count} {c.count === 1 ? 'tour' : 'tours'}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Categories -->
    {categories.length > 1 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Browse by category</h2>
        <div class="flex flex-wrap gap-2">
          {categories.map((c) => (
            <a
              href={`/tours/category/${slugify(c.category)}/in/${countrySlug}`}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 hover:bg-primary-50 transition-colors"
            >
              {c.category}
              <span class="text-xs text-gray-400">{c.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- All tours grid -->
    <section class="mb-12">
      <div class="flex items-end justify-between mb-6">
        <h2 class="font-heading text-2xl font-normal text-gray-900">All tours in {countryName}</h2>
        <a href={`/tours?country=${encodeURIComponent(countryName)}`} class="text-sm text-primary-600 hover:underline">View all {tourCount} &rarr;</a>
      </div>
      {toursGridData.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
          {toursGridData.map((t: any, index: number) => (
            <TourCard tour={t} index={index} />
          ))}
        </div>
      ) : (
        <p class="text-gray-500">No tours listed yet.</p>
      )}
    </section>

    <!-- Other countries — cross-link surface for travellers comparing
         destinations and for site-wide PageRank distribution. -->
    {otherCountries.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">Other destinations</h2>
        <div class="flex flex-wrap gap-3">
          {otherCountries.map((c) => (
            <a href={`/tours/in/${c.slug}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
              Tours in {c.name}
              <span class="text-xs text-gray-400">{c.count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- FAQ (visible + FAQPage JSON-LD with Speakable) -->
    <FAQSection faqs={faqs} />
  </div>

  <!-- Structured data: TouristDestination -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": countryName,
    "description": copy.intro,
    "url": canonical,
    "image": copy.heroImage,
    "touristType": categories.map(c => c.category),
  })} />

  <!-- Place / geo for the destination -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Place",
    "name": countryName,
    "address": { "@type": "PostalAddress", "addressCountry": countryName },
    ...(priceRange ? { "priceRange": priceRange } : {}),
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      { "@type": "ListItem", "position": 3, "name": countryName, "item": canonical },
    ],
  })} />

  <!-- ItemList of tours -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": tourCount,
    "itemListElement": toursGridData.slice(0, 10).map((t: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://www.findtoursin.com/tours/${t.slug}`,
      "name": t.name,
    })),
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}
</PublicLayout>
