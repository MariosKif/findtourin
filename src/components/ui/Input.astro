---
interface Props {
  label?: string;
  name: string;
  type?: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url';
  placeholder?: string;
  value?: string | number;
  required?: boolean;
  error?: string;
  class?: string;
  [key: string]: any;
}

const {
  label,
  name,
  type = 'text',
  placeholder,
  value,
  required = false,
  error,
  class: className,
  ...rest
} = Astro.props;

const inputId = `input-${name}`;
---

<div class:list={['flex flex-col gap-1.5', className]}>
  {label && (
    <label for={inputId} class="text-sm font-medium text-gray-700">
      {label}
      {required && <span class="text-red-500 ml-0.5">*</span>}
    </label>
  )}
  <input
    id={inputId}
    name={name}
    type={type}
    placeholder={placeholder}
    value={value}
    required={required}
    class:list={[
      'w-full rounded-lg border px-4 py-2.5 text-gray-900 placeholder-gray-400 transition-colors duration-200',
      'focus:outline-none focus:ring-2 focus:ring-offset-0',
      error
        ? 'border-red-400 focus:border-red-500 focus:ring-red-200'
        : 'border-gray-300 focus:border-primary-500 focus:ring-primary-200',
    ]}
    {...rest}
  />
  {error && (
    <p class="text-sm text-red-600">{error}</p>
  )}
</div>
