---
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ListingsTable from '../../../components/dashboard/ListingsTable.astro';
import Button from '../../../components/ui/Button.astro';
import { supabase } from '../../../lib/supabase';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const { data } = await supabase
  .from('tours')
  .select('*')
  .eq('agency_id', user.id)
  .order('created_at', { ascending: false });

const userTours = data || [];
---

<DashboardLayout title="My Listings">
  <div class="flex items-center justify-between mb-6">
    <p class="text-gray-600">{userTours.length} tour{userTours.length !== 1 ? 's' : ''} total</p>
    <Button href="/dashboard/tours/new" variant="primary">+ Add New Tour</Button>
  </div>

  <ListingsTable tours={userTours} />
</DashboardLayout>
