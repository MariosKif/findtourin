---
interface Props {
  tour: {
    name: string;
    description: string;
    category: string;
    status: string;
    country: string;
    city: string;
    departure_country?: string | null;
    departure_city?: string | null;
    price: string;
    currency: string;
    duration_days?: number | null;
    max_participants?: number | null;
    start_date?: string | null;
    end_date?: string | null;
  };
  reviews?: { name: string; rating: number; text: string; date: string }[];
}

const { tour, reviews } = Astro.props;

const currencySymbols: Record<string, string> = {
  EUR: '\u20AC',
  USD: '$',
  GBP: '\u00A3',
};
const symbol = currencySymbols[tour.currency] || tour.currency;

const statusColors: Record<string, string> = {
  active: 'bg-green-100 text-green-700',
  pending_payment: 'bg-yellow-100 text-yellow-700',
  draft: 'bg-gray-100 text-gray-600',
  inactive: 'bg-red-100 text-red-700',
};
const statusLabel: Record<string, string> = {
  active: 'Active',
  pending_payment: 'Pending Payment',
  draft: 'Draft',
  inactive: 'Inactive',
};

function formatDate(date: string | null | undefined): string {
  if (!date) return 'TBD';
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function formatReviewDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<div class="space-y-8">
  {/* Header */}
  <div>
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-primary-100 px-3 py-1 text-sm font-semibold text-primary-700">
        {tour.category}
      </span>
      <span class:list={[
        'rounded-full px-3 py-1 text-sm font-semibold',
        statusColors[tour.status] || 'bg-gray-100 text-gray-600',
      ]}>
        {statusLabel[tour.status] || tour.status}
      </span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 md:text-4xl">{tour.name}</h1>
  </div>

  {/* Description */}
  <div>
    <h2 class="mb-3 text-xl font-semibold text-gray-900">About This Tour</h2>
    <div class="prose prose-gray max-w-none leading-relaxed text-gray-600">
      {tour.description.split('\n').map((paragraph) =>
        paragraph.trim() ? <p>{paragraph}</p> : null
      )}
    </div>
  </div>

  {/* Details Grid */}
  <div>
    <h2 class="mb-4 text-xl font-semibold text-gray-900">Tour Details</h2>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
      {/* Duration */}
      <div class="rounded-xl bg-gray-50 p-4">
        <div class="mb-1 text-sm text-gray-500">Duration</div>
        <div class="text-lg font-semibold text-gray-900">
          {tour.duration_days ? `${tour.duration_days} ${tour.duration_days === 1 ? 'day' : 'days'}` : 'TBD'}
        </div>
      </div>

      {/* Max Participants */}
      <div class="rounded-xl bg-gray-50 p-4">
        <div class="mb-1 text-sm text-gray-500">Max Participants</div>
        <div class="text-lg font-semibold text-gray-900">
          {tour.max_participants || 'Unlimited'}
        </div>
      </div>

      {/* Price */}
      <div class="rounded-xl bg-gray-50 p-4">
        <div class="mb-1 text-sm text-gray-500">Price</div>
        <div class="text-lg font-bold text-secondary-600">
          {symbol}{Number(tour.price).toLocaleString()}
        </div>
      </div>

      {/* Start Date */}
      <div class="rounded-xl bg-gray-50 p-4">
        <div class="mb-1 text-sm text-gray-500">Start Date</div>
        <div class="text-lg font-semibold text-gray-900">{formatDate(tour.start_date)}</div>
      </div>

      {/* End Date */}
      <div class="rounded-xl bg-gray-50 p-4">
        <div class="mb-1 text-sm text-gray-500">End Date</div>
        <div class="text-lg font-semibold text-gray-900">{formatDate(tour.end_date)}</div>
      </div>
    </div>
  </div>

  {/* Location */}
  <div>
    <h2 class="mb-4 text-xl font-semibold text-gray-900">Location</h2>
    <div class="space-y-3">
      {(tour.departure_city || tour.departure_country) && (
        <div class="flex items-start gap-3 rounded-xl bg-gray-50 p-4">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19V5m0 0l-4 4m4-4l4 4" />
          </svg>
          <div>
            <div class="text-xs font-medium uppercase tracking-wide text-gray-400 mb-0.5">Departure</div>
            <div class="font-semibold text-gray-900">{[tour.departure_city, tour.departure_country].filter(Boolean).join(', ')}</div>
          </div>
        </div>
      )}
      <div class="flex items-start gap-3 rounded-xl bg-gray-50 p-4">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div>
          <div class="text-xs font-medium uppercase tracking-wide text-gray-400 mb-0.5">Destination</div>
          <div class="font-semibold text-gray-900">{tour.city}</div>
          <div class="text-gray-500">{tour.country}</div>
        </div>
      </div>
    </div>
  </div>

  {/* Reviews */}
  {reviews && reviews.length > 0 && (
    <div>
      <h2 class="mb-4 text-xl font-semibold text-gray-900">Reviews</h2>
      <div class="space-y-4">
        {reviews.map((review) => (
          <div class="rounded-xl bg-gray-50 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100 text-primary-600 font-semibold text-sm">
                {review.name.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-gray-900">{review.name}</div>
                <div class="flex items-center gap-0.5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      class:list={[
                        'h-3.5 w-3.5',
                        i < review.rating ? 'text-amber-400' : 'text-gray-200',
                      ]}
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed">{review.text}</p>
            <div class="mt-2 text-xs text-gray-400">{formatReviewDate(review.date)}</div>
          </div>
        ))}
      </div>
    </div>
  )}
</div>
