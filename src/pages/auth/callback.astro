---
export const prerender = false;
---

<html>
<head><title>Authenticating...</title><meta name="robots" content="noindex, nofollow"></head>
<body>
  <p>Authenticating, please wait...</p>
  <div id="supabase-config" class="hidden"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-anon-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
  ></div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const configEl = document.getElementById('supabase-config') as HTMLDivElement;
    const supabase = createClient(configEl.dataset.url!, configEl.dataset.anonKey!);

    async function handleCallback() {
      try {
        // Supabase OAuth returns tokens in the URL hash
        const { data: { session }, error } = await supabase.auth.getSession();

        if (error || !session) {
          // Try to exchange the code from URL params
          const params = new URLSearchParams(window.location.search);
          const code = params.get('code');

          if (code) {
            const { data, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
            if (exchangeError || !data.session) {
              window.location.href = '/auth/login?error=callback_failed';
              return;
            }

            // Send tokens to server to set cookies
            const res = await fetch('/api/auth/google', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: data.session.access_token,
                refresh_token: data.session.refresh_token,
              }),
            });

            const result = await res.json();
            if (result.needsProfile) {
              window.location.href = '/auth/complete-profile';
            } else if (result.role === 'agency' || result.role === 'admin') {
              window.location.href = '/dashboard';
            } else {
              window.location.href = '/';
            }
            return;
          }

          window.location.href = '/auth/login?error=no_session';
          return;
        }

        // Session exists from hash fragment
        const res = await fetch('/api/auth/google', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_token: session.access_token,
            refresh_token: session.refresh_token,
          }),
        });

        const result = await res.json();
        if (result.needsProfile) {
          window.location.href = '/auth/complete-profile';
        } else if (result.role === 'agency' || result.role === 'admin') {
          window.location.href = '/dashboard';
        } else {
          window.location.href = '/';
        }
      } catch {
        window.location.href = '/auth/login?error=callback_failed';
      }
    }

    handleCallback();
  </script>
</body>
</html>
