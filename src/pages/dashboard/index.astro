---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatsCards from '../../components/dashboard/StatsCards.astro';
import ListingsTable from '../../components/dashboard/ListingsTable.astro';
import Badge from '../../components/ui/Badge.astro';
import { supabase } from '../../lib/supabase';
import { formatPrice, formatDate } from '../../lib/utils';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/auth/login');
}

const { data: allUserTours } = await supabase
  .from('tours')
  .select('*')
  .eq('agency_id', user.id);

const tours = allUserTours || [];
const totalListings = tours.length;
const activeListings = tours.filter(t => t.status === 'active').length;
const pendingPayment = tours.filter(t => t.status === 'pending_payment').length;

const { data: paymentsData } = await supabase
  .from('payments')
  .select('amount')
  .eq('agency_id', user.id)
  .eq('status', 'completed');

const totalSpent = (paymentsData || []).reduce((sum, p) => sum + (p.amount || 0), 0);

const recentTours = [...tours]
  .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())
  .slice(0, 5);

const stats = [
  { label: 'Total Listings', value: totalListings, icon: 'listings' },
  { label: 'Active Listings', value: activeListings, icon: 'active' },
  { label: 'Pending Payment', value: pendingPayment, icon: 'pending' },
  { label: 'Total Spent', value: formatPrice(totalSpent / 100), icon: 'money' },
];
---

<DashboardLayout title="Dashboard">
  <div class="space-y-8">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">Welcome back, {user.name}</h2>
      <p class="mt-1 text-sm text-gray-500">Here's an overview of your tour listings.</p>
    </div>

    <StatsCards stats={stats} />

    <div>
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900">Recent Listings</h3>
        <a href="/dashboard/tours" class="text-sm font-medium text-primary-600 hover:text-primary-700">
          View all &rarr;
        </a>
      </div>
      <ListingsTable tours={recentTours} />
    </div>
  </div>
</DashboardLayout>
