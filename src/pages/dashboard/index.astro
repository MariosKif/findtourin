---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatsCards from '../../components/dashboard/StatsCards.astro';
import ListingsTable from '../../components/dashboard/ListingsTable.astro';
import Badge from '../../components/ui/Badge.astro';
import { toursCol, paymentsCol } from '../../lib/firestore';
import { formatPrice, formatDate } from '../../lib/utils';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/auth/login');
}

// Fetch all user's tours and count by status in JS
const toursSnapshot = await toursCol().where('agencyId', '==', user.id).get();
const allUserTours = toursSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));

const totalListings = allUserTours.length;
const activeListings = allUserTours.filter(t => t.status === 'active').length;
const pendingPayment = allUserTours.filter(t => t.status === 'pending_payment').length;

// Total spent
const paymentsSnapshot = await paymentsCol().where('agencyId', '==', user.id).where('status', '==', 'completed').get();
const totalSpent = paymentsSnapshot.docs.reduce((sum, doc) => sum + (doc.data().amount || 0), 0);

// Recent listings (sort in JS, take 5)
const recentTours = allUserTours
  .sort((a, b) => {
    const aTime = a.createdAt?.toMillis?.() || 0;
    const bTime = b.createdAt?.toMillis?.() || 0;
    return bTime - aTime;
  })
  .slice(0, 5);

const stats = [
  { label: 'Total Listings', value: totalListings, icon: 'listings' },
  { label: 'Active Listings', value: activeListings, icon: 'active' },
  { label: 'Pending Payment', value: pendingPayment, icon: 'pending' },
  { label: 'Total Spent', value: formatPrice(totalSpent / 100), icon: 'money' },
];
---

<DashboardLayout title="Dashboard">
  <div class="space-y-8">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">Welcome back, {user.name}</h2>
      <p class="mt-1 text-sm text-gray-500">Here's an overview of your tour listings.</p>
    </div>

    <StatsCards stats={stats} />

    <div>
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900">Recent Listings</h3>
        <a href="/dashboard/tours" class="text-sm font-medium text-primary-600 hover:text-primary-700">
          View all &rarr;
        </a>
      </div>
      <ListingsTable tours={recentTours} />
    </div>
  </div>
</DashboardLayout>
