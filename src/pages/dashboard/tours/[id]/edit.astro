---
export const prerender = false;
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import TourForm from '../../../../components/tours/TourForm.astro';
import ImageUpload from '../../../../components/ui/ImageUpload.astro';
import { supabase } from '../../../../lib/supabase';
import { getActivePlanForUser } from '../../../../lib/subscriptions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const { id } = Astro.params;
if (!id) return Astro.redirect('/dashboard/tours');

const tourId = id;
const { data: tour } = await supabase
  .from('tours')
  .select('*')
  .eq('id', tourId)
  .single();

if (!tour) return Astro.redirect('/dashboard/tours');
if (tour.agency_id !== user.id && user.role !== 'admin') return Astro.redirect('/dashboard/tours');

const { plan } = await getActivePlanForUser(tour.agency_id);
const maxImages = plan.maxImagesPerTour;

const isJustCreated = Astro.url.searchParams.get('new') === '1';

// Images are stored in the tour document
const images = (tour.images || []).map((img: any, index: number) => ({
  ...img,
  id: `${tourId}_${index}`,
  tourId: tourId,
  position: img.position ?? index,
}));
---

<DashboardLayout title={`Edit: ${tour.name}`}>
  <div class="max-w-4xl space-y-8">
    {isJustCreated && (
      <div class="rounded-xl bg-green-50 border border-green-200 p-4 text-sm text-green-800 flex items-start gap-3">
        <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="font-semibold">Tour created. Now add up to {maxImages} images below.</p>
          <p class="text-xs text-green-700 mt-1">Your listing will go live after you complete the listing-fee payment.</p>
        </div>
      </div>
    )}

    <TourForm tour={tour} />

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Tour Images</h2>
      <p class="text-sm text-gray-600 mb-4">Upload up to {maxImages} images. The first image will be used as the thumbnail.</p>
      <ImageUpload tourId={id} maxImages={maxImages} />

      {images.length > 0 && (
        <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
          {images.map((img) => (
            <div class="relative group rounded-lg overflow-hidden aspect-square">
              <img src={img.url} alt={img.alt_text || 'Tour image'} class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <button
                  data-image-id={img.id}
                  data-tour-id={id}
                  class="delete-image-btn px-3 py-1.5 bg-red-500 text-white text-xs font-medium rounded-lg hover:bg-red-600"
                >
                  Delete
                </button>
              </div>
              <span class="absolute top-1 left-1 bg-black/60 text-white text-xs px-2 py-0.5 rounded">#{img.position + 1}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <script>
    document.querySelectorAll('.delete-image-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const imageId = target.dataset.imageId;
        const tourId = target.dataset.tourId;
        if (!confirm('Delete this image?')) return;

        const res = await fetch(`/api/tours/${tourId}/images`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ imageId }),
        });

        if (res.ok) {
          target.closest('.relative')?.remove();
        }
      });
    });
  </script>
</DashboardLayout>
