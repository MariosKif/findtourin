---
import Input from '../ui/Input.astro';
import Select from '../ui/Select.astro';
import Button from '../ui/Button.astro';

const roleOptions = [
  { value: 'user', label: 'User' },
  { value: 'agency', label: 'Agency' },
];
---

<form id="register-form" class="space-y-5">
  <div id="register-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700"></div>

  <Input
    label="Full Name"
    name="name"
    type="text"
    placeholder="John Doe"
    required
  />

  <Input
    label="Email"
    name="email"
    type="email"
    placeholder="you@example.com"
    required
  />

  <Input
    label="Password"
    name="password"
    type="password"
    placeholder="At least 8 characters"
    required
    minlength="8"
  />

  <Input
    label="Confirm Password"
    name="confirmPassword"
    type="password"
    placeholder="Repeat your password"
    required
    minlength="8"
  />

  <Select
    label="Account Type"
    name="role"
    options={roleOptions}
    value="user"
    required
  />

  <div id="agency-fields" class="hidden space-y-5">
    <Input
      label="Company Name"
      name="companyName"
      type="text"
      placeholder="Your company name"
    />

    <Input
      label="Phone"
      name="phone"
      type="tel"
      placeholder="+1 (555) 000-0000"
    />

    <Input
      label="Website"
      name="website"
      type="url"
      placeholder="https://yourcompany.com"
    />
  </div>

  <Button type="submit" variant="primary" size="lg" class="w-full">
    Create Account
  </Button>

</form>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('register-error') as HTMLDivElement;
  const roleSelect = form.querySelector('select[name="role"]') as HTMLSelectElement;
  const agencyFields = document.getElementById('agency-fields') as HTMLDivElement;

  function showError(message: string) {
    errorDiv.textContent = message;
    errorDiv.classList.remove('hidden');
  }

  function redirectAfterLogin(data: { role?: string }) {
    if (data.role === 'agency' || data.role === 'admin') {
      window.location.href = '/dashboard';
    } else {
      window.location.href = '/';
    }
  }

  roleSelect.addEventListener('change', () => {
    if (roleSelect.value === 'agency') {
      agencyFields.classList.remove('hidden');
    } else {
      agencyFields.classList.add('hidden');
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    errorDiv.textContent = '';

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;
    const role = formData.get('role') as string;

    if (password !== confirmPassword) {
      showError('Passwords do not match.');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating account...';

    try {
      const body: Record<string, string> = { name, email, password, role };

      if (role === 'agency') {
        const companyName = formData.get('companyName') as string;
        const phone = formData.get('phone') as string;
        const website = formData.get('website') as string;
        if (companyName) body.companyName = companyName;
        if (phone) body.phone = phone;
        if (website) body.website = website;
      }

      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (!res.ok) {
        showError(data?.error || 'Registration failed. Please try again.');
        return;
      }

      redirectAfterLogin(data);
    } catch {
      showError('Something went wrong. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
