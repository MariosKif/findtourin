---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TourGallery from '../../components/tours/TourGallery.astro';
import TourInfo from '../../components/tours/TourInfo.astro';
import AgencyContactCard from '../../components/tours/AgencyContactCard.astro';
import TourCard from '../../components/tours/TourCard.astro';
import FAQSection from '../../components/common/FAQSection.astro';
import { supabase } from '../../lib/supabase';
import { getDemoTourBySlug, DEMO_REVIEWS } from '../../lib/demo-tours';
import { slugify, getCityIntentCopy, getDayTripCopy } from '../../lib/destinations';
import { TOUR_LIST_SELECT, normalizeTour } from '../../lib/tour-helpers';
import { getVerifiedReviewsForTour, ratingSchemaFragment } from '../../lib/reviews';
import { INTENT_SLUGS, tourMatchesIntent, MIN_TOURS_FOR_INDEX, humanIntent } from '../../lib/programmatic';

// Public tour detail — edge-cache 2 min (shorter; tour content can change),
// stale up to a day while revalidating in background.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=120, stale-while-revalidate=86400');

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/tours');

let tour: any;
let images: any[] = [];
let agency: any;
let relatedTours: any[] = [];

try {
  const { data: tourData } = await supabase
    .from('tours')
    .select('*')
    .eq('slug', slug)
    .limit(1)
    .single();
  if (tourData) tour = tourData;
} catch {
  // DB unavailable — fall through to demo lookup
}

if (!tour || tour.status !== 'active') {
  const demoTour = getDemoTourBySlug(slug);
  if (!demoTour) return Astro.redirect('/tours');
  tour = demoTour;
}

// Increment view count (fire-and-forget)
if (tour?.id && !tour.id.startsWith('demo-')) {
  supabase
    .from('tours')
    .update({ view_count: (tour.view_count || 0) + 1 })
    .eq('id', tour.id)
    .then(() => {});
}

try {
  images = tour.images || [];
  if (tour.agency_id) {
    const { data: agencyData } = await supabase
      .from('users')
      .select('*')
      .eq('id', tour.agency_id)
      .single();
    agency = agencyData;
  }

  if (tour.country) {
    const { data: candidates } = await supabase
      .from('tours')
      .select(TOUR_LIST_SELECT)
      .eq('status', 'active')
      .eq('country', tour.country)
      .neq('slug', slug)
      .limit(20);
    if (candidates) {
      const scored = candidates
        .map((c: any) => ({
          t: c,
          score: (c.category === tour.category ? 2 : 0) + (c.city === tour.city ? 1 : 0),
        }))
        .sort((a, b) => b.score - a.score || (b.t.view_count || 0) - (a.t.view_count || 0))
        .slice(0, 4);
      relatedTours = scored.map((s) => normalizeTour(s.t));
    }
  }
} catch {
  // DB unavailable — use demo defaults
}

const reviews = DEMO_REVIEWS[slug] || [];

// Verified reviews from Supabase. Returns null today (table not provisioned)
// and lights up rich-snippet AggregateRating + Review schema automatically
// when ≥3 verified rows land. Synthetic reviews are NOT used — they're a
// manual-action trigger.
const verifiedReviewBundle = tour?.id && !String(tour.id).startsWith('demo-')
  ? await getVerifiedReviewsForTour(supabase, tour.id)
  : null;
const ratingFragment = ratingSchemaFragment(verifiedReviewBundle);

const tourWithAgency = {
  ...tour,
  agencyName: agency?.company_name || agency?.name || null,
  agencyVerified: Boolean(agency?.is_verified),
  rating: tour.rating,
  review_count: tour.review_count ?? tour.reviewCount,
};

// --- FAQ (per-tour, with schema) ---
// Display fallback for tours without a real agency — keeps copy and JSON-LD
// from rendering the literal string "null" via template-literal coercion.
const agencyDisplay = tourWithAgency.agencyName ?? 'the tour operator';
const currency = tour.currency || 'EUR';
const currencySymbol = currency === 'EUR' ? '€' : currency === 'USD' ? '$' : currency === 'GBP' ? '£' : currency;
const durationText = tour.duration_days
  ? `${tour.duration_days} ${tour.duration_days === 1 ? 'day' : 'days'}`
  : 'a custom duration set by the agency';
const faqs = [
  {
    q: `How much does ${tour.name} cost?`,
    a: `${tour.name} starts at ${currencySymbol}${Number(tour.price).toLocaleString()} per person. Contact ${agencyDisplay} directly for group pricing, availability, and any discounts.`,
  },
  {
    q: `How long is this tour?`,
    a: `This tour runs for ${durationText}${tour.city && tour.country ? `, based in ${tour.city}, ${tour.country}` : ''}.`,
  },
  {
    q: `How do I book ${tour.name}?`,
    a: `FindToursIn is a directory — contact ${agencyDisplay} directly using the email, phone, or website shown on this page. There are no booking fees or commissions: you deal straight with the operator.`,
  },
  {
    q: `What's included?`,
    a: `Inclusions vary by itinerary. Reach out to ${agencyDisplay} for the full list of what's covered, optional add-ons, and any gear or preparation recommendations.`,
  },
];

const countrySlug = tour.country ? slugify(tour.country) : null;
const citySlug = tour.city ? slugify(tour.city) : null;

// Compute related internal-link surfaces for the "More to explore" block.
// Same gating as the templated routes themselves — we never link to a page
// that would 404 (intent page without ≥3 tours, day-trip page without
// curated copy, etc.). The query above already pulled all city tours via
// the `relatedTours` candidates list, but for accurate intent counts we
// need the full city slice — fetch a lean count here.
let availableIntents: typeof INTENT_SLUGS[number][] = [];
let dayTripEligible = false;
if (tour.country && tour.city && countrySlug && citySlug) {
  try {
    const { data: cityTours } = await supabase
      .from('tours')
      .select('category, duration_days, price, description, name')
      .eq('status', 'active')
      .eq('country', tour.country)
      .eq('city', tour.city);
    if (cityTours && cityTours.length >= MIN_TOURS_FOR_INDEX) {
      availableIntents = INTENT_SLUGS.filter((intent) => {
        const matches = cityTours.filter((t: any) => tourMatchesIntent(t, intent)).length;
        if (matches < MIN_TOURS_FOR_INDEX) return false;
        return getCityIntentCopy(tour.city, tour.country, intent).curated;
      });
      const dayTripCount = cityTours.filter((t: any) => {
        const d = typeof t.duration_days === 'number' ? t.duration_days : null;
        return d !== null && d <= 1;
      }).length;
      dayTripEligible = dayTripCount >= MIN_TOURS_FOR_INDEX && getDayTripCopy(tour.city).curated;
    }
  } catch {
    // DB unavailable — skip the related-links block silently.
  }
}

// Meta description: 155 chars, cut on the last whole-word boundary so we
// don't ship a description that ends mid-clause ("…connecting the").
function truncateDesc(s: string | null | undefined, max = 155): string {
  if (!s) return '';
  const clean = s.replace(/\s+/g, ' ').trim();
  if (clean.length <= max) return clean;
  const cut = clean.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return cut.slice(0, lastSpace > 0 ? lastSpace : max).replace(/[,;:\-—\s]+$/, '') + '…';
}
const metaDesc = truncateDesc(tour.description);
---

<PublicLayout
  title={tour.name}
  description={metaDesc}
  image={images[0]?.url}
  gaPageData={{
    page_type: 'tour_detail',
    tour_slug: tour.slug,
    tour_name: tour.name,
    tour_country: tour.country,
    tour_city: tour.city,
    tour_category: tour.category,
    tour_price: Number(tour.price) || 0,
    tour_currency: tour.currency || 'EUR',
    agency_id: tour.agency_id || '',
  }}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:text-primary-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/tours" class="hover:text-primary-600">Tours</a>
      {countrySlug && (
        <>
          <span class="mx-2">/</span>
          <a href={`/tours/in/${countrySlug}`} class="hover:text-primary-600">{tour.country}</a>
        </>
      )}
      {countrySlug && citySlug && (
        <>
          <span class="mx-2">/</span>
          <a href={`/tours/in/${countrySlug}/${citySlug}`} class="hover:text-primary-600">{tour.city}</a>
        </>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-900">{tour.name}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Main Content -->
      <div class="flex-1">
        <TourGallery images={images.map(img => ({ url: img.url, altText: img.alt_text || img.altText || '' }))} locale={Astro.currentLocale} />
        <div class="mt-8">
          <TourInfo tour={tour} reviews={reviews} />
        </div>
      </div>

      <!-- Contact Sidebar -->
      <aside class="w-full lg:w-96 shrink-0">
        <div class="lg:sticky lg:top-24">
          <AgencyContactCard tour={tourWithAgency} />
        </div>
      </aside>
    </div>

    <!-- FAQ (visible + FAQPage JSON-LD with Speakable) -->
    <div class="mt-16">
      <FAQSection faqs={faqs} />
    </div>

    <!-- Related tours -->
    {relatedTours.length > 0 && (
      <section class="mt-16">
        <div class="flex items-end justify-between mb-6">
          <h2 class="font-heading text-2xl font-normal text-gray-900">
            More tours in {tour.country}
          </h2>
          {countrySlug && (
            <a href={`/tours/in/${countrySlug}`} class="text-sm text-primary-600 hover:underline">View all &rarr;</a>
          )}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedTours.map((t) => (
            <TourCard tour={t} eagerThreshold={0} />
          ))}
        </div>
      </section>
    )}

    <!-- More to explore — surfaces the city hub, day-trip page, and
         intent variants when they're eligible. Pure internal-linking
         hub-and-spoke; every link points at a page that already passes
         shouldIndex(). -->
    {countrySlug && citySlug && (availableIntents.length > 0 || dayTripEligible) && (
      <section class="mt-16">
        <h2 class="font-heading text-2xl font-normal text-gray-900 mb-6">
          More to explore in {tour.city}
        </h2>
        <div class="flex flex-wrap gap-3">
          <a href={`/tours/in/${countrySlug}/${citySlug}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-primary-200 bg-white text-primary-700 text-sm font-medium hover:bg-primary-50 transition-colors">
            All tours in {tour.city} &rarr;
          </a>
          {dayTripEligible && (
            <a href={`/day-trips-from/${citySlug}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-primary-200 bg-white text-primary-700 text-sm font-medium hover:bg-primary-50 transition-colors">
              Day trips from {tour.city} &rarr;
            </a>
          )}
          {availableIntents.slice(0, 5).map((intent) => (
            <a href={`/tours/in/${countrySlug}/${citySlug}/${intent}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
              {humanIntent(intent)} in {tour.city}
            </a>
          ))}
          <a href={`/tours/in/${countrySlug}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">
            All tours in {tour.country} &rarr;
          </a>
        </div>
      </section>
    )}
  </div>

  {/* JSON-LD: Product + TouristTrip @graph. Product unlocks the price /
      availability rich card in Google SERPs (the strongest card on travel
      queries), while TouristTrip preserves the travel-vertical entity
      signals for AI engines. They share data via @id linking. */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Product",
        "@id": `https://www.findtoursin.com/tours/${tour.slug}#product`,
        "name": tour.name,
        "description": metaDesc || tour.description,
        "image": images.length > 0
          ? images.map((img) => img.url)
          : ["https://www.findtoursin.com/images/hero-bg.jpg"],
        "brand": { "@type": "Brand", "name": tourWithAgency.agencyName || "FindToursIn" },
        "category": tour.category,
        "url": `https://www.findtoursin.com/tours/${tour.slug}`,
        "offers": {
          "@type": "Offer",
          "url": `https://www.findtoursin.com/tours/${tour.slug}`,
          "price": tour.price,
          "priceCurrency": tour.currency || "EUR",
          "availability": "https://schema.org/InStock",
          "validFrom": new Date().toISOString().slice(0, 10),
          "priceValidUntil": new Date(Date.now() + 1000 * 60 * 60 * 24 * 180).toISOString().slice(0, 10),
          ...(tourWithAgency.agencyName ? {
            "seller": {
              "@type": "TravelAgency",
              "name": tourWithAgency.agencyName,
            },
          } : {}),
        },
        // AggregateRating + Review[] only fires when ≥3 verified reviews
        // exist. Empty object spread when reviews aren't ready.
        ...ratingFragment,
      },
      {
        "@type": "TouristTrip",
        "@id": `https://www.findtoursin.com/tours/${tour.slug}#trip`,
        "name": tour.name,
        "description": tour.description,
        "url": `https://www.findtoursin.com/tours/${tour.slug}`,
        "touristType": tour.category,
        ...(tour.duration_days
          ? {
              "itinerary": {
                "@type": "ItemList",
                "numberOfItems": tour.duration_days,
                "description": `${tour.duration_days}-day ${tour.category.toLowerCase()} tour in ${tour.city}, ${tour.country}`,
              },
            }
          : {}),
        ...(tourWithAgency.agencyName
          ? { "provider": { "@type": "TravelAgency", "name": tourWithAgency.agencyName } }
          : {}),
      },
    ],
  })} />

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.findtoursin.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tours", "item": "https://www.findtoursin.com/tours" },
      ...(countrySlug ? [{ "@type": "ListItem", "position": 3, "name": tour.country, "item": `https://www.findtoursin.com/tours/in/${countrySlug}` }] : []),
      ...(countrySlug && citySlug ? [{ "@type": "ListItem", "position": 4, "name": tour.city, "item": `https://www.findtoursin.com/tours/in/${countrySlug}/${citySlug}` }] : []),
      { "@type": "ListItem", "position": countrySlug && citySlug ? 5 : countrySlug ? 4 : 3, "name": tour.name, "item": `https://www.findtoursin.com/tours/${tour.slug}` },
    ],
  })} />

  {/* FAQPage + Speakable schema is emitted by <FAQSection> above. */}

  {/* ImageObject for the hero — only when the tour has a real image.
       Helps Google Images understand the photo as the canonical hero
       and lets it appear in image rich results for queries like
       "[tour name] photo". */}
  {images.length > 0 && images[0]?.url && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ImageObject",
      "contentUrl": images[0].url,
      "url": images[0].url,
      "name": images[0].alt_text || images[0].altText || tour.name,
      "caption": images[0].alt_text || images[0].altText || tour.name,
      "representativeOfPage": true,
      ...(tourWithAgency.agencyName ? {
        "creator": { "@type": "TravelAgency", "name": tourWithAgency.agencyName },
      } : {}),
      "license": `https://www.findtoursin.com/tours/${tour.slug}`,
    })} />
  )}

  {/* VideoObject — only when the DB row carries a video URL. We never
       fabricate one. Surfaces the tour in Google Video search and AI
       Overview video carousels. */}
  {tour.video_url && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": tour.name,
      "description": metaDesc || tour.description,
      "thumbnailUrl": images[0]?.url || "https://www.findtoursin.com/images/hero-bg.jpg",
      "contentUrl": tour.video_url,
      "uploadDate": tour.updated_at ? new Date(tour.updated_at).toISOString().slice(0, 10) : new Date().toISOString().slice(0, 10),
      "publisher": { "@id": "https://www.findtoursin.com/#organization" },
    })} />
  )}
</PublicLayout>
