---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import { supabase } from '../../lib/supabase';
import { formatDate, formatPrice } from '../../lib/utils';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') return Astro.redirect('/');

const { data: toursData } = await supabase
  .from('tours')
  .select('*')
  .order('created_at', { ascending: false });

const toursArray = toursData || [];

// Batch-fetch agency profiles
const agencyIds = [...new Set(toursArray.map(t => t.agency_id).filter(Boolean))];
const agencyMap = new Map<string, any>();

if (agencyIds.length > 0) {
  const { data: agencies } = await supabase
    .from('users')
    .select('*')
    .in('id', agencyIds);

  (agencies || []).forEach(a => agencyMap.set(a.id, a));
}

const allTours = toursArray.map(t => {
  const agency = agencyMap.get(t.agency_id);
  return {
    ...t,
    agencyName: agency?.name || null,
    agencyEmail: agency?.email || null,
  };
});

const statusVariant: Record<string, string> = {
  active: 'success',
  pending_payment: 'warning',
  inactive: 'neutral',
  deleted: 'danger',
};
---

<DashboardLayout title="Manage Listings">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Tour</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Agency</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Status</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Category</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Price</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Created</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {allTours.map((t) => (
            <tr class="hover:bg-gray-50" data-tour-id={t.id}>
              <td class="px-4 py-3">
                <a href={`/tours/${t.slug}`} class="font-medium text-primary-600 hover:underline">{t.name}</a>
                <p class="text-xs text-gray-500">{t.country}</p>
              </td>
              <td class="px-4 py-3 text-gray-600 text-xs">
                <p>{t.agencyName}</p>
                <p class="text-gray-400">{t.agencyEmail}</p>
              </td>
              <td class="px-4 py-3">
                <select class="status-select text-xs border border-gray-300 rounded px-2 py-1" data-tour-id={t.id}>
                  <option value="active" selected={t.status === 'active'}>Active</option>
                  <option value="pending_payment" selected={t.status === 'pending_payment'}>Pending</option>
                  <option value="inactive" selected={t.status === 'inactive'}>Inactive</option>
                  <option value="deleted" selected={t.status === 'deleted'}>Deleted</option>
                </select>
              </td>
              <td class="px-4 py-3 text-gray-600 text-xs">{t.category}</td>
              <td class="px-4 py-3 text-gray-900 font-medium">{formatPrice(Number(t.price), t.currency)}</td>
              <td class="px-4 py-3 text-gray-500 text-xs">{formatDate(t.created_at)}</td>
              <td class="px-4 py-3">
                <button class="delete-tour-btn text-xs text-red-600 hover:underline" data-tour-id={t.id}>
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    document.querySelectorAll('.status-select').forEach((select) => {
      select.addEventListener('change', async (e) => {
        const target = e.currentTarget as HTMLSelectElement;
        const tourId = target.dataset.tourId;
        await fetch(`/api/admin/tours/${tourId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: target.value }),
        });
      });
    });

    document.querySelectorAll('.delete-tour-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        if (!confirm('Permanently delete this tour?')) return;
        const tourId = target.dataset.tourId;
        const res = await fetch(`/api/admin/tours/${tourId}`, { method: 'DELETE' });
        if (res.ok) {
          target.closest('tr')?.remove();
        }
      });
    });
  </script>
</DashboardLayout>
