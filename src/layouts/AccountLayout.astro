---
import PublicLayout from './PublicLayout.astro';
import AccountTabNav from '../components/account/AccountTabNav.astro';
import Toast from '../components/ui/Toast.astro';

interface Props {
  title?: string;
}

const { title = 'My Account' } = Astro.props;
---

<PublicLayout title={title} noIndex={true}>
  <div class="bg-gray-50 min-h-[calc(100vh-4rem)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <h1 class="text-3xl font-bold text-gray-900 font-heading">{title}</h1>
      <p class="mt-1 text-gray-500">Manage your account and preferences</p>

      <div class="mt-6">
        <AccountTabNav />
      </div>

      <div class="mt-8">
        <slot />
      </div>
    </div>
  </div>
  <Toast />
</PublicLayout>
