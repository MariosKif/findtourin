---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import BillingHistory from '../../components/dashboard/BillingHistory.astro';
import { paymentsCol, toursCol } from '../../lib/firestore';
import { formatPrice } from '../../lib/utils';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const paymentsSnapshot = await paymentsCol().where('agencyId', '==', user.id).orderBy('createdAt', 'desc').get();

const userPayments: any[] = [];
for (const doc of paymentsSnapshot.docs) {
  const data = doc.data();
  let tourName = null;
  if (data.tourId) {
    try {
      const tourDoc = await toursCol().doc(data.tourId).get();
      if (tourDoc.exists) {
        tourName = tourDoc.data()?.name || null;
      }
    } catch {}
  }
  userPayments.push({
    id: doc.id,
    amount: data.amount,
    currency: data.currency,
    status: data.status,
    createdAt: data.createdAt?.toDate?.()?.toISOString?.() || data.createdAt,
    tourName,
    tourId: data.tourId,
  });
}

const totalSpent = userPayments
  .filter((p) => p.status === 'completed')
  .reduce((sum, p) => sum + p.amount, 0);
---

<DashboardLayout title="Billing">
  <div class="mb-6 bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-sm text-gray-500">Total Spent</p>
    <p class="text-3xl font-bold text-gray-900">{formatPrice(totalSpent / 100)}</p>
  </div>

  <BillingHistory payments={userPayments} />
</DashboardLayout>
