---
interface Props {
  tour: {
    id: string;
    name: string;
    slug: string;
    description: string;
    country: string;
    city: string;
    departure_country?: string | null;
    departure_city?: string | null;
    price: string;
    currency: string;
    category: string;
    duration_days?: number | null;
    thumbnail: string | null;
    rating?: number;
    review_count?: number;
    view_count?: number;
    favouriteCount?: number;
  };
}

const { tour } = Astro.props;

const currencySymbols: Record<string, string> = {
  EUR: '\u20AC',
  USD: '$',
  GBP: '\u00A3',
};
const symbol = currencySymbols[tour.currency] || tour.currency;

const destinationLabel = `${tour.city}, ${tour.country}`;
const ratingValue = tour.rating ?? 0;
---

<a
  href={`/tours/${tour.slug}`}
  class="tour-card group block overflow-hidden rounded-2xl bg-white border border-gray-100 shadow-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
>
  {/* Image */}
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    {tour.thumbnail ? (
      <img
        src={tour.thumbnail}
        alt={tour.name}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-400 to-primary-600">
        <svg class="h-16 w-16 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    )}

    {/* Bottom gradient overlay for pill readability */}
    <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>

    {/* Top gradient for heart button */}
    <div class="absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black/20 to-transparent pointer-events-none"></div>

    {/* Category pill - top left */}
    <span class="absolute top-3 left-3 rounded-full bg-white/90 backdrop-blur-sm px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-gray-700 shadow-sm">
      {tour.category}
    </span>

    {/* Duration pill - bottom left */}
    {tour.duration_days && (
      <span class="absolute bottom-3 left-3 rounded-full bg-white/90 backdrop-blur-sm px-2.5 py-1 text-xs font-semibold text-gray-700 shadow-sm flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {tour.duration_days} {tour.duration_days === 1 ? 'day' : 'days'}
      </span>
    )}

    {/* Price badge - bottom right */}
    <div class="absolute bottom-3 right-3 rounded-full bg-white/90 backdrop-blur-sm px-3 py-1 shadow-sm">
      <span class="text-xs text-gray-500">From </span>
      <span class="text-sm font-bold text-gray-900">{symbol}{Number(tour.price).toLocaleString()}</span>
    </div>

    {/* Wishlist heart button - top right */}
    <button
      type="button"
      class="wishlist-btn absolute top-3 right-3 flex h-9 w-9 items-center justify-center rounded-full bg-white/80 backdrop-blur-sm shadow-sm transition-all hover:bg-white hover:scale-110"
      data-tour-id={tour.id}
      aria-label="Add to favourites"
      onclick="event.preventDefault(); event.stopPropagation();"
    >
      <svg class="wishlist-icon-outline h-5 w-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <svg class="wishlist-icon-filled hidden h-5 w-5 text-red-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
  </div>

  {/* Content */}
  <div class="p-4">
    <h3 class="text-[15px] font-semibold text-gray-900 leading-snug transition-colors group-hover:text-primary-600 line-clamp-2">
      {tour.name}
    </h3>

    {/* Destination */}
    <div class="mt-1.5 flex items-center gap-1 text-sm text-gray-500">
      <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="line-clamp-1">{destinationLabel}</span>
    </div>

    {/* Divider */}
    <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
      {/* Rating */}
      <div class="flex items-center gap-2">
        {tour.rating != null && (
          <div class="flex items-center gap-1">
            <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span class="text-sm font-semibold text-gray-800">{ratingValue.toFixed(1)}</span>
            {tour.review_count != null && (
              <span class="text-xs text-gray-400">({tour.review_count})</span>
            )}
          </div>
        )}
      </div>

      {/* Views & favourites */}
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1 text-xs text-gray-400" title="Views">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          {tour.view_count || 0}
        </span>
        <span class="flex items-center gap-1 text-xs text-gray-400" title="Favourites">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          {tour.favouriteCount || 0}
        </span>
      </div>
    </div>
  </div>
</a>

<script>
  let favouritesCache: string[] | null = null;
  let fetchPromise: Promise<string[]> | null = null;

  async function loadFavourites(): Promise<string[]> {
    if (favouritesCache !== null) return favouritesCache;
    if (fetchPromise) return fetchPromise;

    fetchPromise = fetch('/api/favourites')
      .then(res => {
        if (!res.ok) return [];
        return res.json();
      })
      .catch(() => []);

    favouritesCache = await fetchPromise;
    fetchPromise = null;
    return favouritesCache!;
  }

  async function initWishlistButtons() {
    const buttons = document.querySelectorAll('.wishlist-btn');
    const favs = await loadFavourites();

    buttons.forEach((btn) => {
      const tourId = (btn as HTMLElement).dataset.tourId;
      if (!tourId) return;

      const outlineIcon = btn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const filledIcon = btn.querySelector('.wishlist-icon-filled') as HTMLElement;
      if (!outlineIcon || !filledIcon) return;

      // Set initial state
      if (favs.includes(tourId)) {
        outlineIcon.classList.add('hidden');
        filledIcon.classList.remove('hidden');
      } else {
        outlineIcon.classList.remove('hidden');
        filledIcon.classList.add('hidden');
      }

      // Remove old listeners by cloning
      const newBtn = btn.cloneNode(true) as HTMLElement;
      newBtn.onclick = (e) => { e.preventDefault(); e.stopPropagation(); };
      btn.parentNode?.replaceChild(newBtn, btn);

      const newOutline = newBtn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const newFilled = newBtn.querySelector('.wishlist-icon-filled') as HTMLElement;

      newBtn.addEventListener('click', async () => {
        const isFavourited = !newOutline.classList.contains('hidden') === false;

        if (isFavourited) {
          newOutline.classList.remove('hidden');
          newFilled.classList.add('hidden');

          const res = await fetch(`/api/favourites/${tourId}`, { method: 'DELETE' });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache = favouritesCache.filter(id => id !== tourId);
          }
        } else {
          newOutline.classList.add('hidden');
          newFilled.classList.remove('hidden');
          newFilled.classList.add('wishlist-heartbeat');
          setTimeout(() => newFilled.classList.remove('wishlist-heartbeat'), 600);

          const res = await fetch('/api/favourites', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tourId }),
          });
          if (res.status === 401) {
            window.location.href = '/auth/login';
            return;
          }
          if (res.ok && favouritesCache) {
            favouritesCache.push(tourId);
          }
        }
      });
    });
  }

  initWishlistButtons();
  document.addEventListener('astro:after-swap', () => {
    favouritesCache = null;
    initWishlistButtons();
  });
</script>
