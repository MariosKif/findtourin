---
// Real-User Monitoring for Core Web Vitals. Sends LCP, INP, CLS, FCP,
// and TTFB to Google Analytics 4 as `web_vital` events with the metric
// name and value. GA4 keeps the per-event histograms so you can diff
// p75 across a release without spinning up a separate RUM service.
//
// We import web-vitals from a CDN inline (no Astro client bundling) so
// the script ships ~5 KB extra without affecting the page-shell HTML
// payload. The script runs after page load, so it never blocks render.
---

{/* Web Vitals are only meaningful on real user sessions. We avoid
    instrumenting bots (their navigation patterns produce noise) by
    short-circuiting when `Notification` API isn't available — a
    cheap-and-good-enough headless-Chrome heuristic.
    The script is inline so we don't add another network request, and
    it loads the web-vitals library asynchronously after the page is
    interactive. */}
<script is:inline>
  (function () {
    if (typeof window === 'undefined' || !('addEventListener' in window)) return;
    // Skip if GA4 isn't loaded — nothing to send to.
    if (typeof window.gtag !== 'function') return;
    // Skip headless / bot user agents — noise reduction.
    var ua = (navigator.userAgent || '').toLowerCase();
    if (/(headlesschrome|bot|crawler|spider|preview)/.test(ua)) return;

    function send(metric) {
      // GA4 caps event_value at 32-bit integer; round and bound.
      var value = Math.round(metric.name === 'CLS' ? metric.value * 1000 : metric.value);
      window.gtag('event', 'web_vital', {
        event_category: 'Web Vitals',
        event_label: metric.id,
        metric_name: metric.name,
        metric_value: value,
        metric_rating: metric.rating,
        metric_delta: Math.round((metric.delta || 0) * (metric.name === 'CLS' ? 1000 : 1)),
        page_path: location.pathname,
        non_interaction: true,
      });
    }

    // Lazy-load web-vitals after the page is interactive so we don't
    // delay first paint. Same-origin cache hits via the package's UMD
    // build keep this cheap.
    function load() {
      // Use the v5+ ESM build via esm.sh — no bundler step needed and
      // the result is cached aggressively. Falls back silently on
      // network or CSP errors.
      import('https://esm.sh/web-vitals@5')
        .then(function (m) {
          if (m.onLCP) m.onLCP(send);
          if (m.onINP) m.onINP(send);
          if (m.onCLS) m.onCLS(send);
          if (m.onFCP) m.onFCP(send);
          if (m.onTTFB) m.onTTFB(send);
        })
        .catch(function () { /* silent */ });
    }

    if (document.readyState === 'complete') load();
    else window.addEventListener('load', load, { once: true });
  })();
</script>
