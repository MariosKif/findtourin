---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { ATTRACTIONS } from '../../lib/seo/attractions';
import { slugify } from '../../lib/destinations';
import { currentYear } from '../../lib/programmatic';
import { imgUrl, imgSrcset } from '../../lib/image';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const year = currentYear();
const pageTitle = `Top tour attractions ${year} — Tickets, tips, tours`;
const metaDescription = `${ATTRACTIONS.length} curated guides to top tour attractions in Greece, Turkey, Italy, Bulgaria, and Albania. Tickets, opening hours, skip-the-line tips, and tours that visit.`;
const canonical = 'https://www.findtoursin.com/attractions';
const SITE = 'https://www.findtoursin.com';

// Group by country for the index layout.
const byCountry = ATTRACTIONS.reduce((acc, a) => {
  if (!acc[a.country]) acc[a.country] = [];
  acc[a.country].push(a);
  return acc;
}, {} as Record<string, typeof ATTRACTIONS>);
const countries = Object.keys(byCountry).sort();
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Attractions</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Top tour attractions
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl" data-speakable="true">
        {ATTRACTIONS.length} curated guides to the top attractions in our regions — tickets, opening hours, the skip-the-line trick that actually works, and tours that visit.
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {countries.map((country) => (
      <section class="mb-14">
        <h2 class="font-heading text-2xl sm:text-3xl font-normal text-gray-900 mb-6">{country}</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {byCountry[country].map((a) => (
            <a href={`/attractions/${slugify(a.country)}/${slugify(a.city)}/${a.slug}`} class="group rounded-2xl overflow-hidden border border-gray-200 hover:border-primary-400 hover:shadow-md transition-all">
              <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                <img
                  src={imgUrl(a.heroImage, 600)}
                  srcset={imgSrcset(a.heroImage, [400, 600, 800])}
                  sizes="(max-width: 640px) 100vw, 33vw"
                  alt={a.name}
                  width="600"
                  height="450"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-heading text-lg text-gray-900 group-hover:text-primary-700">{a.name}</h3>
                <p class="mt-1 text-sm text-gray-500">{a.city}{a.isUnesco ? ' · UNESCO' : ''}</p>
                {a.ticketPrice && <p class="mt-2 text-xs text-gray-400">Ticket: {a.ticketPrice}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "isPartOf": { "@id": `${SITE}/#organization` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": ATTRACTIONS.length,
    "itemListElement": ATTRACTIONS.map((a, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/attractions/${slugify(a.country)}/${slugify(a.city)}/${a.slug}`,
      "name": a.name,
    })),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Attractions", "item": canonical },
    ],
  })} />
</PublicLayout>
