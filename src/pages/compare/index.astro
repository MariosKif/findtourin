---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import { COMPETITORS } from '../../lib/seo/competitors';
import { currentYear } from '../../lib/programmatic';

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=86400, stale-while-revalidate=604800');

const year = currentYear();
const pageTitle = `Compare FindToursIn ${year} — Honest comparisons with major OTAs`;
const metaDescription = 'Side-by-side comparisons between FindToursIn and major tour-booking platforms — pricing, commission, inventory, and what each does best.';
const canonical = 'https://www.findtoursin.com/compare';
const SITE = 'https://www.findtoursin.com';
---

<PublicLayout title={pageTitle} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-primary-50 to-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Compare</span>
      </nav>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-gray-900 leading-tight">
        Compare FindToursIn
      </h1>
      <p class="mt-4 text-lg text-gray-700 max-w-2xl" data-speakable="true">
        Honest, dated comparisons between FindToursIn and {COMPETITORS.length} major tour-booking platforms — including what each does better than us. Use these to pick the right platform for your trip.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-4 sm:grid-cols-2">
      {COMPETITORS.map((c) => (
        <a href={`/compare/findtoursin-vs-${c.slug}`} class="group rounded-2xl border border-gray-200 p-6 hover:border-primary-400 hover:shadow-md transition-all">
          <h2 class="font-heading text-xl text-gray-900 group-hover:text-primary-700">FindToursIn vs {c.name}</h2>
          <p class="mt-2 text-sm text-gray-600">Founded {c.founded} · {c.hq}</p>
          <p class="mt-3 text-gray-700 text-sm leading-relaxed">{c.description.slice(0, 130)}…</p>
        </a>
      ))}
    </div>

    <section class="mt-14 p-6 rounded-2xl bg-gray-50 border border-gray-200">
      <h2 class="font-heading text-xl text-gray-900 mb-3">Looking for alternatives?</h2>
      <p class="text-gray-600 mb-4">If you\'re considering switching from one of these platforms, our alternatives pages break down the options.</p>
      <div class="flex flex-wrap gap-2">
        {COMPETITORS.map((c) => (
          <a href={`/alternatives/${c.slug}-alternatives`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary-400 hover:text-primary-700 transition-colors">{c.name} alternatives</a>
        ))}
      </div>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": metaDescription,
    "url": canonical,
    "isPartOf": { "@id": `${SITE}/#organization` },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "numberOfItems": COMPETITORS.length,
    "itemListElement": COMPETITORS.map((c, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/compare/findtoursin-vs-${c.slug}`,
      "name": `FindToursIn vs ${c.name}`,
    })),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/` },
      { "@type": "ListItem", "position": 2, "name": "Compare", "item": canonical },
    ],
  })} />
</PublicLayout>
