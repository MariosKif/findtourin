---
export const prerender = false;
import { getCollection } from 'astro:content';
import PublicLayout from '../../../layouts/PublicLayout.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';

const { tag } = Astro.params;
if (!tag) return Astro.redirect('/blog');

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, '-');

const posts = allPosts
  .filter((p) => slugify(p.data.category) === tag || p.data.tags.some((t) => slugify(t) === tag))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

if (posts.length === 0) return Astro.redirect('/blog');

const displayTag = tag.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<PublicLayout title={`${displayTag} — Blog`} description={`Blog posts about ${displayTag} on FindToursIn.`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {/* Breadcrumbs */}
    <nav class="mb-8 text-sm text-gray-500">
      <a href="/" class="hover:text-primary-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-primary-600">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{displayTag}</span>
    </nav>

    <div class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl text-gray-900 mb-3">{displayTag}</h1>
      <p class="text-gray-600">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-400 text-lg">No posts found for this tag.</p>
        <a href="/blog" class="mt-4 inline-block text-primary-600 hover:underline">Back to all posts</a>
      </div>
    )}
  </div>
</PublicLayout>
