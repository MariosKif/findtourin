---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="About Us" description="Learn about FindToursIn — connecting travelers with trusted tour agencies worldwide.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <!-- Hero -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900">About FindToursIn</h1>
      <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto">
        We connect curious travelers with trusted tour agencies around the globe, making it easy to discover your next adventure.
      </p>
    </div>

    <!-- Mission -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h2>
      <p class="text-gray-600 leading-relaxed">
        FindToursIn was built with a simple idea: finding great tours shouldn't be complicated. We provide a curated marketplace where tour agencies can showcase their experiences and travelers can easily browse, compare, and reach out directly to book.
      </p>
      <p class="mt-4 text-gray-600 leading-relaxed">
        We believe in direct connections. Unlike booking platforms that add layers between you and the agency, we simply help you find the right tour and let you contact the agency directly — by email, phone, or their website.
      </p>
    </section>

    <!-- How It Works -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">How It Works</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-primary-50 rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-primary-900 mb-2">For Travelers</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-primary-500 mt-1">&#10003;</span>
              Browse hundreds of curated tours
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-500 mt-1">&#10003;</span>
              Filter by destination, category, and price
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-500 mt-1">&#10003;</span>
              Contact agencies directly — no middleman
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-500 mt-1">&#10003;</span>
              Completely free to use
            </li>
          </ul>
        </div>
        <div class="bg-secondary-50 rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-secondary-900 mb-2">For Agencies</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-secondary-500 mt-1">&#10003;</span>
              List your tours to reach more travelers
            </li>
            <li class="flex items-start gap-2">
              <span class="text-secondary-500 mt-1">&#10003;</span>
              Simple dashboard to manage listings
            </li>
            <li class="flex items-start gap-2">
              <span class="text-secondary-500 mt-1">&#10003;</span>
              One-time listing fee per tour
            </li>
            <li class="flex items-start gap-2">
              <span class="text-secondary-500 mt-1">&#10003;</span>
              Travelers contact you directly
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-gray-900 text-white rounded-2xl p-12 text-center">
      <div class="grid grid-cols-3 gap-8">
        <div>
          <p class="text-3xl font-bold">500+</p>
          <p class="mt-1 text-gray-300 text-sm">Tours Listed</p>
        </div>
        <div>
          <p class="text-3xl font-bold">200+</p>
          <p class="mt-1 text-gray-300 text-sm">Trusted Agencies</p>
        </div>
        <div>
          <p class="text-3xl font-bold">50+</p>
          <p class="mt-1 text-gray-300 text-sm">Countries</p>
        </div>
      </div>
    </section>
  </div>
</PublicLayout>
