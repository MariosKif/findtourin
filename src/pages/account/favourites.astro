---
export const prerender = false;
import AccountLayout from '../../layouts/AccountLayout.astro';
import TourCard from '../../components/tours/TourCard.astro';
import { favouritesCol, toursCol, docToObj, type TourDoc, type FavouriteDoc } from '../../lib/firestore';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// Get favourited tours with their first image
const favSnapshot = await favouritesCol().where('userId', '==', user.id).get();
const tourIds = favSnapshot.docs.map(doc => doc.data().tourId);

const allTours: any[] = [];
if (tourIds.length > 0) {
  const chunks = [];
  for (let i = 0; i < tourIds.length; i += 10) {
    chunks.push(tourIds.slice(i, i + 10));
  }
  for (const chunk of chunks) {
    const snapshot = await toursCol().where('__name__', 'in', chunk).get();
    snapshot.docs.forEach(doc => {
      const data = doc.data();
      allTours.push({ id: doc.id, ...data, thumbnail: data.images?.[0]?.url || null });
    });
  }
}
const toursWithThumbnails = allTours;
---

<AccountLayout title="Favourites">
  {toursWithThumbnails.length > 0 ? (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {toursWithThumbnails.map((tour) => (
        <TourCard tour={tour} />
      ))}
    </div>
  ) : (
    <div class="text-center py-16">
      <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <h2 class="mt-4 text-xl font-semibold text-gray-900">No favourites yet</h2>
      <p class="mt-2 text-gray-600">Browse our tours and tap the heart icon to save your favourites.</p>
      <a href="/tours" class="mt-6 inline-block rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-primary-700 transition-colors">
        Explore Tours
      </a>
    </div>
  )}
</AccountLayout>
