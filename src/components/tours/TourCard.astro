---
import { imgUrl, imgSrcset } from '../../lib/image';

interface Props {
  /** Position of this card in the rendered list — used to gate eager image
      loading to roughly the first row above the fold. Cards beyond
      `eagerThreshold` (default 4) lazy-load all their images. */
  index?: number;
  eagerThreshold?: number;
  tour: {
    id: string;
    name: string;
    slug: string;
    description: string;
    country: string;
    city: string;
    departure_country?: string | null;
    departure_city?: string | null;
    price: string;
    currency: string;
    category: string;
    duration_days?: number | null;
    thumbnail: string | null;
    images?: { url: string }[];
    rating?: number;
    review_count?: number;
    view_count?: number;
    favouriteCount?: number;
  };
}

const { tour, index = 0, eagerThreshold = 4 } = Astro.props;
const isAboveFold = index < eagerThreshold;

const currencySymbols: Record<string, string> = {
  EUR: '\u20AC',
  USD: '$',
  GBP: '\u00A3',
};
const symbol = currencySymbols[tour.currency] || tour.currency;
const ratingValue = tour.rating ?? 0;

// Collect all image URLs for the carousel
const allImages = (tour.images && tour.images.length > 0)
  ? tour.images.map(img => img.url)
  : tour.thumbnail
    ? [tour.thumbnail]
    : [];
const hasMultipleImages = allImages.length > 1;
const cardId = `card-${tour.id}`;

// Card renders ~210–350px wide depending on breakpoint. Two retina widths
// cover everything from mobile (50vw) to 6-col desktop (16vw).
const CARD_WIDTHS = [320, 480, 640];
const CARD_SIZES = '(max-width: 549px) 100vw, (max-width: 949px) 33vw, 20vw';
---

<div class="tour-card group" id={cardId}>
  {/* Image carousel */}
  <div class="relative aspect-square overflow-hidden rounded-xl bg-gray-100">
    {/* Images */}
    <a href={`/tours/${tour.slug}`} class="block h-full w-full">
      <div class="carousel-track flex h-full w-full transition-transform duration-300 ease-out" data-card={cardId} data-total={allImages.length}>
        {allImages.length > 0 ? (
          allImages.map((url, i) => (
            <div
              class="h-full w-full flex-shrink-0 bg-gray-100"
              data-slide={i}
              data-src={i === 0 ? undefined : imgUrl(url, 600)}
              data-srcset={i === 0 ? undefined : imgSrcset(url, CARD_WIDTHS)}
              data-sizes={i === 0 ? undefined : CARD_SIZES}
              data-alt={i === 0 ? undefined : `${tour.name} - photo ${i + 1}`}
            >
              {i === 0 && (
                <img
                  src={imgUrl(url, 600)}
                  srcset={imgSrcset(url, CARD_WIDTHS)}
                  sizes={CARD_SIZES}
                  alt={tour.name}
                  width="600"
                  height="600"
                  class="h-full w-full object-cover"
                  loading={isAboveFold ? 'eager' : 'lazy'}
                  decoding="async"
                  fetchpriority={isAboveFold ? 'high' : undefined}
                />
              )}
            </div>
          ))
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-gray-200 to-gray-300">
            <svg class="h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        )}
      </div>
    </a>

    {/* Carousel arrows (visible on hover, hidden if 1 image) */}
    {hasMultipleImages && (
      <>
        <button
          class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white shadow-md opacity-0 group-hover:opacity-100 transition-opacity hover:scale-105 z-10"
          data-card={cardId}
          aria-label="Previous image"
        >
          <svg class="h-3 w-3 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white shadow-md opacity-0 group-hover:opacity-100 transition-opacity hover:scale-105 z-10"
          data-card={cardId}
          aria-label="Next image"
        >
          <svg class="h-3 w-3 text-gray-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </>
    )}

    {/* Dot indicators */}
    {hasMultipleImages && (
      <div class="carousel-dots absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
        {allImages.map((_, i) => (
          <span class:list={[
            'h-1.5 w-1.5 rounded-full transition-all',
            i === 0 ? 'bg-white scale-100' : 'bg-white/50 scale-75',
          ]} data-dot={i} />
        ))}
      </div>
    )}

    {/* Wishlist heart button */}
    <button
      type="button"
      class="wishlist-btn absolute top-2.5 right-2.5 z-10"
      data-tour-id={tour.id}
      aria-label="Add to favourites"
    >
      <svg class="wishlist-icon-outline h-6 w-6 drop-shadow-sm" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M16 28c-.6 0-1.1-.2-1.5-.5C7 21.5 4 18 4 13.5 4 9.9 6.9 7 10.5 7c1.9 0 3.8.9 5 2.3L16 10l.5-.7C17.7 7.9 19.6 7 21.5 7 25.1 7 28 9.9 28 13.5c0 4.5-3 8-8.5 14-.4.3-.9.5-1.5.5z" fill="rgba(0,0,0,0.5)" stroke="white" stroke-width="2" />
      </svg>
      <svg class="wishlist-icon-filled hidden h-6 w-6 drop-shadow-sm" viewBox="0 0 32 32" fill="none">
        <path d="M16 28c-.6 0-1.1-.2-1.5-.5C7 21.5 4 18 4 13.5 4 9.9 6.9 7 10.5 7c1.9 0 3.8.9 5 2.3L16 10l.5-.7C17.7 7.9 19.6 7 21.5 7 25.1 7 28 9.9 28 13.5c0 4.5-3 8-8.5 14-.4.3-.9.5-1.5.5z" fill="#FF385C" stroke="white" stroke-width="2" />
      </svg>
    </button>
  </div>

  {/* Content */}
  <a href={`/tours/${tour.slug}`} class="block mt-2">
    {/* Name */}
    <h3 class="text-[15px] font-semibold text-gray-900 leading-snug truncate">
      {tour.name}
    </h3>

    {/* Location */}
    <p class="text-[15px] text-gray-500 truncate">{tour.city}, {tour.country}</p>

    {/* Duration */}
    {tour.duration_days && (
      <p class="text-[15px] text-gray-500">{tour.duration_days} {tour.duration_days === 1 ? 'day' : 'days'}</p>
    )}

    {/* Price + Rating */}
    <div class="mt-1 flex items-center gap-1 text-[15px]">
      <span class="font-semibold text-gray-900">From {symbol}{Number(tour.price).toLocaleString()}</span>
      {ratingValue > 0 && (
        <>
          <span class="text-gray-400 mx-0.5">&middot;</span>
          <svg class="h-3 w-3 text-gray-900" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-gray-900">{ratingValue.toFixed(2)}</span>
        </>
      )}
    </div>

    {/* Views & Favourites — hidden until at least one has real data */}
    {((tour.view_count ?? 0) > 0 || (tour.favouriteCount ?? 0) > 0) && (
      <div class="mt-0.5 flex items-center gap-3">
        {(tour.view_count ?? 0) > 0 && (
          <span class="flex items-center gap-1 text-xs text-gray-400">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            {tour.view_count}
          </span>
        )}
        {(tour.favouriteCount ?? 0) > 0 && (
          <span class="flex items-center gap-1 text-xs text-gray-400">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            {tour.favouriteCount}
          </span>
        )}
      </div>
    )}
  </a>
</div>

<script>
  // === Image carousel ===
  function initCarousels() {
    document.querySelectorAll('.carousel-next').forEach(btn => {
      if ((btn as HTMLElement).dataset.init) return;
      (btn as HTMLElement).dataset.init = '1';
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const cardId = (btn as HTMLElement).dataset.card!;
        slideCarousel(cardId, 1);
      });
    });

    document.querySelectorAll('.carousel-prev').forEach(btn => {
      if ((btn as HTMLElement).dataset.init) return;
      (btn as HTMLElement).dataset.init = '1';
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const cardId = (btn as HTMLElement).dataset.card!;
        slideCarousel(cardId, -1);
      });
    });

    // Touch swipe support
    document.querySelectorAll('.carousel-track').forEach(track => {
      if ((track as HTMLElement).dataset.swipeInit) return;
      (track as HTMLElement).dataset.swipeInit = '1';
      let startX = 0;
      let isDragging = false;

      track.addEventListener('touchstart', (e) => {
        startX = (e as TouchEvent).touches[0].clientX;
        isDragging = true;
        const card = (track as HTMLElement).closest('.tour-card') as HTMLElement | null;
        if (card) hydrateLazySlides(card);
      }, { passive: true });

      track.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const endX = (e as TouchEvent).changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 40) {
          const cardId = (track as HTMLElement).dataset.card!;
          slideCarousel(cardId, diff > 0 ? 1 : -1);
        }
      }, { passive: true });
    });
  }

  // Cards render only the first image's <img>; other slides are data-only
  // placeholders. On the first carousel interaction we hydrate the rest.
  // Saves ~80% of <img> tags on /tours (197 → ~40) without changing layout.
  function hydrateLazySlides(card: HTMLElement) {
    const slides = card.querySelectorAll<HTMLElement>('[data-slide]');
    slides.forEach((slide) => {
      if (slide.querySelector('img')) return;
      const src = slide.dataset.src;
      if (!src) return;
      const img = document.createElement('img');
      img.src = src;
      if (slide.dataset.srcset) img.srcset = slide.dataset.srcset;
      if (slide.dataset.sizes) img.sizes = slide.dataset.sizes;
      img.alt = slide.dataset.alt || '';
      img.width = 600;
      img.height = 600;
      img.className = 'h-full w-full object-cover';
      img.loading = 'lazy';
      img.decoding = 'async';
      slide.appendChild(img);
    });
  }

  function slideCarousel(cardId: string, direction: number) {
    const card = document.getElementById(cardId);
    if (!card) return;
    const track = card.querySelector('.carousel-track') as HTMLElement;
    const dots = card.querySelectorAll('[data-dot]');
    if (!track) return;

    hydrateLazySlides(card);

    const totalSlides = Number(track.dataset.total || track.children.length);
    if (totalSlides <= 1) return;

    let currentIndex = parseInt(track.dataset.index || '0');
    currentIndex += direction;

    if (currentIndex < 0) currentIndex = totalSlides - 1;
    if (currentIndex >= totalSlides) currentIndex = 0;

    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    track.dataset.index = String(currentIndex);

    // Update dots
    dots.forEach((dot, i) => {
      if (i === currentIndex) {
        dot.classList.remove('bg-white/50', 'scale-75');
        dot.classList.add('bg-white', 'scale-100');
      } else {
        dot.classList.add('bg-white/50', 'scale-75');
        dot.classList.remove('bg-white', 'scale-100');
      }
    });
  }

  initCarousels();
  document.addEventListener('astro:after-swap', initCarousels);

  // === Wishlist ===
  let favouritesCache: string[] | null = null;
  let fetchPromise: Promise<string[]> | null = null;

  async function loadFavourites(): Promise<string[]> {
    if (favouritesCache !== null) return favouritesCache;
    if (fetchPromise) return fetchPromise;
    fetchPromise = fetch('/api/favourites').then(r => r.ok ? r.json() : []).catch(() => []);
    favouritesCache = await fetchPromise;
    fetchPromise = null;
    return favouritesCache!;
  }

  async function initWishlistButtons() {
    const buttons = document.querySelectorAll('.wishlist-btn');
    const favs = await loadFavourites();

    buttons.forEach((btn) => {
      const tourId = (btn as HTMLElement).dataset.tourId;
      if (!tourId) return;

      const outline = btn.querySelector('.wishlist-icon-outline') as HTMLElement;
      const filled = btn.querySelector('.wishlist-icon-filled') as HTMLElement;
      if (!outline || !filled) return;

      if (favs.includes(tourId)) {
        outline.classList.add('hidden');
        filled.classList.remove('hidden');
      } else {
        outline.classList.remove('hidden');
        filled.classList.add('hidden');
      }

      const newBtn = btn.cloneNode(true) as HTMLElement;
      newBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const o = newBtn.querySelector('.wishlist-icon-outline') as HTMLElement;
        const f = newBtn.querySelector('.wishlist-icon-filled') as HTMLElement;
        const isFav = o.classList.contains('hidden');

        if (isFav) {
          o.classList.remove('hidden');
          f.classList.add('hidden');
          const res = await fetch(`/api/favourites/${tourId}`, { method: 'DELETE' });
          if (res.status === 401) { window.location.href = '/auth/login'; return; }
          if (res.ok && favouritesCache) favouritesCache = favouritesCache.filter(id => id !== tourId);
        } else {
          o.classList.add('hidden');
          f.classList.remove('hidden');
          const res = await fetch('/api/favourites', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tourId }),
          });
          if (res.status === 401) { window.location.href = '/auth/login'; return; }
          if (res.ok && favouritesCache) favouritesCache.push(tourId);
        }
      });
      btn.parentNode?.replaceChild(newBtn, btn);
    });
  }

  initWishlistButtons();
  document.addEventListener('astro:after-swap', () => {
    favouritesCache = null;
    initWishlistButtons();
  });
</script>
