---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Server Error">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <p class="text-8xl font-bold text-red-200">500</p>
    <h1 class="mt-4 text-3xl font-bold text-gray-900">Something Went Wrong</h1>
    <p class="mt-4 text-lg text-gray-600 max-w-md">
      We're experiencing technical difficulties. Please try again later.
    </p>
    <div class="mt-8">
      <a href="/" class="px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">
        Go Home
      </a>
    </div>
  </div>
</PublicLayout>
